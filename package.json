{
  "name": "whatsforlunch",
  "version": "0.0.0",
  "private": true,
  "description": "Track leftovers and pantry inventory. Stop wasting food.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,md,yaml,yml}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,jsx,json,md,yaml,yml}'",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:e2e": "pnpm --filter @wfl/mobile test:e2e",
    "graphql:codegen": "pnpm --filter @wfl/shared graphql:codegen",
    "graphql:validate": "pnpm --filter @wfl/infra graphql:validate",
    "cdk:synth": "pnpm --filter @wfl/infra cdk synth",
    "cdk:deploy": "pnpm --filter @wfl/infra cdk deploy",
    "ai:eval": "pnpm --filter @wfl/services ai:eval",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
