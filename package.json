{
  "name": "whatsforlunch",
  "version": "0.0.0",
  "private": true,
  "description": "Track leftovers and pantry inventory. Stop wasting food.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,md,yaml,yml}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,jsx,json,md,yaml,yml}'",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:e2e": "pnpm --filter @wfl/mobile test:e2e",
    "graphql:codegen": "pnpm --filter @wfl/shared graphql:codegen",
    "graphql:validate": "pnpm --filter @wfl/infra graphql:validate",
    "cdk:synth": "pnpm --filter @wfl/infra cdk:synth",
    "cdk:deploy": "pnpm --filter @wfl/infra cdk:deploy",
    "cdk:watch": "pnpm --filter @wfl/infra cdk:watch",
    "cdk:outputs": "pnpm --filter @wfl/infra cdk:outputs",
    "cdk:destroy": "pnpm --filter @wfl/infra cdk:destroy",
    "seed:dev": "pnpm --filter @wfl/mobile seed:dev",
    "dev:mobile": "pnpm --filter @wfl/mobile dev",
    "dev:web": "pnpm --filter @wfl/web dev",
    "build:web": "pnpm --filter @wfl/web build",
    "ai:eval": "pnpm --filter @wfl/services ai:eval",
    "local:api": "pnpm --filter @wfl/local-mock dev",
    "local:dev": "docker-compose -f docker-compose.local.yml up -d && sleep 3 && pnpm local:migrate && pnpm --filter @wfl/mobile dev",
    "local:setup": "docker-compose -f docker-compose.local.yml pull && docker-compose -f docker-compose.local.yml up -d && sleep 3 && pnpm local:migrate",
    "local:start": "docker-compose -f docker-compose.local.yml up -d",
    "local:stop": "docker-compose -f docker-compose.local.yml stop",
    "local:down": "docker-compose -f docker-compose.local.yml down",
    "local:logs": "docker-compose -f docker-compose.local.yml logs -f",
    "local:api-logs": "docker-compose -f docker-compose.local.yml logs -f mock-api",
    "local:migrate": "tsx scripts/local/dynamodb-setup.ts",
    "local:seed": "tsx scripts/local/seed-data.ts",
    "local:test": "pnpm --filter @wfl/local-mock integration-test",
    "bench:local": "tsx scripts/benchmarks/api-benchmark.ts",
    "bench:staging": "API_URL=$STAGING_API_URL tsx scripts/benchmarks/api-benchmark.ts",
    "local:reset": "docker-compose -f docker-compose.local.yml down -v && docker-compose -f docker-compose.local.yml up -d && sleep 3 && pnpm local:migrate && pnpm local:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "concurrently": "^9.1.0",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "tsx": "^4.9.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
