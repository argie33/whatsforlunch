# WhatsFresh Production Configuration
# Copy to .env.production and fill in actual values

# ============================================
# Authentication & API
# ============================================
EXPO_PUBLIC_AUTH_MODE=aws
EXPO_PUBLIC_APPSYNC_URL=https://your-appsync-endpoint.appsync-api.us-east-1.amazonaws.com/graphql

# ============================================
# Image CDN (for item photos)
# ============================================
# Set to your CloudFront distribution domain
# Format: https://d1234abcd.cloudfront.net (no trailing slash)
EXPO_PUBLIC_CDN_DOMAIN=d1234abcd.cloudfront.net

# ============================================
# Claude AI API (for food classification fallback)
# ============================================
# Get from https://console.anthropic.com/api_keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ============================================
# AWS Region (backend Lambda functions)
# ============================================
AWS_REGION=us-east-1

# ============================================
# DynamoDB Table (for classification logging)
# ============================================
DYNAMODB_TABLE=wfl-main-prod

# ============================================
# S3 Bucket (for classification export for ML pipeline)
# ============================================
CLASSIFICATION_LOGS_BUCKET=wfl-classification-logs-prod

# ============================================
# PostHog Analytics (optional)
# ============================================
EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# Sentry Error Tracking (optional)
# ============================================
EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================
# RevenueCat Subscriptions (optional)
# ============================================
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_xxxxxxxxxxxxxxxx
