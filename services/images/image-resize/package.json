{
  "name": "@wfl/image-resize-lambda",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --external:@aws-sdk/* --external:sharp --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@aws-lambda-powertools/commons": "^1.19.0",
    "@aws-lambda-powertools/logger": "^1.19.0",
    "@aws-sdk/client-s3": "^3.681.0",
    "sharp": "^0.33.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.39",
    "@types/node": "^20.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.7.2"
  }
}
