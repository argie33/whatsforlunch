---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';
---

<BaseLayout title="Login — WhatsFresh" noIndex={true}>
  <main style="height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #2A4A3A 0%, #1A3A2A 100%); padding: 20px;">
    <div style="width: 100%; max-width: 360px;">
      <!-- Logo -->
      <div style="text-align: center; margin-bottom: 32px;">
        <div
          style="width: 56px; height: 56px; background: var(--brand); border-radius: var(--r-lg); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 28px;"
        >
          🥦
        </div>
        <h1 style="font-size: 28px; font-weight: 800; margin: 0 0 8px 0; color: white;">WhatsFresh</h1>
        <p style="font-size: 14px; color: rgba(255,255,255,0.8); margin: 0;">Track what's fresh</p>
      </div>

      <!-- Form -->
      <Card>
        <div style="padding: 24px;">
          <div id="error-message" style="color: var(--urgent); margin-bottom: 16px; display: none; padding: 12px; background: var(--urgent-bg); border-radius: var(--r-md); font-size: 14px;"></div>

          <div style="margin-bottom: 16px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--t1);">Email</label>
            <input
              id="email-input"
              type="email"
              placeholder="your@email.com"
              style="width: 100%; padding: 12px; border: 1px solid var(--b1); border-radius: var(--r-md); font-size: 14px; font-family: inherit; box-sizing: border-box;"
            />
          </div>

          <button id="submit-btn" style="width: 100%; padding: 16px 24px; background: var(--brand); color: white; border: none; border-radius: var(--r-md); font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s;">
            Sign In
          </button>
        </div>
      </Card>

      <!-- Links -->
      <div style="text-align: center; margin-top: 16px;">
        <span style="color: rgba(255,255,255,0.8); font-size: 13px;">Dev: Use any email to test</span>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  input:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-soft);
  }

  #submit-btn:hover {
    background: var(--brand-dark);
    transform: translateY(-1px);
  }

  #submit-btn:active {
    transform: scale(0.98);
  }

  #submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script>
  import { login, initAuth } from '@/lib/auth';

  initAuth();

  const emailInput = document.getElementById('email-input') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorMsg = document.getElementById('error-message') as HTMLDivElement;

  submitBtn.addEventListener('click', async () => {
    const email = emailInput.value.trim();

    if (!email) {
      errorMsg.textContent = 'Please enter an email';
      errorMsg.style.display = 'block';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Signing in...';
    errorMsg.style.display = 'none';

    try {
      await login(email);
      window.location.href = '/app/dashboard';
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Login failed';
      errorMsg.textContent = message;
      errorMsg.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Sign In';
    }
  });

  emailInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') submitBtn.click();
  });
</script>
