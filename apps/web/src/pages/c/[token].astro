---
import { APP_LINKS } from '@/config/app-links';

/**
 * QR sticker redirect page — /c/:token
 *
 * Behavior:
 * - The <meta http-equiv="refresh"> fires immediately and opens the app via Universal Link.
 * - On iOS: whatsfresh://c/TOKEN universal link fires first (app installed) or
 *   falls through to the App Store.
 * - On Android: App Link fires or falls through to Play Store.
 * - If neither fires (desktop browser), shows this page with download CTAs.
 *
 * AAAS file at /.well-known/apple-app-site-association handles the Universal Link.
 */

const { token } = Astro.params;
const deepLink = `${APP_LINKS.deepLinkScheme}c/${token}`;
const appStoreUrl = APP_LINKS.appStore;
const playStoreUrl = APP_LINKS.playStore;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Opening WhatsFresh…</title>
    <!-- Attempt to open app immediately -->
    <meta http-equiv="refresh" content={`0; url=${deepLink}`} />
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #FBFAF7; margin: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; text-align: center; }
      .card { background: white; border-radius: 1.5rem; padding: 2.5rem 2rem; max-width: 360px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
      h1 { font-size: 1.5rem; font-weight: 700; color: #111; margin-bottom: .5rem; }
      p { color: #666; font-size: 1rem; line-height: 1.5; margin-bottom: 2rem; }
      .btn { display: inline-flex; align-items: center; gap: .6rem; padding: .85rem 1.5rem; border-radius: 1rem; font-weight: 600; font-size: 1rem; text-decoration: none; transition: opacity .15s; width: 100%; justify-content: center; box-sizing: border-box; margin-bottom: .75rem; }
      .btn:hover { opacity: .85; }
      .btn-dark { background: #111; color: #fff; }
      .btn-outline { background: white; color: #111; border: 1.5px solid #ddd; }
      .logo { width: 56px; height: 56px; background: #2F7D5B; border-radius: 1rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; }
    </style>
  </head>
  <body>
    <div class="card" role="main">
      <div class="logo" aria-hidden="true">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none">
          <rect x="5" y="2" width="14" height="20" rx="3" fill="white" fill-opacity="0.9"/>
          <rect x="5" y="2" width="14" height="9" rx="3" fill="white"/>
          <circle cx="9" cy="6" r="1.5" fill="#E85C38"/>
          <circle cx="13" cy="6" r="1.5" fill="#E8A838"/>
          <circle cx="9" cy="15" r="1.5" fill="#2F7D5B"/>
        </svg>
      </div>

      <h1>Opening WhatsFresh…</h1>
      <p>If the app didn't open, download it below — then scan this QR code again.</p>

      <a href={appStoreUrl} class="btn btn-dark" aria-label="Download WhatsFresh on the App Store">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Download on App Store
      </a>

      <a href={playStoreUrl} class="btn btn-outline" aria-label="Get WhatsFresh on Google Play">
        Get it on Google Play
      </a>

      <p style="font-size:.85rem; margin-top:1rem; margin-bottom:0;">
        Already have the app?{' '}
        <a href={deepLink} style="color:#2F7D5B; font-weight:600; text-decoration:none;">Open it now</a>
      </p>
    </div>

    <!-- After 3 seconds of inaction, show the download options more prominently -->
    <script>
      // If user is still here after 1.5s, they probably don't have the app
      setTimeout(() => {
        document.querySelector('h1').textContent = 'Get the app to open this container.';
      }, 1500);
    </script>
  </body>
</html>
