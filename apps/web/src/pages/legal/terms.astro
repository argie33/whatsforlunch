---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service — WhatsFresh">
  <main style="display: flex; flex-direction: column; min-height: 100vh; background: var(--bg); padding: 20px; max-width: 800px; margin: 0 auto;">
    <h1 style="font-size: 28px; font-weight: 800; margin-bottom: 8px; color: var(--t1);">Terms of Service</h1>
    <p style="font-size: 13px; color: var(--t2); margin-bottom: 32px;">Last updated: May 2026</p>

    <div style="color: var(--t1); line-height: 1.6; display: flex; flex-direction: column; gap: 20px; margin-bottom: 40px;">
      <section>
        <h2 style="font-size: 20px; font-weight: 700; margin-bottom: 12px; color: var(--t1);">1. Agreement</h2>
        <p>By using WhatsFresh, you agree to these terms and our privacy policy.</p>
      </section>

      <section>
        <h2 style="font-size: 20px; font-weight: 700; margin-bottom: 12px; color: var(--t1);">2. License</h2>
        <p>We grant you a non-exclusive, non-transferable license to use our app subject to these terms.</p>
      </section>

      <section>
        <h2 style="font-size: 20px; font-weight: 700; margin-bottom: 12px; color: var(--t1);">3. Restrictions</h2>
        <p>You may not reverse engineer, decompile, or attempt to gain unauthorized access to our service.</p>
      </section>

      <section>
        <h2 style="font-size: 20px; font-weight: 700; margin-bottom: 12px; color: var(--t1);">4. Disclaimers</h2>
        <p>WhatsFresh is provided "as is" without warranties. We are not liable for food-related health issues.</p>
      </section>

      <section>
        <h2 style="font-size: 20px; font-weight: 700; margin-bottom: 12px; color: var(--t1);">5. Changes</h2>
        <p>We may update these terms at any time. Continued use indicates acceptance of changes.</p>
      </section>

      <section>
        <h2 style="font-size: 20px; font-weight: 700; margin-bottom: 12px; color: var(--t1);">6. Contact</h2>
        <p>For terms questions, contact us at legal@whatsfresh.app</p>
      </section>
    </div>

    <a href="/" style="color: var(--brand); text-decoration: none; font-weight: 600;">← Back to home</a>
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
