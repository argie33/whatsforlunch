---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import InsightCard from '@/components/InsightCard.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Weekly Digest — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Weekly Digest" subtitle="May 1 - May 8" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Summary Cards -->
      <div style="padding: 16px 22px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
          <Card>
            <div style="padding: 16px; text-align: center;">
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 8px 0; letter-spacing: 1.5px;">Items Used</p>
              <p id="items-used" style="font-size: 28px; font-weight: 800; color: var(--fresh); margin: 0;">0</p>
            </div>
          </Card>
          <Card>
            <div style="padding: 16px; text-align: center;">
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 8px 0; letter-spacing: 1.5px;">Waste Prevented</p>
              <p id="waste-prevented" style="font-size: 28px; font-weight: 800; color: var(--fresh); margin: 0;">$0</p>
            </div>
          </Card>
        </div>

        <!-- Highlights -->
        <InsightCard
          eyebrow="Weekly Highlight"
          title="Great Week!"
          text="You prevented $34 in food waste. Keep it up!"
          icon="🎉"
        />

        <!-- Expiring Soon -->
        <p class="eyebrow" style="margin: 24px 0 12px 0;">⏰ Expiring Soon</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 10px;">
            <div style="display: flex; gap: 12px; align-items: center;">
              <span style="font-size: 24px;">🥦</span>
              <div style="flex: 1;">
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">Broccoli</p>
                <p style="font-size: 12px; color: var(--soon); margin: 0;">Expires in 2 days</p>
              </div>
            </div>
            <div style="display: flex; gap: 12px; align-items: center;">
              <span style="font-size: 24px;">🥬</span>
              <div style="flex: 1;">
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">Spinach</p>
                <p style="font-size: 12px; color: var(--soon); margin: 0;">Expires in 3 days</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Achievements -->
        <p class="eyebrow" style="margin-bottom: 12px;">🏆 Achievements Earned</p>
        <Card>
          <div style="padding: 16px; text-align: center;">
            <p style="font-size: 40px; margin: 0 0 8px 0;">🔥</p>
            <p style="font-size: 14px; font-weight: 600; margin: 0 0 4px 0;">7-Day Streak</p>
            <p style="font-size: 12px; color: var(--t2); margin: 0;">Keep using items before they expire</p>
          </div>
        </Card>

        <!-- Action -->
        <Button variant="primary" block onclick="alert('Share digest')" style="margin-top: 24px;">
          📤 Share Digest
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>

<script>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  const emojiMap = {
    vegetable: '🥦',
    produce: '🥦',
    fruit: '🍎',
    dairy: '🥛',
    bread: '🍞',
    baked: '🍞',
    meat: '🥩',
    protein: '🥩',
    frozen: '🧊',
    pantry: '🥫',
    sauce: '🥫',
    prepared: '🥘',
    leftover: '🥘',
    beverage: '🥤',
    other: '📦',
  };

  async function loadDigest() {
    try {
      const userQuery = `query { getProfile { id } listHouseholds { id } }`;
      const userData = await gql(userQuery);
      const householdId = userData.listHouseholds?.[0]?.id;

      if (!householdId) return;

      // Fetch analytics
      const analyticsQuery = `query GetAnalytics($householdId: ID!) {
        getHouseholdAnalytics(householdId: $householdId) {
          totalItems
          wastedItems
          wastedValue
        }
      }`;
      const analyticsData = await gql(analyticsQuery, { householdId });
      const analytics = analyticsData.getHouseholdAnalytics || {};

      document.getElementById('items-used').textContent = analytics.totalItems || 0;
      document.getElementById('waste-prevented').textContent = '$' + (analytics.wastedValue || 0);

      // Fetch items to show expiring soon
      const itemsQuery = `query ListItems($householdId: ID!) {
        listItems(householdId: $householdId) {
          id foodName category storageLocation status expiryAt
        }
      }`;
      const itemsData = await gql(itemsQuery, { householdId });
      const items = (itemsData.listItems || []).filter(i => i.status === 'soon' || i.status === 'urgent');

      if (items.length > 0) {
        const expiringHtml = items.slice(0, 3).map((item) => {
          const emoji = emojiMap[item.category?.toLowerCase()] || emojiMap.other;
          const days = item.expiryAt ? Math.ceil((new Date(item.expiryAt).getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24)) : 0;
          return `
            <div style="display: flex; gap: 12px; align-items: center;">
              <span style="font-size: 24px;">${emoji}</span>
              <div style="flex: 1;">
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">${item.foodName}</p>
                <p style="font-size: 12px; color: var(--${item.status === 'soon' ? 'soon' : 'urgent'}); margin: 0;">Expires in ${days} day${days !== 1 ? 's' : ''}</p>
              </div>
            </div>
          `;
        }).join('');
        document.querySelector('[style*="Expiring Soon"]')?.nextElementSibling?.querySelector('[style*="flex-direction: column; gap: 10px"]').innerHTML = expiringHtml;
      }
    } catch (error) {
      console.error('Failed to load digest:', error);
    }
  }

  loadDigest();
</script>
