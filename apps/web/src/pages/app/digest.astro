---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Weekly Digest — WhatsFresh">
  <main>
    <div class="scroll" id="digestScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/dashboard" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Weekly Digest</div>
        <button class="btn-icon" onclick="navigator.share?.({title:'WhatsFresh Digest'})">↗</button>
      </div>

      <!-- Period subtitle -->
      <div style="padding:0 22px 14px;color:var(--t2);font-size:13px;font-weight:600;">May 1 – May 8, 2026</div>

      <!-- Planet-style summary card -->
      <div style="padding:0 22px 14px;">
        <div class="planet-card">
          <div style="font-size:11px;font-weight:800;letter-spacing:2px;opacity:0.85;text-transform:uppercase;margin-bottom:8px;">📅 This Week</div>
          <div style="font-family:Fraunces,serif;font-size:36px;font-weight:800;line-height:1;margin-bottom:6px;" id="weekSaved">$34</div>
          <div style="font-size:14px;opacity:0.92;">saved from food waste this week</div>
          <div style="display:flex;gap:12px;margin-top:14px;font-size:13px;">
            <div style="flex:1;">
              <div style="font-family:Fraunces,serif;font-size:22px;font-weight:800;" id="itemsUsed">12</div>
              <div style="opacity:0.85;font-size:12px;">items used</div>
            </div>
            <div style="flex:1;">
              <div style="font-family:Fraunces,serif;font-size:22px;font-weight:800;" id="lbsSaved">3.2</div>
              <div style="opacity:0.85;font-size:12px;">lbs saved</div>
            </div>
            <div style="flex:1;">
              <div style="font-family:Fraunces,serif;font-size:22px;font-weight:800;" id="streakDays">7</div>
              <div style="opacity:0.85;font-size:12px;">day streak</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Expiring soon -->
      <div class="section-header" style="padding:0 22px 12px;">
        <div class="section-title serif">⏰ Expiring Soon</div>
        <a href="/app/items?filter=urgent" class="section-link">All →</a>
      </div>
      <div style="padding:0 22px 14px;">
        <div class="info-card" id="expiringList">
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <span style="font-size:24px;">🥦</span>
              <div>
                <div style="font-weight:600;">Broccoli</div>
                <div style="font-size:12px;color:var(--soon);">Expires in 2 days</div>
              </div>
            </div>
            <div class="detail-badge" style="background:var(--soon-bg);color:var(--soon);font-size:9px;">2D</div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <span style="font-size:24px;">🥬</span>
              <div>
                <div style="font-weight:600;">Spinach</div>
                <div style="font-size:12px;color:var(--urgent);">Today!</div>
              </div>
            </div>
            <div class="detail-badge" style="background:var(--urgent-bg);color:var(--urgent);font-size:9px;">TODAY</div>
          </div>
        </div>
      </div>

      <!-- Achievement -->
      <div class="section-header" style="padding:0 22px 12px;">
        <div class="section-title serif">🏆 Achievements</div>
      </div>
      <div class="achv-list" style="padding-left:22px;">
        <div class="achv unlocked gold"><div class="achv-emoji">🔥</div><div class="achv-name">7-Day Streak</div><div class="achv-prog">Unlocked!</div></div>
        <div class="achv unlocked green"><div class="achv-emoji">💰</div><div class="achv-name">$34 Saved</div><div class="achv-prog">This week</div></div>
      </div>

      <!-- Share -->
      <div style="padding:20px 22px 40px;">
        <button class="btn btn-primary btn-block btn-lg" onclick="navigator.share?.({title:'My WhatsFresh Digest',text:'I saved $34 this week!'}) || alert('Share: I saved $34 this week!')">📤 Share Digest</button>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  async function loadDigest() {
    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            items(limit: 200) { id name emoji status daysUntilExpiry }
          }`
        })
      });
      const { data } = await res.json();
      const items = data?.items || [];

      const urgent = items.filter((i: any) => i.status === 'urgent' || i.status === 'soon');
      const usedEl = document.getElementById('itemsUsed');
      if (usedEl) usedEl.textContent = String(items.length);

      if (urgent.length > 0) {
        const list = document.getElementById('expiringList');
        if (list) {
          list.innerHTML = urgent.slice(0, 3).map((i: any) => `
            <a href="/app/items/${i.id}" class="info-row" style="text-decoration:none;">
              <div style="display:flex;align-items:center;gap:12px;flex:1;">
                <span style="font-size:24px;">${i.emoji || '🥫'}</span>
                <div>
                  <div style="font-weight:600;color:var(--t1);">${i.name}</div>
                  <div style="font-size:12px;color:var(--${i.status === 'urgent' ? 'urgent' : 'soon'});">
                    ${i.daysUntilExpiry === 0 ? 'Today!' : 'In ' + i.daysUntilExpiry + ' day' + (i.daysUntilExpiry !== 1 ? 's' : '')}
                  </div>
                </div>
              </div>
            </a>`).join('');
        }
      }
    } catch (_) {}
  }

  loadDigest();
</script>
