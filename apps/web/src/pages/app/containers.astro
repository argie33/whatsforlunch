---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';
import FAB from '@/components/FAB.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Containers — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Containers" subtitle="Storage locations" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <div id="containers-list" style="min-height: 200px; display: flex; align-items: center; justify-content: center;">
          <p style="color: var(--t2);">Loading containers...</p>
        </div>

        <!-- Add Container -->
        <p class="eyebrow" style="margin: 24px 0 12px 0;">New Container</p>
        <Button variant="secondary" block onclick="alert('Add container form coming soon')" style="margin-bottom: 24px;">
          ➕ Add Container
        </Button>

        <!-- Smart Home Info -->
        <p class="eyebrow" style="margin-bottom: 12px;">Smart Home</p>
        <Card>
          <div style="padding: 16px; text-align: center;">
            <p style="font-size: 13px; color: var(--t2); margin: 0 0 12px 0;">
              🏠 Connect smart devices to track temperature, humidity, and more
            </p>
            <Button variant="ghost" block onclick="location.href='/app/smart-home'">
              Setup Smart Home
            </Button>
          </div>
        </Card>
      </div>
    </div>

    <FAB icon="➕" label="Add container" href="/app/containers/new" />
    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  .container-card {
    background: var(--raised);
    border: 1px solid var(--b1);
    border-radius: var(--r-lg);
    padding: 14px;
    margin-bottom: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: transform 0.15s var(--quick), box-shadow 0.2s;
  }

  .container-card:active {
    transform: scale(0.98);
  }
</style>

<script>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  const emojiMap = {
    fridge: '🧊',
    freezer: '❄️',
    counter: '🏠',
    pantry: '🚪',
    wine: '🍷',
  };

  async function loadContainers() {
    const list = document.getElementById('containers-list');

    try {
      const userQuery = `query { me { id defaultHouseholdId } myHouseholds { id } }`;
      const userData = await gql(userQuery);

      let householdId = userData.me.defaultHouseholdId;
      if (!householdId && userData.myHouseholds.length > 0) {
        householdId = userData.myHouseholds[0].id;
      }

      if (!householdId) {
        list.innerHTML = '<p style="color: var(--t2);">No household found</p>';
        return;
      }

      const containersQuery = `query ListContainers($householdId: UUID!) {
        listContainers(householdId: $householdId) {
          id
          nickname
        }
      }`;

      const data = await gql(containersQuery, { householdId });
      const containers = data.listContainers || [];

      if (containers.length === 0) {
        list.innerHTML = '<p style="color: var(--t2);">No containers. Create one to get started!</p>';
        return;
      }

      const html = containers
        .map(
          (c) => `
        <div class="container-card" onclick="location.href='/app/containers/${c.id}'">
          <div style="display: flex; gap: 12px; align-items: center;">
            <div style="font-size: 32px;">${emojiMap[c.nickname?.toLowerCase()] || '📦'}</div>
            <div>
              <h4 style="font-size: 15px; font-weight: 700; margin: 0 0 4px 0;">${c.nickname || 'Container'}</h4>
              <p style="font-size: 12px; color: var(--t2); margin: 0;">ID: ${c.id.slice(0, 8)}</p>
            </div>
          </div>
        </div>
      `
        )
        .join('');

      list.innerHTML = html;
    } catch (error) {
      console.error('Failed to load containers:', error);
      list.innerHTML = '<p style="color: var(--t2);">Failed to load containers</p>';
    }
  }

  loadContainers();
</script>
