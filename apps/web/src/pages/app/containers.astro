---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Containers — WhatsFresh">
  <main>
    <div class="scroll" id="containersScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Containers</div>
        <a href="/app/scan" class="btn-icon" style="text-decoration:none;">+</a>
      </div>

      <!-- Summary card -->
      <div style="padding:0 22px 14px;">
        <div class="card" style="background:linear-gradient(135deg,var(--brand) 0%,var(--brand-light) 100%);color:white;border:none;padding:20px;">
          <div style="font-size:11px;font-weight:800;letter-spacing:2px;opacity:0.85;text-transform:uppercase;margin-bottom:8px;">📦 Active</div>
          <div style="font-family:Fraunces,serif;font-size:30px;font-weight:800;letter-spacing:-1px;line-height:1;margin-bottom:4px;" id="containerCount">— containers</div>
          <div style="font-size:14px;opacity:0.92;" id="itemCount">Loading...</div>
        </div>
      </div>

      <!-- Containers list -->
      <div style="padding:0 22px;">
        <div class="info-card" id="containersList">
          <div style="padding:12px;color:var(--t2);text-align:center;">Loading containers...</div>
        </div>
      </div>

      <!-- QR Stickers CTA -->
      <div style="padding:16px 22px 40px;">
        <div class="card card-pressable" style="border:2px dashed var(--b2);text-align:center;padding:24px;background:transparent;">
          <div style="font-size:42px;margin-bottom:8px;">🏷️</div>
          <div style="font-family:Fraunces,serif;font-weight:800;font-size:18px;margin-bottom:4px;">Order QR Stickers</div>
          <div style="font-size:13px;color:var(--t2);margin-bottom:14px;">100 reusable stickers · $9.99</div>
          <button class="btn btn-primary" style="padding:10px 18px;">Order now</button>
        </div>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  const emojiMap: Record<string, string> = {
    fridge: '🧊',
    refrigerator: '🧊',
    freezer: '❄️',
    pantry: '🥫',
    counter: '🍞',
    wine: '🍷',
    cellar: '🍷',
  };

  function getEmoji(name: string) {
    const lower = (name || '').toLowerCase();
    for (const [key, emoji] of Object.entries(emojiMap)) {
      if (lower.includes(key)) return emoji;
    }
    return '📦';
  }

  async function loadContainers() {
    const list = document.getElementById('containersList');
    const countEl = document.getElementById('containerCount');
    const itemsEl = document.getElementById('itemCount');
    if (!list) return;

    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            containers {
              id name itemCount
            }
          }`
        })
      });
      const { data } = await res.json();
      const containers = data?.containers || [];

      if (countEl) countEl.textContent = `${containers.length} container${containers.length !== 1 ? 's' : ''}`;

      const totalItems = containers.reduce((sum: number, c: any) => sum + (c.itemCount || 0), 0);
      if (itemsEl) itemsEl.textContent = `Total ${totalItems} items tracked`;

      if (containers.length === 0) {
        list.innerHTML = `
          <div style="padding:32px;text-align:center;color:var(--t2);">
            <div style="font-size:48px;margin-bottom:12px;">📦</div>
            <div style="font-family:Fraunces,serif;font-size:18px;font-weight:700;color:var(--t1);margin-bottom:6px;">No containers yet</div>
            <div style="font-size:13px;">Add your first storage location</div>
          </div>`;
        return;
      }

      list.innerHTML = containers.map((c: any) => `
        <a href="/app/containers/${c.id}" class="info-row" style="text-decoration:none;cursor:pointer;">
          <div style="display:flex;align-items:center;gap:14px;flex:1;">
            <span style="font-size:28px;">${getEmoji(c.name)}</span>
            <div>
              <div style="font-weight:600;font-size:15px;color:var(--t1);">${c.name}</div>
              <div style="font-size:12px;color:var(--t2);">${c.itemCount || 0} item${c.itemCount !== 1 ? 's' : ''}</div>
            </div>
          </div>
          <span style="color:var(--t3);font-size:18px;">›</span>
        </a>`).join('');
    } catch (_) {
      if (list) list.innerHTML = `
        <div style="padding:20px;text-align:center;color:var(--t2);">
          <div style="font-size:13px;">Couldn't load containers</div>
        </div>`;
    }
  }

  loadContainers();
</script>
