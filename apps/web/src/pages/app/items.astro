---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import ItemCard from '@/components/ItemCard.astro';
import FAB from '@/components/FAB.astro';

const mockItems = [
  { id: '1', name: 'Broccoli', emoji: '🥦', status: 'fresh' as const, days: 5, container: 'Fridge' },
  { id: '2', name: 'Spinach', emoji: '🥬', status: 'fresh' as const, days: 4, container: 'Fridge' },
  { id: '3', name: 'Milk', emoji: '🥛', status: 'soon' as const, days: 2, container: 'Fridge' },
  { id: '4', name: 'Yogurt', emoji: '🍨', status: 'soon' as const, days: 3, container: 'Fridge' },
  { id: '5', name: 'Bread', emoji: '🍞', status: 'urgent' as const, days: 0, container: 'Counter' },
  { id: '6', name: 'Bananas', emoji: '🍌', status: 'urgent' as const, days: 1, container: 'Counter' },
  { id: '7', name: 'Cheese', emoji: '🧀', status: 'expired' as const, days: -2, container: 'Fridge' },
];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items', active: true },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];

const freshItems = mockItems.filter((i) => i.status === 'fresh');
const soonItems = mockItems.filter((i) => i.status === 'soon');
const urgentItems = mockItems.filter((i) => i.status === 'urgent');
const expiredItems = mockItems.filter((i) => i.status === 'expired');
---

<BaseLayout title="Items — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <!-- Top Bar -->
    <TopBar
      title="Items"
      subtitle={`${mockItems.length} total`}
      actions={[
        { icon: '🔍', label: 'Search', onClick: "location.href='/app/search'" },
        { icon: '⚙️', label: 'Filter', onClick: "alert('Filter coming soon')" },
      ]}
    />

    <!-- Scrollable Content -->
    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      {urgentItems.length > 0 && (
        <div style="padding: 16px 22px 0;">
          <h3 class="section-title" style="color: var(--urgent); margin-bottom: 12px;">Use Today</h3>
          {urgentItems.map((item) => (
            <ItemCard
              key={item.id}
              name={item.name}
              emoji={item.emoji}
              status={item.status}
              days={item.days}
              container={item.container}
              onClick={`location.href='/app/items/${item.id}'`}
            />
          ))}
        </div>
      )}

      {soonItems.length > 0 && (
        <div style="padding: 16px 22px 0;">
          <h3 class="section-title" style="color: var(--soon); margin-bottom: 12px;">Using Soon</h3>
          {soonItems.map((item) => (
            <ItemCard
              key={item.id}
              name={item.name}
              emoji={item.emoji}
              status={item.status}
              days={item.days}
              container={item.container}
              onClick={`location.href='/app/items/${item.id}'`}
            />
          ))}
        </div>
      )}

      {freshItems.length > 0 && (
        <div style="padding: 16px 22px 0;">
          <h3 class="section-title" style="color: var(--fresh); margin-bottom: 12px;">Fresh</h3>
          {freshItems.map((item) => (
            <ItemCard
              key={item.id}
              name={item.name}
              emoji={item.emoji}
              status={item.status}
              days={item.days}
              container={item.container}
              onClick={`location.href='/app/items/${item.id}'`}
            />
          ))}
        </div>
      )}

      {expiredItems.length > 0 && (
        <div style="padding: 16px 22px 0;">
          <h3 class="section-title" style="color: var(--expired); margin-bottom: 12px;">Expired</h3>
          {expiredItems.map((item) => (
            <ItemCard
              key={item.id}
              name={item.name}
              emoji={item.emoji}
              status={item.status}
              days={item.days}
              container={item.container}
              onClick={`location.href='/app/items/${item.id}'`}
            />
          ))}
        </div>
      )}
    </div>

    <!-- FAB -->
    <FAB icon="➕" label="Add item" href="/app/add" />

    <!-- Tab Bar -->
    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
