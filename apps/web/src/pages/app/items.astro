---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items', active: true },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Inventory — WhatsFresh">
  <main>
    <div class="scroll" id="itemsScroll">

      <!-- Top Bar -->
      <div class="topbar" id="topbarItems">
        <div class="topbar-title">
          <div class="caption" style="color:var(--t2)"><span id="totalCount">—</span> items</div>
          <div class="h2 serif">Inventory</div>
        </div>
        <div class="topbar-actions">
          <a href="/app/search" class="btn-icon" style="text-decoration:none;">🔍</a>
          <button class="btn-icon" id="sortBtn" aria-label="Sort">⇅</button>
        </div>
      </div>

      <!-- Search bar -->
      <div class="searchbar" id="searchbar">
        <span style="color:var(--t3);font-size:18px;">🔍</span>
        <input class="searchbar-input" id="searchInput" placeholder="Search 'milk', 'leftover'..." autocomplete="off" />
      </div>

      <!-- Filter chips -->
      <div class="chips">
        <button class="chip active" data-filter="all" onclick="setFilter('all',this)">All</button>
        <button class="chip" data-filter="urgent" onclick="setFilter('urgent',this)">🔥 Urgent</button>
        <button class="chip" data-filter="fresh" onclick="setFilter('fresh',this)">✅ Fresh</button>
        <button class="chip" data-filter="fridge" onclick="setFilter('fridge',this)">🧊 Fridge</button>
        <button class="chip" data-filter="freezer" onclick="setFilter('freezer',this)">❄️ Freezer</button>
        <button class="chip" data-filter="pantry" onclick="setFilter('pantry',this)">🥫 Pantry</button>
        <button class="chip" data-filter="counter" onclick="setFilter('counter',this)">🍞 Counter</button>
      </div>

      <!-- Items list -->
      <div style="padding:0 22px 12px;">
        <div id="itemsList">
          <!-- Skeleton loader -->
          <div class="item-card" style="animation:none;opacity:1;">
            <div style="width:4px;flex-shrink:0;background:var(--sunken);"></div>
            <div class="item-content">
              <div class="skel" style="width:52px;height:52px;border-radius:var(--r-md);flex-shrink:0;"></div>
              <div class="item-info">
                <div class="skel" style="width:60%;height:17px;margin-bottom:6px;"></div>
                <div class="skel" style="width:45%;height:13px;"></div>
              </div>
            </div>
          </div>
          <div class="item-card" style="animation:none;opacity:1;">
            <div style="width:4px;flex-shrink:0;background:var(--sunken);"></div>
            <div class="item-content">
              <div class="skel" style="width:52px;height:52px;border-radius:var(--r-md);flex-shrink:0;"></div>
              <div class="item-info">
                <div class="skel" style="width:50%;height:17px;margin-bottom:6px;"></div>
                <div class="skel" style="width:38%;height:13px;"></div>
              </div>
            </div>
          </div>
          <div class="item-card" style="animation:none;opacity:1;">
            <div style="width:4px;flex-shrink:0;background:var(--sunken);"></div>
            <div class="item-content">
              <div class="skel" style="width:52px;height:52px;border-radius:var(--r-md);flex-shrink:0;"></div>
              <div class="item-info">
                <div class="skel" style="width:55%;height:17px;margin-bottom:6px;"></div>
                <div class="skel" style="width:40%;height:13px;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- FAB -->
    <a href="/app/add" class="fab" aria-label="Add item" style="text-decoration:none;">+</a>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }

  .topbar { padding-top: 20px; }

  .searchbar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--raised);
    border: 1.5px solid var(--b1);
    border-radius: var(--r-md);
    margin: 0 22px 14px;
    transition: all 0.2s;
  }

  .searchbar:focus-within {
    border-color: var(--brand);
    box-shadow: 0 0 0 4px rgba(14,92,58,0.10);
  }

  .searchbar-input {
    border: none;
    background: transparent;
    flex: 1;
    font-size: 15px;
    outline: none;
    font-family: inherit;
    color: var(--t1);
  }

  .searchbar-input::placeholder { color: var(--t3); }

  .fab {
    position: fixed;
    bottom: 96px;
    right: 22px;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    font-weight: 300;
    z-index: 25;
  }
</style>

<script>
  const scroll = document.getElementById('itemsScroll');
  const topbar = document.getElementById('topbarItems');
  scroll?.addEventListener('scroll', () => {
    if ((scroll.scrollTop || 0) > 10) topbar?.classList.add('scrolled');
    else topbar?.classList.remove('scrolled');
  });

  let allItems: any[] = [];
  let currentFilter = 'all';

  function setFilter(filter: string, btn: HTMLElement) {
    currentFilter = filter;
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    renderItems();
  }

  (window as any).setFilter = setFilter;

  function getFilteredItems() {
    const searchVal = (document.getElementById('searchInput') as HTMLInputElement)?.value?.toLowerCase() || '';
    return allItems.filter(item => {
      if (searchVal && !item.name.toLowerCase().includes(searchVal) && !item.container.toLowerCase().includes(searchVal)) return false;
      if (currentFilter === 'all') return true;
      if (currentFilter === 'urgent') return item.status === 'urgent';
      if (currentFilter === 'fresh') return item.status === 'fresh';
      if (currentFilter === 'fridge') return item.container.toLowerCase().includes('fridge') || item.container.toLowerCase().includes('refrigerator');
      if (currentFilter === 'freezer') return item.container.toLowerCase().includes('freeze');
      if (currentFilter === 'pantry') return item.container.toLowerCase().includes('pantry');
      if (currentFilter === 'counter') return item.container.toLowerCase().includes('counter');
      return true;
    });
  }

  function getDaysLabel(d: number) {
    if (d < 0) return 'Expired';
    if (d === 0) return 'Today';
    if (d === 1) return 'Tomorrow';
    return `${d}d left`;
  }

  function renderItems() {
    const items = getFilteredItems();
    const list = document.getElementById('itemsList');
    if (!list) return;

    if (items.length === 0) {
      list.innerHTML = `
        <div style="text-align:center;padding:48px 22px;color:var(--t2);">
          <div style="font-size:56px;margin-bottom:16px;">🍃</div>
          <div style="font-family:Fraunces,serif;font-size:20px;font-weight:700;color:var(--t1);margin-bottom:6px;">Nothing here</div>
          <div style="font-size:14px;">Try a different filter or add some items</div>
        </div>`;
      return;
    }

    // Sort: urgent first, then soon, then fresh, then expired
    const order = { urgent: 0, soon: 1, fresh: 2, expired: 3 };
    items.sort((a, b) => (order[a.status] ?? 9) - (order[b.status] ?? 9));

    list.innerHTML = items.map((item, idx) => `
      <a href="/app/items/${item.id}" class="item-card" style="text-decoration:none;animation-delay:${idx * 0.03}s;">
        <div class="item-stripe ${item.status}"></div>
        <div class="item-content">
          <div class="item-icon ${item.status}">${item.emoji || '🥫'}</div>
          <div class="item-info">
            <div class="item-name">${item.name}</div>
            <div class="item-meta">
              <span>${item.container}</span>
              <div class="dot"></div>
              <span>${getDaysLabel(item.daysUntilExpiry)}</span>
            </div>
          </div>
          <div class="item-badge ${item.status}">${getDaysLabel(item.daysUntilExpiry)}</div>
        </div>
      </a>`).join('');
  }

  async function loadItems() {
    try {
      // First get household ID
      const householdRes = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query { listHouseholds { id } }`
        })
      });
      const householdData = await householdRes.json();
      const householdId = householdData.data?.listHouseholds?.[0]?.id;

      if (!householdId) return;

      // Then get items
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query ListItems($householdId: ID!) {
            listItems(householdId: $householdId) {
              id foodName category storageLocation status expiryAt
            }
          }`,
          variables: { householdId }
        })
      });
      const { data } = await res.json();
      if (data?.listItems) {
        // Map to consistent format
        allItems = data.listItems.map((i: any) => {
          const expiryDate = i.expiryAt ? new Date(i.expiryAt) : null;
          const daysUntilExpiry = expiryDate
            ? Math.floor((expiryDate.getTime() - Date.now()) / (1000 * 60 * 60 * 24))
            : 0;
          return {
            id: i.id,
            name: i.foodName,
            emoji: '🥫',
            status: i.status || 'fresh',
            daysUntilExpiry,
            container: i.storageLocation || 'Fridge'
          };
        });
        const totalEl = document.getElementById('totalCount');
        if (totalEl) totalEl.textContent = String(allItems.length);
        renderItems();
      }
    } catch (e) {
      console.error('Failed to load items:', e);
    }
  }

  document.getElementById('searchInput')?.addEventListener('input', renderItems);

  // Handle URL filter param
  const urlFilter = new URLSearchParams(location.search).get('filter');
  if (urlFilter) {
    const btn = document.querySelector(`[data-filter="${urlFilter}"]`) as HTMLElement;
    if (btn) setFilter(urlFilter, btn);
  }

  loadItems();
</script>
