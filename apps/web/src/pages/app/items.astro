---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import SearchBar from '@/components/SearchBar.astro';
import FAB from '@/components/FAB.astro';

const mockItems = [
  { id: '1', name: 'Broccoli', emoji: '🥦', status: 'fresh' as const, days: 5, container: 'Fridge' },
  { id: '2', name: 'Spinach', emoji: '🥬', status: 'fresh' as const, days: 4, container: 'Fridge' },
  { id: '3', name: 'Milk', emoji: '🥛', status: 'soon' as const, days: 2, container: 'Fridge' },
  { id: '4', name: 'Yogurt', emoji: '🍨', status: 'soon' as const, days: 3, container: 'Fridge' },
  { id: '5', name: 'Bread', emoji: '🍞', status: 'urgent' as const, days: 0, container: 'Counter' },
  { id: '6', name: 'Bananas', emoji: '🍌', status: 'urgent' as const, days: 1, container: 'Counter' },
  { id: '7', name: 'Cheese', emoji: '🧀', status: 'expired' as const, days: -2, container: 'Fridge' },
];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items', active: true },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Items — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <!-- Top Bar -->
    <TopBar
      title="Items"
      subtitle={`${mockItems.length} total`}
      actions={[
        { icon: '⚙️', label: 'Filter', onClick: "alert('Filter coming soon')" },
      ]}
    />

    <!-- Search Bar -->
    <SearchBar placeholder="Filter items..." />

    <!-- Scrollable Content -->
    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div id="items-container"></div>
    </div>

    <!-- FAB -->
    <FAB icon="➕" label="Add item" href="/app/add" />
    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  .item-card {
    background: var(--raised);
    border-radius: var(--r-lg);
    margin-bottom: 10px;
    overflow: hidden;
    border: 1px solid var(--b1);
    display: flex;
    position: relative;
    cursor: pointer;
    transition: transform 0.15s var(--quick), box-shadow 0.2s;
  }

  .item-card:active {
    transform: scale(0.98);
  }

  .item-card:hover {
    box-shadow: var(--s-2);
  }

  .item-stripe {
    width: 4px;
    flex-shrink: 0;
  }

  .item-stripe.fresh {
    background: linear-gradient(180deg, #1F9956 0%, #34B86C 100%);
  }

  .item-stripe.soon {
    background: linear-gradient(180deg, #E08F1B 0%, #F4B942 100%);
  }

  .item-stripe.urgent {
    background: linear-gradient(180deg, #E0392B 0%, #FF6B47 100%);
  }

  .item-stripe.expired {
    background: #6B6B6B;
  }

  .item-content {
    flex: 1;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .item-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--r-md);
    background: var(--sunken);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    flex-shrink: 0;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  .item-info {
    flex: 1;
  }

  .item-name {
    font-size: 17px;
    font-weight: 700;
    color: var(--t1);
    margin-bottom: 3px;
  }

  .item-meta {
    font-size: 13px;
    color: var(--t2);
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .section-title {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin: 0;
  }

  .empty-state {
    padding: 40px 22px;
    text-align: center;
    color: var(--t2);
  }
</style>

<script define:vars={{ mockItems }}>
  const searchInput = document.querySelector('.searchbar-input');
  const container = document.getElementById('items-container');

  function groupByStatus(items) {
    const groups = {
      urgent: [],
      soon: [],
      fresh: [],
      expired: [],
    };
    items.forEach(item => {
      if (groups[item.status]) {
        groups[item.status].push(item);
      }
    });
    return groups;
  }

  function renderItems(items) {
    if (items.length === 0) {
      container.innerHTML = `<div class="empty-state" style="padding: 22px; margin: 16px;">No items found</div>`;
      return;
    }

    const groups = groupByStatus(items);
    const titles = { urgent: 'Use Today', soon: 'Using Soon', fresh: 'Fresh', expired: 'Expired' };
    const colors = { urgent: 'var(--urgent)', soon: 'var(--soon)', fresh: 'var(--fresh)', expired: 'var(--expired)' };

    let html = '';
    Object.entries(groups).forEach(([status, statusItems]) => {
      if (statusItems.length === 0) return;
      html += `
        <div style="padding: 16px 22px 0;">
          <h3 class="section-title" style="color: ${colors[status]}; margin-bottom: 12px;">${titles[status]}</h3>
          ${statusItems.map(item => `
            <div class="item-card" onclick="location.href='/app/items/${item.id}'">
              <div class="item-stripe ${item.status}"></div>
              <div class="item-content">
                <div class="item-icon">${item.emoji}</div>
                <div class="item-info">
                  <div class="item-name">${item.name}</div>
                  <div class="item-meta">${item.container} • ${item.days > 0 ? item.days + ' days' : (item.days === 0 ? 'Today' : 'Expired')}</div>
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      `;
    });

    container.innerHTML = html;
  }

  function filterItems(query) {
    const q = query.toLowerCase();
    const filtered = mockItems.filter(item =>
      item.name.toLowerCase().includes(q) ||
      item.container.toLowerCase().includes(q)
    );
    renderItems(filtered);
  }

  // Load real data from API
  async function loadRealItems() {
    try {
      const { gql } = await import('@/lib/graphql.ts');
      const { initAuth, isAuthenticated } = await import('@/lib/auth.ts');

      initAuth();
      if (!isAuthenticated()) {
        window.location.href = '/auth/login';
        return;
      }

      // Get household
      const profileData = await gql(`query { getProfile { id } listHouseholds { id } }`);
      let householdId = profileData.listHouseholds?.[0]?.id;

      if (!householdId) {
        renderItems([]);
        return;
      }

      // Fetch items
      const itemsData = await gql(`query ListItems($householdId: UUID!) {
        listItems(householdId: $householdId) {
          id foodName category storageLocation status expiryAt storedAt
        }
      }`, { householdId });

      const items = itemsData.listItems || [];
      const emojiMap = {
        vegetable: '🥦', fruit: '🍎', dairy: '🥛', bread: '🍞',
        meat: '🥩', frozen: '🧊', pantry: '🥫', other: '📦'
      };

      const mappedItems = items.map(item => ({
        id: item.id,
        name: item.foodName,
        emoji: emojiMap[item.category?.toLowerCase()] || '📦',
        status: item.status || 'fresh',
        days: Math.ceil((new Date(item.expiryAt).getTime() - Date.now()) / (1000 * 60 * 60 * 24)),
        container: item.storageLocation || 'Unknown'
      }));

      renderItems(mappedItems);
    } catch (error) {
      console.error('Failed to load items:', error);
      renderItems(mockItems);
    }
  }

  // Load items on page load
  loadRealItems();

  // Search listener
  searchInput?.addEventListener('input', (e) => {
    filterItems(e.target.value);
  });
</script>
