---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Delete Account — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Delete Account</div>
        <div style="width:44px"></div>
      </div>

      <div style="padding:0 22px;margin-top:8px;">
        <!-- Warning -->
        <div class="metric-card" style="background:var(--urgent-bg);border:1px solid var(--urgent);padding:16px;margin-bottom:16px;">
          <div style="font-size:13px;color:var(--urgent);margin:0;font-weight:600;">
            ⚠️ Warning: Deleting your account is permanent and cannot be undone.
          </div>
        </div>

        <!-- What Will Happen -->
        <div class="eyebrow" style="margin-bottom:12px;">WHAT WILL HAPPEN</div>
        <div class="metric-card" style="padding:16px;display:flex;flex-direction:column;gap:10px;font-size:14px;color:var(--t1);margin-bottom:16px;">
          <div>🗑️ All your data will be permanently deleted</div>
          <div>👥 You will be removed from all households</div>
          <div>📊 All household members will lose access to your activity history</div>
          <div>🔐 Your account cannot be recovered</div>
        </div>

        <!-- Reason -->
        <div class="eyebrow" style="margin-bottom:12px;">WHY ARE YOU LEAVING?</div>
        <div class="metric-card" style="padding:16px;margin-bottom:16px;">
          <select style="width:100%;padding:10px;border:1px solid var(--b1);border-radius:var(--r-md);font-size:14px;font-family:inherit;">
            <option>Select a reason...</option>
            <option>Not useful for me</option>
            <option>Technical issues</option>
            <option>Privacy concerns</option>
            <option>Found another app</option>
            <option>Other</option>
          </select>
        </div>

        <!-- Confirmation -->
        <div class="eyebrow" style="margin-bottom:12px;">CONFIRM DELETION</div>
        <div class="metric-card" style="padding:16px;margin-bottom:16px;">
          <label style="display:flex;align-items:flex-start;gap:8px;cursor:pointer;">
            <input type="checkbox" id="confirm" style="width:18px;height:18px;cursor:pointer;accent-color:var(--urgent);margin-top:2px;" />
            <span style="font-size:13px;color:var(--t1);">
              I understand that my account and all data will be permanently deleted
            </span>
          </label>
        </div>

        <!-- Delete Button -->
        <button class="btn btn-block btn-lg" style="background:var(--urgent);color:white;margin-bottom:8px;" onclick="deleteAccount()">Delete My Account</button>
        <button class="btn btn-secondary btn-block" onclick="location.href='/app/settings'">Cancel</button>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function deleteAccount() {
    const confirmed = (document.getElementById('confirm') as HTMLInputElement).checked;
    if (confirmed) {
      alert('This would delete the account');
    } else {
      alert('Please confirm the deletion');
    }
  }

  (window as any).deleteAccount = deleteAccount;
</script>
