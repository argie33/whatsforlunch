---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Delete Account — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Delete Account" subtitle="This action cannot be undone" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Warning -->
        <Card style="margin-bottom: 16px; background: var(--urgent-bg); border: 1px solid var(--urgent);">
          <div style="padding: 16px;">
            <p style="font-size: 13px; color: var(--urgent); margin: 0; font-weight: 600;">
              ⚠️ Warning: Deleting your account is permanent and cannot be undone.
            </p>
          </div>
        </Card>

        <!-- What Will Happen -->
        <p class="eyebrow" style="margin-bottom: 12px;">What will happen</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 10px; font-size: 14px; color: var(--t1);">
            <div>🗑️ All your data will be permanently deleted</div>
            <div>👥 You will be removed from all households</div>
            <div>📊 All household members will lose access to your activity history</div>
            <div>🔐 Your account cannot be recovered</div>
          </div>
        </Card>

        <!-- Reason -->
        <p class="eyebrow" style="margin-bottom: 12px;">Why are you leaving?</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <select style="width: 100%; padding: 10px; border: 1px solid var(--b1); border-radius: var(--r-md); font-size: 14px; font-family: inherit;">
              <option>Select a reason...</option>
              <option>Not useful for me</option>
              <option>Technical issues</option>
              <option>Privacy concerns</option>
              <option>Found another app</option>
              <option>Other</option>
            </select>
          </div>
        </Card>

        <!-- Confirmation -->
        <p class="eyebrow" style="margin-bottom: 12px;">Confirm deletion</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
              <input
                type="checkbox"
                id="confirm"
                style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--urgent);"
              />
              <span style="font-size: 13px; color: var(--t1);">
                I understand that my account and all data will be permanently deleted
              </span>
            </label>
          </div>
        </Card>

        <!-- Delete Button -->
        <Button variant="coral" block onclick="alert('This would delete the account')" style="margin-bottom: 8px;">
          Delete My Account
        </Button>
        <Button variant="secondary" block onclick="location.href='/app/profile'">
          Cancel
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
