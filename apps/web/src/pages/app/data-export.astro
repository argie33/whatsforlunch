---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Export Data — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Export Data</div>
        <div style="width:44px"></div>
      </div>

      <!-- Info -->
      <div style="padding:0 22px;margin-top:8px;">
        <div class="metric-card" style="background:var(--brand-soft);border-radius:var(--r-md);padding:16px;">
          <div style="font-size:13px;color:var(--brand);margin:0;">
            📥 Download all your data in JSON or CSV format. This includes items, containers, recipes, and activity history.
          </div>
        </div>

        <!-- Export Format -->
        <div class="eyebrow" style="margin:16px 0 12px;">FORMAT</div>
        <div class="settings-section">
          <label class="settings-row" style="border-bottom:1px solid var(--b1);cursor:pointer;">
            <div style="display:flex;align-items:center;gap:8px;flex:1;">
              <input type="radio" name="format" defaultChecked style="cursor:pointer;accent-color:var(--brand);" />
              <div>
                <div style="font-size:14px;font-weight:600;margin:0;color:var(--t1);">JSON</div>
                <div style="font-size:12px;color:var(--t2);margin:0;">Structured format (recommended)</div>
              </div>
            </div>
          </label>
          <label class="settings-row" style="border-bottom:none;cursor:pointer;">
            <div style="display:flex;align-items:center;gap:8px;flex:1;">
              <input type="radio" name="format" style="cursor:pointer;accent-color:var(--brand);" />
              <div>
                <div style="font-size:14px;font-weight:600;margin:0;color:var(--t1);">CSV</div>
                <div style="font-size:12px;color:var(--t2);margin:0;">Spreadsheet format</div>
              </div>
            </div>
          </label>
        </div>

        <!-- What's Included -->
        <div class="eyebrow" style="margin:16px 0 12px;">INCLUDED</div>
        <div class="metric-card" style="padding:16px;display:flex;flex-direction:column;gap:8px;font-size:14px;color:var(--t1);">
          <div>✓ All items and containers</div>
          <div>✓ Activity history</div>
          <div>✓ Household members</div>
          <div>✓ Settings & preferences</div>
        </div>

        <!-- Export -->
        <button class="btn btn-primary btn-block btn-lg" style="margin:24px 0 8px;" id="exportBtn">📥 Export My Data</button>

        <!-- Delete Account -->
        <div class="eyebrow" style="margin:24px 0 12px;">🗑️ DELETE ACCOUNT</div>
        <button class="btn btn-ghost btn-block" style="color:var(--coral);" onclick="location.href='/app/delete-account'">Delete Account Permanently</button>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  document.getElementById('exportBtn')?.addEventListener('click', async () => {
    const format = (document.querySelector('input[name="format"]:checked') as HTMLInputElement)?.value || 'json';
    const btn = document.getElementById('exportBtn') as HTMLButtonElement;
    const original = btn.textContent;
    btn.disabled = true;
    btn.textContent = '⏳ Exporting...';

    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query { exportData(format: ${format === 'csv' ? 'CSV' : 'JSON'}) }`
        })
      });
      const { data, errors } = await res.json();
      if (errors?.length) throw new Error(errors[0].message);

      const exportData = data?.exportData;
      if (!exportData) throw new Error('No data returned');

      // Create and trigger download
      const element = document.createElement('a');
      element.setAttribute('href', 'data:text/plain;charset=utf-8,' + encodeURIComponent(exportData));
      element.setAttribute('download', `whatsfresh-export-${new Date().toISOString().split('T')[0]}.${format}`);
      element.style.display = 'none';
      document.body.appendChild(element);
      element.click();
      document.body.removeChild(element);

      btn.textContent = '✓ Downloaded!';
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = original;
      }, 2000);
    } catch (error: any) {
      alert('Failed to export: ' + (error.message || 'Unknown error'));
      btn.disabled = false;
      btn.textContent = original;
    }
  });
</script>
