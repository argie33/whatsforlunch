---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];

const steps = [
  { text: 'Heat oil in a wok or large pan', done: true },
  { text: 'Add chopped garlic and stir for 30 seconds', done: true },
  { text: 'Add broccoli florets and stir fry for 3-4 minutes', done: false },
  { text: 'Add soy sauce and serve hot', done: false },
];

const usedItems = [
  { name: 'Broccoli', emoji: '🥦' },
];
---

<BaseLayout title="Cooking — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;background:linear-gradient(135deg,var(--coral) 0%,var(--honey) 100%);color:white;border:none;">
        <a href="/app/recipes" class="btn-icon glass" style="text-decoration:none;">←</a>
        <div class="back-title" style="color:white;">Stir-fry Vegetables</div>
        <div style="width:44px"></div>
      </div>

      <!-- Current Step Card -->
      <div style="padding:0 22px 16px;">
        <div class="card" style="background:linear-gradient(135deg,var(--coral) 0%,var(--honey) 100%);color:white;border:none;padding:20px;margin-top:8px;">
          <div style="font-size:11px;font-weight:800;letter-spacing:1.5px;opacity:0.85;text-transform:uppercase;margin-bottom:8px;">Step 3 of 4</div>
          <div style="font-family:Fraunces,serif;font-size:24px;font-weight:800;letter-spacing:-0.4px;margin-bottom:12px;line-height:1.2;">Add broccoli florets and stir fry</div>
          <button class="btn btn-primary" style="background:white;color:var(--coral);width:100%;" onclick="markStepDone()">✓ Step Complete</button>
        </div>
      </div>

      <!-- Timer -->
      <div style="padding:0 22px 16px;">
        <div class="eyebrow" style="margin-bottom:12px;">⏱️ Timer</div>
        <div class="card" style="text-align:center;padding:24px;">
          <div style="font-family:Fraunces,serif;font-size:56px;font-weight:800;color:var(--coral);letter-spacing:-1px;line-height:1;margin-bottom:16px;">3:45</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
            <button class="btn btn-secondary" style="padding:10px;font-size:16px;" onclick="pauseTimer()">⏸️</button>
            <button class="btn btn-secondary" style="padding:10px;font-size:16px;" onclick="addTime()">➕</button>
            <button class="btn btn-secondary" style="padding:10px;font-size:16px;" onclick="skipStep()">⏭️</button>
          </div>
        </div>
      </div>

      <!-- Steps -->
      <div style="padding:0 22px 16px;">
        <div class="eyebrow" style="margin-bottom:12px;">📋 Steps</div>
        <div class="info-card">
          {steps.map((step, index) => (
            <div key={index} class="step-row" style={index === steps.length - 1 ? 'border-bottom:none;' : ''}>
              <div class="step-num" style={step.done ? 'background:var(--fresh);' : ''}>{step.done ? '✓' : index + 1}</div>
              <div class="step-text" style={step.done ? 'color:var(--t3);text-decoration:line-through;' : ''}>{step.text}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Items Used -->
      <div style="padding:0 22px 40px;">
        <div class="eyebrow" style="margin-bottom:12px;">🥦 Items Used</div>
        <div class="info-card">
          {usedItems.map((item) => (
            <div key={item.name} class="info-row" style="border-bottom:none;">
              <span style="font-size:24px;margin-right:12px;">{item.emoji}</span>
              <span class="info-value">{item.name}</span>
            </div>
          ))}
        </div>
        <button class="btn btn-ghost btn-block" style="margin-top:14px;">+ Add item used</button>
        <button class="btn btn-primary btn-block btn-lg" style="margin-top:8px;" onclick="finishCooking()">✓ Finish cooking</button>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="recipes" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function markStepDone() {
    alert('Step marked complete!');
  }

  function pauseTimer() {
    alert('Timer paused');
  }

  function addTime() {
    alert('Time added');
  }

  function skipStep() {
    alert('Step skipped');
  }

  function finishCooking() {
    location.href = '/app/recipes';
  }

  (window as any).markStepDone = markStepDone;
  (window as any).pauseTimer = pauseTimer;
  (window as any).addTime = addTime;
  (window as any).skipStep = skipStep;
  (window as any).finishCooking = finishCooking;
</script>
