---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];

const steps = [
  { text: 'Heat oil in a wok or large pan', done: true },
  { text: 'Add chopped garlic and stir for 30 seconds', done: true },
  { text: 'Add broccoli florets and stir fry for 3-4 minutes', done: false },
  { text: 'Add soy sauce and serve hot', done: false },
];

const usedItems = [
  { name: 'Broccoli', emoji: '🥦' },
];
---

<BaseLayout title="Cooking — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Stir-fry Vegetables" subtitle="Step 3 of 4" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Current Step -->
      <div style="padding: 24px 22px; background: linear-gradient(135deg, var(--coral-soft) 0%, var(--honey-soft) 100%);">
        <div style="background: var(--raised); border-radius: var(--r-lg); padding: 20px; box-shadow: var(--s-2);">
          <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 8px 0; letter-spacing: 1.5px;">Current Step</p>
          <h2 style="font-size: 20px; font-weight: 700; margin: 0 0 16px 0; line-height: 1.4;">
            Add broccoli florets and stir fry for 3-4 minutes
          </h2>
          <Button variant="primary" block onclick="alert('Step complete!')">
            ✓ Step Complete
          </Button>
        </div>
      </div>

      <!-- Content -->
      <div style="padding: 16px 22px;">
        <!-- Timer -->
        <p class="eyebrow" style="margin-bottom: 12px;">⏱️ Timer</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 20px; text-align: center;">
            <div style="font-size: 48px; font-weight: 800; font-family: 'Fraunces', serif; color: var(--coral); margin-bottom: 12px;">
              3:45
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;">
              <Button variant="secondary" onclick="alert('Pause')" style="padding: 8px;">⏸️</Button>
              <Button variant="secondary" onclick="alert('Add time')" style="padding: 8px;">➕</Button>
              <Button variant="secondary" onclick="alert('Skip')" style="padding: 8px;">⏭️</Button>
            </div>
          </div>
        </Card>

        <!-- Steps Progress -->
        <p class="eyebrow" style="margin-bottom: 12px;">Steps</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 12px;">
            {steps.map((step, index) => (
              <div key={index} style="display: flex; gap: 12px; align-items: flex-start;">
                <div
                  style={`min-width: 28px; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-weight: 700; font-size: 14px; ${
                    step.done
                      ? 'background: var(--fresh); color: white;'
                      : 'background: var(--b1); color: var(--t2);'
                  }`}
                >
                  {step.done ? '✓' : index + 1}
                </div>
                <p
                  style={`font-size: 14px; margin: 0; line-height: 1.4; ${
                    step.done ? 'color: var(--t2); text-decoration: line-through;' : 'color: var(--t1);'
                  }`}
                >
                  {step.text}
                </p>
              </div>
            ))}
          </div>
        </Card>

        <!-- Used Items -->
        <p class="eyebrow" style="margin-bottom: 12px;">Items Used</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 10px;">
            {usedItems.map((item) => (
              <div key={item.name} style="display: flex; align-items: center; gap: 12px;">
                <span style="font-size: 24px;">{item.emoji}</span>
                <span style="font-size: 14px; color: var(--t1);">{item.name}</span>
              </div>
            ))}
          </div>
        </Card>

        <!-- Action -->
        <Button variant="ghost" block onclick="alert('Add item used')" style="margin-bottom: 24px;">
          + Add Item Used
        </Button>

        <Button variant="primary" block onclick="location.href='/app/recipes'">
          ✓ Finish Cooking
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="recipes" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
