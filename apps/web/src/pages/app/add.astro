---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Add Item — WhatsFresh">
  <main>
    <div class="scroll no-tab" id="addScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/items" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Add item</div>
        <button class="btn-ghost" id="saveBtn" style="font-weight:800;">Save</button>
      </div>

      <div style="padding:0 22px 40px;">

        <!-- Capture options -->
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:20px;">
          <a href="/app/scan" class="card card-pressable" style="padding:16px 8px;text-align:center;text-decoration:none;color:inherit;">
            <div style="font-size:28px;margin-bottom:6px;">📷</div>
            <div style="font-size:12px;font-weight:700;">AI Scan</div>
          </a>
          <a href="/app/scan" class="card card-pressable" style="padding:16px 8px;text-align:center;text-decoration:none;color:inherit;">
            <div style="font-size:28px;margin-bottom:6px;">🧾</div>
            <div style="font-size:12px;font-weight:700;">Barcode</div>
          </a>
          <a href="/app/scan" class="card card-pressable" style="padding:16px 8px;text-align:center;text-decoration:none;color:inherit;">
            <div style="font-size:28px;margin-bottom:6px;">🗓️</div>
            <div style="font-size:12px;font-weight:700;">Date OCR</div>
          </a>
        </div>

        <!-- Food name -->
        <div class="input-group">
          <label class="input-label">Food name</label>
          <input class="input" id="newName" placeholder="e.g., Greek yogurt" autocomplete="off" />
        </div>

        <!-- Storage location pickers -->
        <div class="input-group">
          <label class="input-label">Storage location</label>
          <div class="pickers">
            <button class="picker active" onclick="pickStor(this,'fridge')">🧊 Fridge</button>
            <button class="picker" onclick="pickStor(this,'freezer')">❄️ Freezer</button>
            <button class="picker" onclick="pickStor(this,'pantry')">🥫 Pantry</button>
            <button class="picker" onclick="pickStor(this,'counter')">🍞 Counter</button>
          </div>
        </div>

        <!-- Category pickers -->
        <div class="input-group">
          <label class="input-label">Category</label>
          <div class="pickers">
            <button class="picker active" onclick="pickCat(this,'dairy')">🥛 Dairy</button>
            <button class="picker" onclick="pickCat(this,'protein')">🥩 Protein</button>
            <button class="picker" onclick="pickCat(this,'produce')">🥦 Produce</button>
            <button class="picker" onclick="pickCat(this,'grain')">🌾 Grain</button>
            <button class="picker" onclick="pickCat(this,'leftover')">🍱 Leftover</button>
            <button class="picker" onclick="pickCat(this,'sauce')">🍅 Sauce</button>
          </div>
        </div>

        <!-- Expires in pickers -->
        <div class="input-group">
          <label class="input-label">Expires in</label>
          <div class="pickers" id="expPickers">
            <button class="picker" onclick="pickExp(this,1)">1 day</button>
            <button class="picker" onclick="pickExp(this,3)">3 days</button>
            <button class="picker active" onclick="pickExp(this,7)">1 week</button>
            <button class="picker" onclick="pickExp(this,14)">2 weeks</button>
            <button class="picker" onclick="pickExp(this,30)">1 month</button>
            <button class="picker" onclick="pickExp(this,90)">3 months</button>
          </div>
        </div>

        <!-- Quantity -->
        <div class="input-group">
          <label class="input-label">Quantity</label>
          <input class="input" id="newQty" placeholder="1 container" value="1" />
        </div>

        <!-- Notes -->
        <div class="input-group">
          <label class="input-label">Notes</label>
          <input class="input" id="newNotes" placeholder="Anything to remember?" />
        </div>

        <button class="btn btn-primary btn-block btn-lg" id="addBtn" style="margin-bottom:8px;">Add to fridge</button>
        <button class="btn btn-ghost btn-block" id="addAnotherBtn">Save & add another</button>

      </div>
    </div>

    <!-- Toast -->
    <div id="toast" style="position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:var(--brand);color:white;padding:12px 20px;border-radius:var(--r-md);font-size:14px;z-index:50;opacity:0;pointer-events:none;transition:opacity 0.3s;box-shadow:var(--s-glow);white-space:nowrap;"></div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }

  .input-group {
    margin-bottom: 20px;
  }

  .input-label {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: var(--t2);
    letter-spacing: 0.4px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .input {
    width: 100%;
    padding: 13px 14px;
    border: 1.5px solid var(--b1);
    border-radius: var(--r-md);
    font-size: 15px;
    font-family: inherit;
    color: var(--t1);
    background: var(--raised);
    box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .input:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 4px rgba(14,92,58,0.10);
  }
</style>

<script>
  let selectedStorage = 'fridge';
  let selectedCategory = 'dairy';
  let selectedExpDays = 7;

  function pickStor(btn: HTMLElement, val: string) {
    selectedStorage = val;
    btn.closest('.pickers')!.querySelectorAll('.picker').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
  }

  function pickCat(btn: HTMLElement, val: string) {
    selectedCategory = val;
    btn.closest('.pickers')!.querySelectorAll('.picker').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
  }

  function pickExp(btn: HTMLElement, days: number) {
    selectedExpDays = days;
    btn.closest('.pickers')!.querySelectorAll('.picker').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
  }

  (window as any).pickStor = pickStor;
  (window as any).pickCat = pickCat;
  (window as any).pickExp = pickExp;

  function showToast(msg: string, type = 'success') {
    const t = document.getElementById('toast')!;
    t.textContent = msg;
    t.style.background = type === 'error' ? 'var(--urgent)' : 'var(--brand)';
    t.style.opacity = '1';
    setTimeout(() => { t.style.opacity = '0'; }, 2800);
  }

  function getExpiryDate(days: number) {
    const d = new Date();
    d.setDate(d.getDate() + days);
    return d.toISOString().split('T')[0];
  }

  async function submitItem(addAnother = false) {
    const name = (document.getElementById('newName') as HTMLInputElement).value.trim();
    if (!name) {
      showToast('❌ Enter a food name', 'error');
      (document.getElementById('newName') as HTMLInputElement).focus();
      return;
    }

    const btn = document.getElementById('addBtn')!;
    btn.textContent = '⏳ Adding...';
    (btn as HTMLButtonElement).disabled = true;

    try {
      const qty = (document.getElementById('newQty') as HTMLInputElement).value || '1';
      const notes = (document.getElementById('newNotes') as HTMLInputElement).value || '';
      const expiryAt = getExpiryDate(selectedExpDays);
      const foodType = name.toLowerCase().replace(/\s+/g, '_');

      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `mutation CreateItem($input: CreateItemInput!) {
            createItem(input: $input) { id name }
          }`,
          variables: {
            input: {
              name,
              foodType,
              category: selectedCategory,
              storageLocation: selectedStorage,
              expiryAt,
              expirySource: 'user',
              quantityText: qty,
              notes,
            }
          }
        })
      });
      const { data, errors } = await res.json();
      if (errors?.length) throw new Error(errors[0].message);

      showToast('✅ Added ' + (data?.createItem?.name || name));

      if (addAnother) {
        (document.getElementById('newName') as HTMLInputElement).value = '';
        (document.getElementById('newNotes') as HTMLInputElement).value = '';
        btn.textContent = 'Add to fridge';
        (btn as HTMLButtonElement).disabled = false;
      } else {
        setTimeout(() => { location.href = '/app/items'; }, 800);
      }
    } catch (err: any) {
      showToast('❌ ' + (err.message || 'Failed to add item'), 'error');
      btn.textContent = 'Add to fridge';
      (btn as HTMLButtonElement).disabled = false;
    }
  }

  document.getElementById('addBtn')?.addEventListener('click', () => submitItem(false));
  document.getElementById('addAnotherBtn')?.addEventListener('click', () => submitItem(true));
  document.getElementById('saveBtn')?.addEventListener('click', () => submitItem(false));
</script>
