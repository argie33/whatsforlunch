---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';
import FormInput from '@/components/FormInput.astro';
import DatePicker from '@/components/DatePicker.astro';
import Select from '@/components/Select.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Add Item — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <!-- Top Bar -->
    <TopBar title="Add Item" subtitle="What's in your kitchen?" />

    <!-- Scrollable Content -->
    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <form style="padding: 16px 22px;">
        <!-- Quick Action Buttons -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 24px;">
          <Button variant="secondary" block onclick="location.href='/app/scan'">
            📷 Scan Barcode
          </Button>
          <Button variant="secondary" block onclick="alert('Camera recognition coming soon')">
            🤳 Take Photo
          </Button>
        </div>

        <!-- Form Fields -->
        <Card>
          <div style="display: flex; flex-direction: column; gap: 16px;">
            <FormInput
              id="itemName"
              name="itemName"
              label="Item Name"
              placeholder="e.g., Broccoli"
              required
            />

            <Select
              id="category"
              name="category"
              label="Category"
              options={[
                { value: 'vegetables', label: '🥦 Vegetables' },
                { value: 'fruits', label: '🍎 Fruits' },
                { value: 'dairy', label: '🥛 Dairy' },
                { value: 'bakery', label: '🍞 Bakery' },
                { value: 'meat', label: '🍖 Meat' },
                { value: 'seafood', label: '🐟 Seafood' },
                { value: 'pantry', label: '🥫 Pantry' },
              ]}
              required
            />

            <DatePicker
              id="purchaseDate"
              name="purchaseDate"
              label="Purchase Date"
              required
            />

            <DatePicker
              id="expiryDate"
              name="expiryDate"
              label="Expiry Date"
              required
            />

            <FormInput
              id="quantity"
              name="quantity"
              label="Quantity"
              type="number"
              placeholder="1"
              required
            />

            <Select
              id="container"
              name="container"
              label="Where is it stored?"
              options={[
                { value: 'fridge', label: '🧊 Fridge' },
                { value: 'freezer', label: '❄️ Freezer' },
                { value: 'counter', label: '🏠 Counter' },
                { value: 'pantry', label: '🚪 Pantry' },
                { value: 'wine-fridge', label: '🍷 Wine Fridge' },
              ]}
              required
            />

            <div>
              <label style="display: block; font-weight: 600; margin-bottom: 8px; font-size: 13px; color: var(--t1);">
                Notes
              </label>
              <textarea
                id="notes"
                name="notes"
                placeholder="Add any notes about this item..."
                style="width: 100%; padding: 12px; border: 1.5px solid var(--b1); border-radius: var(--r-md); font-size: 14px; font-family: inherit; min-height: 80px; resize: vertical; box-sizing: border-box; transition: border-color 0.2s;"
              ></textarea>
            </div>
          </div>
        </Card>

        <!-- Action Buttons -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 24px; margin-bottom: 16px;">
          <Button variant="secondary" block onclick="history.back()">
            Cancel
          </Button>
          <button type="submit" class="btn btn-primary btn-block" style="width: 100%;">
            Add Item
          </button>
        </div>
      </form>

      <!-- Toast -->
      <div id="toast" style="position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%); background: var(--brand); color: white; padding: 12px 20px; border-radius: var(--r-md); font-size: 14px; z-index: 50; opacity: 0; pointer-events: none; transition: opacity 0.3s; box-shadow: var(--s-glow);"></div>
    </div>

    <!-- Tab Bar -->
    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-soft);
  }
</style>

<script>
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.style.background = type === 'error' ? 'var(--urgent)' : 'var(--brand)';
    toast.style.opacity = '1';
    setTimeout(() => {
      toast.style.opacity = '0';
    }, 3000);
  }

  const form = document.querySelector('form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const itemName = form.querySelector('#itemName')?.value?.trim();
      const category = form.querySelector('#category').value;
      const purchaseDate = form.querySelector('#purchaseDate').value;
      const expiryDate = form.querySelector('#expiryDate').value;
      const quantity = form.querySelector('#quantity').value;
      const container = form.querySelector('#container').value;

      // Validate each field
      if (!itemName) {
        showToast('❌ Please enter an item name', 'error');
        form.querySelector('#itemName').focus();
        return;
      }

      if (itemName.length < 2) {
        showToast('❌ Item name must be at least 2 characters', 'error');
        form.querySelector('#itemName').focus();
        return;
      }

      if (!category) {
        showToast('❌ Please select a category', 'error');
        form.querySelector('#category').focus();
        return;
      }

      if (!purchaseDate) {
        showToast('❌ Please select a purchase date', 'error');
        form.querySelector('#purchaseDate').focus();
        return;
      }

      if (!expiryDate) {
        showToast('❌ Please select an expiry date', 'error');
        form.querySelector('#expiryDate').focus();
        return;
      }

      if (new Date(expiryDate) <= new Date(purchaseDate)) {
        showToast('❌ Expiry date must be after purchase date', 'error');
        form.querySelector('#expiryDate').focus();
        return;
      }

      if (!quantity || parseInt(quantity) < 1) {
        showToast('❌ Please enter a valid quantity', 'error');
        form.querySelector('#quantity').focus();
        return;
      }

      if (!container) {
        showToast('❌ Please select a storage location', 'error');
        form.querySelector('#container').focus();
        return;
      }

      // Disable button and show loading state
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = '⏳ Adding...';

      // Show success and navigate
      setTimeout(() => {
        showToast('✅ Item added successfully!');
        setTimeout(() => {
          location.href = '/app/items';
        }, 800);
      }, 300);
    });

    // Clear validation on input
    form.querySelectorAll('input, select, textarea').forEach(field => {
      field.addEventListener('input', () => {
        field.style.borderColor = '';
      });
    });
  }
</script>
