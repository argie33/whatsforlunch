---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Notifications — WhatsFresh">
  <main>
    <div class="scroll" id="notifScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/dashboard" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Notifications</div>
        <button class="btn-icon" id="markAllBtn" aria-label="Mark all read">✓</button>
      </div>

      <div style="padding:0 22px;">
        <div class="eyebrow" style="margin-bottom:10px;padding-left:4px;">TODAY</div>

        <a href="/app/items" class="notif urgent" style="text-decoration:none;">
          <div class="notif-icon" style="background:var(--urgent-bg);">⏰</div>
          <div class="notif-content">
            <div class="notif-title">Eat today!</div>
            <div class="notif-text">Spinach expires today. Try the garlic pasta recipe →</div>
            <div class="notif-time">2 hours ago</div>
          </div>
        </a>

        <div class="notif soon" onclick="location.href='/app/recipes'">
          <div class="notif-icon" style="background:var(--soon-bg);">🍽</div>
          <div class="notif-content">
            <div class="notif-title">3 new recipes for you</div>
            <div class="notif-text">Based on what's in your fridge, try Mediterranean Pasta Salad</div>
            <div class="notif-time">5 hours ago</div>
          </div>
        </div>

        <div class="eyebrow" style="margin:18px 0 10px;padding-left:4px;">YESTERDAY</div>

        <div class="notif fresh">
          <div class="notif-icon" style="background:var(--fresh-bg);">🎉</div>
          <div class="notif-content">
            <div class="notif-title">7-day streak unlocked!</div>
            <div class="notif-text">You saved $42 and 6 lbs of food this week. Keep it up!</div>
            <div class="notif-time">Yesterday, 8:30 AM</div>
          </div>
        </div>

        <div class="notif brand">
          <div class="notif-icon" style="background:var(--brand-soft);">👨‍👩‍👧</div>
          <div class="notif-content">
            <div class="notif-title">Sarah added milk to fridge</div>
            <div class="notif-text">Now 12 items in My Home household</div>
            <div class="notif-time">Yesterday, 4:12 PM</div>
          </div>
        </div>

        <div class="notif soon">
          <div class="notif-icon" style="background:var(--honey-soft);">📊</div>
          <div class="notif-content">
            <div class="notif-title">Weekly insights ready</div>
            <div class="notif-text">You saved $23 and reduced waste by 15% this week</div>
            <div class="notif-time">Yesterday, 9:00 AM</div>
          </div>
        </div>

        <div id="dynamicNotifs"></div>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  document.getElementById('markAllBtn')?.addEventListener('click', () => {
    document.querySelectorAll('.notif').forEach(n => n.classList.add('read'));
  });
</script>
