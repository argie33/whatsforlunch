---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';

const mockNotifications = [
  { id: '1', icon: '⏰', title: 'Bread expires today', time: '2 hours ago', read: false },
  { id: '2', icon: '🔥', title: 'You have a 3-day streak!', time: '1 day ago', read: true },
  { id: '3', icon: '✅', title: 'Milk used successfully', time: '2 days ago', read: true },
];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Notifications — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Notifications" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        {mockNotifications.map((notif) => (
          <Card
            key={notif.id}
            pressable
            style="margin-bottom: 10px; cursor: pointer;"
            onclick={`alert('Notification: ${notif.title}')`}
          >
            <div style="padding: 14px; display: flex; gap: 12px;">
              <div style="font-size: 24px;">{notif.icon}</div>
              <div style="flex: 1;">
                <h4 style="font-size: 15px; font-weight: 700; margin: 0 0 2px 0;">{notif.title}</h4>
                <p style="font-size: 12px; color: var(--t2); margin: 0;">{notif.time}</p>
              </div>
              {!notif.read && (
                <div
                  style="width: 8px; height: 8px; border-radius: 50%; background: var(--brand); flex-shrink: 0; margin-top: 6px;"
                ></div>
              )}
            </div>
          </Card>
        ))}
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  .notification-card {
    background: var(--raised);
    border: 1px solid var(--b1);
    border-radius: var(--r-lg);
    padding: 14px;
    margin-bottom: 10px;
    display: flex;
    gap: 12px;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.2s;
  }

  .notification-card:active {
    transform: scale(0.98);
  }
</style>

<script>
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  // Notifications are currently static but could be wired to an API endpoint
  // For now showing demo notifications
</script>
