---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const households = [
  { id: '1', name: 'My Home', members: 3, active: true },
  { id: '2', name: 'Parents Home', members: 2, active: false },
  { id: '3', name: 'Vacation Home', members: 1, active: false },
];

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Switch Household — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Your Households" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        {households.map((household) => (
          <Card
            key={household.id}
            pressable
            style={`margin-bottom: 10px; cursor: pointer; opacity: ${household.active ? '1' : '0.8'};`}
            onclick={`location.href='/app/dashboard'`}
          >
            <div style="padding: 14px; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">{household.name}</p>
                <p style="font-size: 12px; color: var(--t2); margin: 4px 0 0 0;">{household.members} members</p>
              </div>
              {household.active && (
                <div style="background: var(--fresh); color: white; padding: 4px 8px; border-radius: var(--r-full); font-size: 11px; font-weight: 600;">
                  Active
                </div>
              )}
            </div>
          </Card>
        ))}

        <Button variant="secondary" block onclick="alert('Create household')" style="margin-top: 16px;">
          ➕ Create Household
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
