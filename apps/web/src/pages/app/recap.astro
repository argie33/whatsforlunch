---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import InsightCard from '@/components/InsightCard.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Month Recap — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="May Recap" subtitle="Your monthly summary" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Big Stats -->
      <div style="padding: 16px 22px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
          <Card>
            <div style="padding: 16px; text-align: center;">
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 8px 0; letter-spacing: 1.5px;">Items Tracked</p>
              <p style="font-size: 32px; font-weight: 800; color: var(--brand); margin: 0; font-family: 'Fraunces', serif;">84</p>
            </div>
          </Card>
          <Card>
            <div style="padding: 16px; text-align: center;">
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 8px 0; letter-spacing: 1.5px;">Money Saved</p>
              <p style="font-size: 32px; font-weight: 800; color: var(--fresh); margin: 0; font-family: 'Fraunces', serif;">$142</p>
            </div>
          </Card>
        </div>

        <!-- Highlights -->
        <InsightCard
          eyebrow="Outstanding Month"
          title="Amazing Work!"
          text="You prevented $142 in food waste. That's 42 lbs of food saved from the trash. 🌍"
          icon="🎉"
        />

        <!-- Breakdown -->
        <p class="eyebrow" style="margin: 24px 0 12px 0;">Breakdown</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: grid; gap: 12px;">
            <div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px;">
                <span style="color: var(--t1);">🥦 Vegetables</span>
                <span style="color: var(--t2);">28 items</span>
              </div>
              <div style="height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
                <div
                  style="width: 45%; height: 100%; background: linear-gradient(90deg, #1F9956 0%, #34B86C 100%); border-radius: 3px;"
                ></div>
              </div>
            </div>
            <div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px;">
                <span style="color: var(--t1);">🥛 Dairy</span>
                <span style="color: var(--t2);">22 items</span>
              </div>
              <div style="height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
                <div
                  style="width: 35%; height: 100%; background: linear-gradient(90deg, var(--sky) 0%, var(--brand-light) 100%); border-radius: 3px;"
                ></div>
              </div>
            </div>
            <div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px;">
                <span style="color: var(--t1);">🍎 Fruits</span>
                <span style="color: var(--t2);">34 items</span>
              </div>
              <div style="height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
                <div
                  style="width: 55%; height: 100%; background: linear-gradient(90deg, var(--coral) 0%, var(--honey) 100%); border-radius: 3px;"
                ></div>
              </div>
            </div>
          </div>
        </Card>

        <!-- Share -->
        <Button variant="primary" block onclick="alert('Share recap')">
          📤 Share Your Recap
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
