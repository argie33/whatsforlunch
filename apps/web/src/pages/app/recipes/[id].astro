---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const { id } = Astro.params;

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Recipe — WhatsFresh">
  <main>
    <div class="scroll no-status no-tab" id="recipeDetailScroll">

      <!-- Hero photo area -->
      <div class="detail-photo" id="recipeHero">
        <a href="/app/recipes" class="btn-icon glass detail-back" style="top:60px;text-decoration:none;">←</a>
        <div class="detail-actions-top" style="top:60px;">
          <button class="btn-icon glass">♡</button>
          <button class="btn-icon glass">↗</button>
        </div>
        <span id="recipeEmoji" style="font-size:80px;">🍽</span>
        <div class="recipe-match" style="top:60px;right:auto;left:50%;transform:translateX(-50%);" id="recipeMatchEl">⭐ 92% match</div>
      </div>

      <div class="detail-body">
        <div class="detail-title serif" id="recipeTitle">Loading recipe...</div>
        <div class="detail-meta" id="recipeMeta">⏱ — min · 🍽 — servings</div>

        <!-- Stats grid -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:24px;" id="statsGrid">
          <div style="text-align:center;padding:14px 8px;background:var(--raised);border:1px solid var(--b1);border-radius:var(--r-md);">
            <div style="font-family:Fraunces,serif;font-size:24px;font-weight:800;" id="statTime">—</div>
            <div style="font-size:11px;color:var(--t2);margin-top:2px;">min total</div>
          </div>
          <div style="text-align:center;padding:14px 8px;background:var(--raised);border:1px solid var(--b1);border-radius:var(--r-md);">
            <div style="font-family:Fraunces,serif;font-size:24px;font-weight:800;" id="statServings">—</div>
            <div style="font-size:11px;color:var(--t2);margin-top:2px;">servings</div>
          </div>
          <div style="text-align:center;padding:14px 8px;background:var(--raised);border:1px solid var(--b1);border-radius:var(--r-md);">
            <div style="font-family:Fraunces,serif;font-size:24px;font-weight:800;">~320</div>
            <div style="font-size:11px;color:var(--t2);margin-top:2px;">cal</div>
          </div>
        </div>

        <!-- Ingredients -->
        <div class="section-title serif" style="margin-bottom:12px;">Ingredients</div>
        <div class="info-card" id="ingredientsList">
          <div style="padding:14px;text-align:center;color:var(--t2);font-size:13px;">Loading...</div>
        </div>

        <!-- Instructions -->
        <div class="section-title serif" style="margin:24px 0 12px;">Instructions</div>
        <div class="info-card" id="instructionsList" style="padding:0 18px;">
          <div class="step-row">
            <div class="step-num">1</div>
            <div class="step-text">Prepare all ingredients before you start cooking.</div>
          </div>
          <div class="step-row">
            <div class="step-num">2</div>
            <div class="step-text">Follow the recipe directions for best results.</div>
          </div>
          <div class="step-row">
            <div class="step-num">3</div>
            <div class="step-text">Season to taste and serve immediately.</div>
          </div>
        </div>

        <div style="margin-top:24px;padding-bottom:40px;">
          <button class="btn btn-primary btn-block btn-lg" onclick="location.href='/app/cooking'">▶ Start Cooking</button>
        </div>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="recipes" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }

  .detail-photo {
    position: relative;
    min-height: 260px;
    background: linear-gradient(135deg, var(--honey-soft) 0%, var(--coral-soft) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
</style>

<script define:vars={{ recipeId: id }}>
  async function loadRecipe() {
    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            recipe(id: "${recipeId}") {
              id name emoji cookTime servings
              ingredients { name amount inFridge }
              steps
            }
          }`
        })
      });
      const { data, errors } = await res.json();
      if (errors?.length) throw new Error(errors[0].message);

      const recipe = data?.recipe;
      if (!recipe) {
        document.getElementById('recipeTitle').textContent = 'Recipe not found';
        return;
      }

      document.getElementById('recipeEmoji').textContent = recipe.emoji || '🍽';
      document.getElementById('recipeTitle').textContent = recipe.name;
      document.getElementById('recipeMeta').textContent =
        (recipe.cookTime ? '⏱ ' + recipe.cookTime + ' min' : '') +
        (recipe.servings ? ' · 🍽 ' + recipe.servings + ' servings' : '');
      document.getElementById('statTime').textContent = recipe.cookTime || '—';
      document.getElementById('statServings').textContent = recipe.servings || '—';

      // Ingredients
      const ingList = document.getElementById('ingredientsList');
      if (recipe.ingredients?.length) {
        ingList.innerHTML = recipe.ingredients.map(ing => `
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:10px;flex:1;">
              <span style="font-size:22px;">${ing.emoji || '🥫'}</span>
              <div>
                <div style="font-weight:600;">${ing.name}</div>
                ${ing.inFridge ? '<div style="font-size:11px;color:var(--fresh);font-weight:700;">✓ in your fridge</div>' : ''}
              </div>
            </div>
            ${ing.amount ? `<div class="info-value">${ing.amount}</div>` : ''}
          </div>`).join('');
      } else {
        ingList.innerHTML = '<div style="padding:14px;color:var(--t2);font-size:13px;">Ingredients not available</div>';
      }

      // Steps
      const stepList = document.getElementById('instructionsList');
      if (recipe.steps?.length) {
        stepList.innerHTML = recipe.steps.map((step, i) => `
          <div class="step-row">
            <div class="step-num">${i + 1}</div>
            <div class="step-text">${step}</div>
          </div>`).join('');
      }
    } catch (err) {
      document.getElementById('recipeTitle').textContent = 'Failed to load recipe';
    }
  }

  loadRecipe();
</script>
