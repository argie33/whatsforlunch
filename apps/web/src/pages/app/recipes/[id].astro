---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const { id } = Astro.params;

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Recipe — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Recipe" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div id="recipe-detail-container" style="padding: 0 22px;">
        <div style="padding: 32px 0 24px; text-align: center;">
          <p style="color: var(--t2);">Loading recipe...</p>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="recipes" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  input[type='checkbox'] {
    cursor: pointer;
    accent-color: var(--brand);
  }
</style>

<script define:vars={{ recipeId: id }}>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  async function loadRecipe() {
    const container = document.getElementById('recipe-detail-container');

    try {
      // Get household ID first
      const userQuery = `query { getProfile { id } listHouseholds { id } }`;
      const userData = await gql(userQuery);

      let householdId = userData.listHouseholds?.[0]?.id;

      if (!householdId) {
        container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">No household found</p></div>';
        return;
      }

      // Fetch recipes
      const recipesQuery = `query GetRecipes($householdId: ID!) {
        getRecommendations(householdId: $householdId) {
          id name ingredients
        }
      }`;

      const recipesData = await gql(recipesQuery, { householdId });
      const recipe = recipesData.getRecommendations?.find((r) => r.id === recipeId);

      if (!recipe) {
        container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">Recipe not found</p></div>';
        return;
      }

      const ingredientsList = recipe.ingredients
        ?.map(
          (ing) => `
        <div style="display: flex; align-items: center; gap: 10px;">
          <input type="checkbox" style="width: 18px; height: 18px; cursor: pointer;" />
          <span style="font-size: 14px; color: var(--t1);">${ing}</span>
        </div>
      `
        )
        .join('') || '';

      container.innerHTML = `
        <div style="padding: 32px 0 24px; text-align: center; background: linear-gradient(135deg, var(--honey-soft) 0%, var(--coral-soft) 100%);">
          <div style="font-size: 80px; margin-bottom: 16px;">👨‍🍳</div>
          <h1 style="font-size: 28px; font-weight: 800; margin: 0 0 8px 0; color: var(--t1);">${recipe.name}</h1>
        </div>

        <div style="padding: 16px 0;">
          <p class="eyebrow" style="padding: 0 0 12px 0; margin: 16px 0 0 0;">Ingredients</p>
          <div style="background: var(--raised); border: 1px solid var(--b1); border-radius: var(--r-lg); padding: 16px; margin-bottom: 16px; display: flex; flex-direction: column; gap: 10px;">
            ${ingredientsList}
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
            <button onclick="location.href='/app/recipes'" style="padding: 16px; background: transparent; color: var(--t1); border: 1.5px solid var(--b1); border-radius: var(--r-md); font-weight: 700; cursor: pointer;">
              More Recipes
            </button>
            <button onclick="location.href='/app/cooking'" style="padding: 16px; background: var(--brand); color: white; border: none; border-radius: var(--r-md); font-weight: 700; cursor: pointer;">
              👨‍🍳 Start Cooking
            </button>
          </div>
        </div>
      `;
    } catch (error) {
      console.error('Failed to load recipe:', error);
      container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">Failed to load recipe</p></div>';
    }
  }

  loadRecipe();
</script>
