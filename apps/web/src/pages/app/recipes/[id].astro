---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

export async function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
  ];
}

const mockRecipes: Record<string, any> = {
  '1': {
    name: 'Stir-fry Vegetables',
    emoji: '🍳',
    time: 15,
    difficulty: 'Easy',
    servings: 2,
    ingredients: [
      { name: 'Broccoli', status: 'have' },
      { name: 'Soy sauce', status: 'have' },
      { name: 'Garlic', status: 'need' },
    ],
    instructions: [
      'Heat oil in a wok or large pan',
      'Add chopped garlic and stir for 30 seconds',
      'Add broccoli florets and stir fry for 3-4 minutes',
      'Add soy sauce and serve hot',
    ],
  },
  '2': {
    name: 'Smoothie Bowl',
    emoji: '🍓',
    time: 5,
    difficulty: 'Easy',
    servings: 1,
    ingredients: [
      { name: 'Yogurt', status: 'have' },
      { name: 'Berries', status: 'have' },
    ],
    instructions: [
      'Blend yogurt and berries together',
      'Pour into bowl',
      'Top with granola and fresh fruit',
    ],
  },
  '3': {
    name: 'Grilled Broccoli',
    emoji: '🥦',
    time: 10,
    difficulty: 'Easy',
    servings: 4,
    ingredients: [
      { name: 'Broccoli', status: 'have' },
      { name: 'Olive oil', status: 'have' },
      { name: 'Salt & pepper', status: 'have' },
    ],
    instructions: [
      'Preheat grill to medium-high',
      'Toss broccoli with olive oil and seasonings',
      'Grill for 4-5 minutes until tender-crisp',
      'Serve immediately',
    ],
  },
};

const { id } = Astro.params;
const recipe = mockRecipes[id!] || mockRecipes['1'];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title={`${recipe.name} — WhatsFresh`}>
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Recipe" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Header -->
      <div style="padding: 32px 22px 24px; text-align: center; background: linear-gradient(135deg, var(--honey-soft) 0%, var(--coral-soft) 100%);">
        <div style="font-size: 80px; margin-bottom: 16px;">{recipe.emoji}</div>
        <h1 style="font-size: 28px; font-weight: 800; margin: 0 0 16px 0; color: var(--t1);">{recipe.name}</h1>
        <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;">
          <span style="background: var(--raised); padding: 6px 12px; border-radius: var(--r-full); font-size: 12px; font-weight: 600;">⏱️ {recipe.time} min</span>
          <span style="background: var(--raised); padding: 6px 12px; border-radius: var(--r-full); font-size: 12px; font-weight: 600;">👥 {recipe.servings} servings</span>
          <span style="background: var(--raised); padding: 6px 12px; border-radius: var(--r-full); font-size: 12px; font-weight: 600;">{recipe.difficulty}</span>
        </div>
      </div>

      <!-- Content -->
      <div style="padding: 16px 22px;">
        <!-- Ingredients -->
        <p class="eyebrow" style="margin-bottom: 12px;">Ingredients</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 10px;">
            {recipe.ingredients.map((ing) => (
              <div key={ing.name} style="display: flex; align-items: center; gap: 10px;">
                <input type="checkbox" style="width: 18px; height: 18px; cursor: pointer;" />
                <span style={`font-size: 14px; ${ing.status === 'need' ? 'color: var(--t2);' : 'color: var(--t1);'}`}>
                  {ing.name}
                  {ing.status === 'need' && ' (need to buy)'}
                </span>
              </div>
            ))}
          </div>
        </Card>

        <!-- Instructions -->
        <p class="eyebrow" style="margin-bottom: 12px;">Instructions</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 12px;">
            {recipe.instructions.map((instruction, index) => (
              <div key={index} style="display: flex; gap: 12px;">
                <div
                  style="min-width: 28px; width: 28px; height: 28px; border-radius: var(--r-full); background: var(--brand-soft); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: var(--brand); flex-shrink: 0;"
                >
                  {index + 1}
                </div>
                <p style="font-size: 14px; line-height: 1.5; margin: 0; color: var(--t1);">{instruction}</p>
              </div>
            ))}
          </div>
        </Card>

        <!-- Action Buttons -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
          <Button variant="secondary" block onclick="location.href='/app/recipes'">
            More Recipes
          </Button>
          <Button variant="primary" block onclick="location.href='/app/cooking'">
            👨‍🍳 Start Cooking
          </Button>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="recipes" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  input[type='checkbox'] {
    cursor: pointer;
    accent-color: var(--brand);
  }
</style>
