---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Shopping — WhatsFresh">
  <main>
    <div class="scroll" id="shopScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/dashboard" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Shopping</div>
        <button class="btn-icon" id="shareBtn" aria-label="Share list">↗</button>
      </div>

      <!-- Today's summary card -->
      <div style="padding:0 22px 14px;">
        <div class="card" style="background:linear-gradient(135deg,var(--coral) 0%,var(--honey) 100%);color:white;border:none;padding:20px;">
          <div style="font-size:11px;font-weight:800;letter-spacing:2px;opacity:0.85;text-transform:uppercase;margin-bottom:8px;">🛒 Today</div>
          <div style="font-family:Fraunces,serif;font-size:30px;font-weight:800;letter-spacing:-1px;line-height:1;margin-bottom:4px;" id="shopSummary">3 items · ~$24</div>
          <div style="font-size:14px;opacity:0.92;">Estimated time: 25 min at the store</div>
        </div>
      </div>

      <!-- To buy list -->
      <div class="section-header" style="padding:0 22px;">
        <div class="section-title serif">To buy</div>
        <button class="section-link" id="addItemBtn">+ Add</button>
      </div>
      <div style="padding:0 22px;">
        <div class="info-card" id="shopList">
          <div class="info-row" style="cursor:pointer;" onclick="toggleShop(this)">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="shop-circle"><!-- --></div>
              <span style="font-size:22px;">🥛</span>
              <div>
                <div style="font-weight:600;" class="shop-label">Whole milk</div>
                <div style="font-size:12px;color:var(--t2);">1 gallon · $4.99</div>
              </div>
            </div>
          </div>
          <div class="info-row" style="cursor:pointer;" onclick="toggleShop(this)">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="shop-circle done">✓</div>
              <span style="font-size:22px;">🥬</span>
              <div>
                <div style="font-weight:600;text-decoration:line-through;color:var(--t3);" class="shop-label">Spinach</div>
                <div style="font-size:12px;color:var(--t3);">2 bunches · $3.99</div>
              </div>
            </div>
          </div>
          <div class="info-row" style="cursor:pointer;" onclick="toggleShop(this)">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="shop-circle"><!-- --></div>
              <span style="font-size:22px;">🍗</span>
              <div>
                <div style="font-weight:600;" class="shop-label">Chicken breast</div>
                <div style="font-size:12px;color:var(--t2);">2 lbs · $12.99</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Smart suggestions -->
      <div class="section-header" style="padding:16px 22px 14px;">
        <div class="section-title serif">Smart suggestions</div>
      </div>
      <div style="padding:0 22px 14px;">
        <div style="font-size:13px;color:var(--t2);margin-bottom:12px;padding:0 4px;">Based on what you usually buy and what's running low</div>
        <div class="info-card">
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="font-size:24px;">🍞</span>
              <div>
                <div style="font-weight:600;">Whole wheat bread</div>
                <div style="font-size:11px;color:var(--t3);">You usually buy weekly · $3.49</div>
              </div>
            </div>
            <button class="btn-icon" style="font-size:18px;" onclick="addSuggestion(this,'🍞','Whole wheat bread')">+</button>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="font-size:24px;">🥑</span>
              <div>
                <div style="font-weight:600;">Avocados</div>
                <div style="font-size:11px;color:var(--t3);">Running low · $2.99</div>
              </div>
            </div>
            <button class="btn-icon" style="font-size:18px;" onclick="addSuggestion(this,'🥑','Avocados')">+</button>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="font-size:24px;">🍅</span>
              <div>
                <div style="font-weight:600;">Tomatoes</div>
                <div style="font-size:11px;color:var(--t3);">Often paired with spinach · $4.49</div>
              </div>
            </div>
            <button class="btn-icon" style="font-size:18px;" onclick="addSuggestion(this,'🍅','Tomatoes')">+</button>
          </div>
        </div>
      </div>

      <!-- Get it delivered -->
      <div class="section-header" style="padding:16px 22px 14px;">
        <div class="section-title serif">Get it delivered</div>
      </div>
      <div style="padding:0 22px 14px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div class="card card-pressable" style="padding:14px;text-align:center;background:linear-gradient(135deg,#FFF5E6,#FFE5C7);border:1px solid #F5C998;">
            <div style="font-size:32px;">🥕</div>
            <div style="font-weight:800;font-size:14px;margin-top:6px;color:#7A4700;">Instacart</div>
            <div style="font-size:11px;color:var(--t2);margin-top:2px;">In ~1 hour · $7.99</div>
          </div>
          <div class="card card-pressable" style="padding:14px;text-align:center;background:linear-gradient(135deg,#E8F4FF,#D0E8FA);border:1px solid #93C5F0;">
            <div style="font-size:32px;">📦</div>
            <div style="font-weight:800;font-size:14px;margin-top:6px;color:#003D6B;">Amazon Fresh</div>
            <div style="font-size:11px;color:var(--t2);margin-top:2px;">Today · Free $35+</div>
          </div>
          <div class="card card-pressable" style="padding:14px;text-align:center;background:linear-gradient(135deg,#FFF9E6,#FFEFB3);border:1px solid #F4D374;">
            <div style="font-size:32px;">🛒</div>
            <div style="font-weight:800;font-size:14px;margin-top:6px;color:#544100;">Walmart+</div>
            <div style="font-size:11px;color:var(--t2);margin-top:2px;">Same day · Free 35+</div>
          </div>
          <div class="card card-pressable" style="padding:14px;text-align:center;background:linear-gradient(135deg,var(--coral-soft),#FFCEC0);border:1px solid #F09578;">
            <div style="font-size:32px;">🏪</div>
            <div style="font-weight:800;font-size:14px;margin-top:6px;color:#6B2A0F;">DoorDash</div>
            <div style="font-size:11px;color:var(--t2);margin-top:2px;">~30 min · $5.99</div>
          </div>
        </div>
        <div style="font-size:10px;color:var(--t3);text-align:center;margin-top:10px;">Affiliate · We may earn a small commission</div>
      </div>

      <div style="padding:0 22px 40px;">
        <button class="btn btn-primary btn-block btn-lg">View store map</button>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }

  .shop-circle {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid var(--b2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 12px;
    font-weight: 700;
  }

  .shop-circle.done {
    background: var(--brand);
    border-color: var(--brand);
    color: white;
  }
</style>

<script>
  function toggleShop(row: HTMLElement) {
    const circle = row.querySelector('.shop-circle') as HTMLElement;
    const label = row.querySelector('.shop-label') as HTMLElement;
    if (!circle || !label) return;
    circle.classList.toggle('done');
    if (circle.classList.contains('done')) {
      circle.textContent = '✓';
      label.style.textDecoration = 'line-through';
      label.style.color = 'var(--t3)';
    } else {
      circle.textContent = '';
      label.style.textDecoration = '';
      label.style.color = '';
    }
  }

  (window as any).toggleShop = toggleShop;

  function addSuggestion(btn: HTMLElement, emoji: string, name: string) {
    btn.textContent = '✓';
    btn.style.background = 'var(--brand-soft)';
    btn.style.color = 'var(--brand)';
  }

  (window as any).addSuggestion = addSuggestion;
</script>
