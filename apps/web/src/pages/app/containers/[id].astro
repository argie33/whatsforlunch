---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import ItemCard from '@/components/ItemCard.astro';
import Button from '@/components/Button.astro';

const { id } = Astro.params;

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Container — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Container" subtitle="Items" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div id="container-detail-container" style="padding: 0 22px;">
        <div style="padding: 32px 0 24px; text-align: center;">
          <p style="color: var(--t2);">Loading container...</p>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>

<script define:vars={{ containerId: id }}>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  const containerEmojiMap = {
    fridge: '🧊',
    freezer: '❄️',
    counter: '🏠',
    pantry: '🥫',
    other: '📦',
  };

  const itemEmojiMap = {
    vegetable: '🥦',
    fruit: '🍎',
    dairy: '🥛',
    bread: '🍞',
    meat: '🥩',
    frozen: '🧊',
    pantry: '🥫',
    other: '📦',
  };

  async function loadContainer() {
    const container = document.getElementById('container-detail-container');

    try {
      const userQuery = `query { getProfile { id } listHouseholds { id } }`;
      const userData = await gql(userQuery);

      let householdId = userData.listHouseholds?.[0]?.id;

      if (!householdId) {
        container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">No household found</p></div>';
        return;
      }

      // Fetch containers
      const containersQuery = `query ListContainers($householdId: ID!) {
        listContainers(householdId: $householdId) {
          id nickname
        }
      }`;

      const containersData = await gql(containersQuery, { householdId });
      const containerData = containersData.listContainers?.find((c) => c.id === containerId);

      if (!containerData) {
        container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">Container not found</p></div>';
        return;
      }

      // Fetch items for this container
      const itemsQuery = `query ListItems($householdId: ID!) {
        listItems(householdId: $householdId) {
          id foodName category storageLocation status
        }
      }`;

      const itemsData = await gql(itemsQuery, { householdId });
      const containerItems = itemsData.listItems?.filter((i) => i.storageLocation === containerData.nickname) || [];

      const emoji = containerEmojiMap[containerData.nickname?.toLowerCase()] || containerEmojiMap.other;

      const itemsList = containerItems
        .map(
          (item) => `
        <div style="background: var(--raised); border: 1px solid var(--b1); border-radius: var(--r-lg); padding: 14px; margin-bottom: 10px; display: flex; gap: 12px; cursor: pointer;" onclick="location.href='/app/items/${item.id}'">
          <div style="width: 48px; height: 48px; border-radius: var(--r-md); background: var(--sunken); display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0;">
            ${itemEmojiMap[item.category?.toLowerCase()] || itemEmojiMap.other}
          </div>
          <div style="flex: 1;">
            <div style="font-size: 16px; font-weight: 700; color: var(--t1);">${item.foodName}</div>
            <div style="font-size: 13px; color: var(--t2);">${item.storageLocation}</div>
          </div>
        </div>
      `
        )
        .join('');

      container.innerHTML = `
        <div style="padding: 24px 0 16px; text-align: center;">
          <div style="font-size: 64px; margin-bottom: 12px;">${emoji}</div>
          <h1 style="font-size: 24px; font-weight: 800; margin: 0; color: var(--t1);">${containerData.nickname}</h1>
        </div>

        <div style="padding: 0 0 16px;">
          ${
            containerItems.length > 0
              ? `
            <p class="eyebrow" style="padding: 0 0 12px 0; margin: 16px 0 0 0;">Items</p>
            ${itemsList}
          `
              : `
            <div style="background: var(--raised); border: 1px solid var(--b1); border-radius: var(--r-lg); text-align: center; margin-top: 16px;">
              <div style="padding: 32px 16px;">
                <p style="font-size: 40px; margin: 0 0 12px 0;">📭</p>
                <p style="color: var(--t2); margin: 0; font-size: 14px;">No items in this container yet</p>
              </div>
            </div>
          `
          }
        </div>

        <div style="padding-top: 8px;">
          <button onclick="alert('Edit container')" style="width: 100%; padding: 16px; background: transparent; color: var(--t1); border: 1.5px solid var(--b1); border-radius: var(--r-md); font-weight: 700; cursor: pointer; margin-bottom: 8px; font-family: inherit; font-size: 14px;">
            ✏️ Edit
          </button>
          <button onclick="alert('Delete container')" style="width: 100%; padding: 16px; background: transparent; color: var(--t1); border: none; border-radius: var(--r-md); font-weight: 700; cursor: pointer; font-family: inherit; font-size: 14px;">
            🗑️ Delete
          </button>
        </div>
      `;
    } catch (error) {
      console.error('Failed to load container:', error);
      container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">Failed to load container</p></div>';
    }
  }

  loadContainer();
</script>
