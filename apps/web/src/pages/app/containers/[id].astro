---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import ItemCard from '@/components/ItemCard.astro';
import Button from '@/components/Button.astro';

export async function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
  ];
}

const mockContainers: Record<string, any> = {
  '1': {
    name: 'Main Fridge',
    emoji: '🧊',
    temp: '38°F',
    humidity: '65%',
    items: [
      { id: '1', name: 'Broccoli', emoji: '🥦', status: 'fresh', days: 5 },
      { id: '2', name: 'Milk', emoji: '🥛', status: 'soon', days: 2 },
    ],
  },
  '2': {
    name: 'Freezer',
    emoji: '❄️',
    temp: '0°F',
    humidity: 'N/A',
    items: [],
  },
  '3': {
    name: 'Counter',
    emoji: '🏠',
    temp: '72°F',
    humidity: '45%',
    items: [
      { id: '3', name: 'Bread', emoji: '🍞', status: 'urgent', days: 0 },
    ],
  },
};

const { id } = Astro.params;
const container = mockContainers[id!] || mockContainers['1'];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title={`${container.name} — WhatsFresh`}>
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title={container.name} subtitle={`${container.items.length} items`} />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Header -->
      <div style="padding: 24px 22px 16px; text-align: center;">
        <div style="font-size: 64px; margin-bottom: 12px;">{container.emoji}</div>
      </div>

      <!-- Status -->
      <div style="padding: 0 22px 16px;">
        <Card>
          <div style="padding: 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
            <div style="text-align: center;">
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Temperature</p>
              <p style="font-size: 18px; font-weight: 700; margin: 0; color: var(--t1);">{container.temp}</p>
            </div>
            {container.humidity !== 'N/A' && (
              <div style="text-align: center;">
                <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Humidity</p>
                <p style="font-size: 18px; font-weight: 700; margin: 0; color: var(--t1);">{container.humidity}</p>
              </div>
            )}
          </div>
        </Card>
      </div>

      <!-- Items in Container -->
      {container.items.length > 0 && (
        <div style="padding: 0 22px;">
          <p class="eyebrow" style="margin-bottom: 12px;">Items</p>
          {container.items.map((item) => (
            <ItemCard
              key={item.id}
              name={item.name}
              emoji={item.emoji}
              status={item.status}
              days={item.days}
              onClick={`location.href='/app/items/${item.id}'`}
            />
          ))}
        </div>
      )}

      {container.items.length === 0 && (
        <div style="padding: 0 22px;">
          <Card style="text-align: center;">
            <div style="padding: 32px 16px;">
              <p style="font-size: 40px; margin: 0 0 12px 0;">📭</p>
              <p style="color: var(--t2); margin: 0; font-size: 14px;">No items in this container yet</p>
            </div>
          </Card>
        </div>
      )}

      <!-- Actions -->
      <div style="padding: 16px 22px;">
        <Button variant="secondary" block onclick="alert('Edit container')" style="margin-bottom: 8px;">
          ✏️ Edit
        </Button>
        <Button variant="ghost" block onclick="alert('Delete container')">
          🗑️ Delete
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
