---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Profile — WhatsFresh">
  <main>
    <div class="scroll" id="profileScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Profile</div>
        <a href="/app/profile/edit" class="btn-ghost" style="font-weight:800;text-decoration:none;color:var(--brand);">Edit</a>
      </div>

      <!-- Profile header -->
      <div style="padding:8px 22px 20px;text-align:center;">
        <div class="avatar-xl" id="profileAvatar">Y</div>
        <div class="profile-name" id="profileName">Loading...</div>
        <div class="profile-email" id="profileEmail">...</div>
        <div class="profile-stats">
          <div class="profile-stat">
            <div class="profile-stat-num" id="statItems">—</div>
            <div class="profile-stat-label">Items</div>
          </div>
          <div class="profile-stat">
            <div class="profile-stat-num" id="statSaved">—</div>
            <div class="profile-stat-label">$ Saved</div>
          </div>
          <div class="profile-stat">
            <div class="profile-stat-num" id="statStreak">—</div>
            <div class="profile-stat-label">Day streak</div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div style="padding:0 22px;">

        <div class="settings-section">ACCOUNT</div>
        <div class="info-card" style="margin-bottom:14px;">
          <a href="/app/profile/edit" class="settings-row" style="text-decoration:none;">
            <div class="settings-icon green">✎</div>
            <div class="settings-content">
              <div class="settings-title">Edit profile</div>
              <div class="settings-sub">Update name, photo, bio</div>
            </div>
            <span class="chevron">›</span>
          </a>
          <a href="/app/household" class="settings-row" style="text-decoration:none;">
            <div class="settings-icon honey">🏠</div>
            <div class="settings-content">
              <div class="settings-title">Household</div>
              <div class="settings-sub" id="householdName">My Home</div>
            </div>
            <span class="chevron">›</span>
          </a>
          <a href="/app/preferences" class="settings-row" style="text-decoration:none;">
            <div class="settings-icon sky">⚙️</div>
            <div class="settings-content">
              <div class="settings-title">Preferences</div>
              <div class="settings-sub">Notifications, dietary</div>
            </div>
            <span class="chevron">›</span>
          </a>
        </div>

        <div class="settings-section">DATA</div>
        <div class="info-card" style="margin-bottom:14px;">
          <a href="/app/data-export" class="settings-row" style="text-decoration:none;">
            <div class="settings-icon sky">📥</div>
            <div class="settings-content">
              <div class="settings-title">Export data</div>
              <div class="settings-sub">Download your food history</div>
            </div>
            <span class="chevron">›</span>
          </a>
          <a href="/app/delete-account" class="settings-row" style="text-decoration:none;">
            <div class="settings-icon coral">🗑</div>
            <div class="settings-content">
              <div class="settings-title" style="color:var(--urgent);">Delete account</div>
              <div class="settings-sub">Permanently remove your data</div>
            </div>
            <span class="chevron">›</span>
          </a>
        </div>

        <button class="settings-row info-card" id="logoutBtn" style="width:100%;text-align:left;border:none;cursor:pointer;margin-bottom:14px;background:var(--raised);">
          <div class="settings-icon coral">🚪</div>
          <div class="settings-content">
            <div class="settings-title" style="color:var(--urgent);">Sign out</div>
          </div>
        </button>

      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  async function loadProfile() {
    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            me { name email }
            items(limit: 200) { id }
          }`
        })
      });
      const { data } = await res.json();
      const user = data?.me;

      if (user) {
        const initials = (user.name || 'U').split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase();
        const avatarEl = document.getElementById('profileAvatar');
        if (avatarEl) avatarEl.textContent = initials;

        const nameEl = document.getElementById('profileName');
        if (nameEl) nameEl.textContent = user.name || 'User';

        const emailEl = document.getElementById('profileEmail');
        if (emailEl) emailEl.textContent = user.email || '';
      }

      const items = data?.items || [];
      const itemsEl = document.getElementById('statItems');
      if (itemsEl) itemsEl.textContent = String(items.length);

      const savedEl = document.getElementById('statSaved');
      if (savedEl) savedEl.textContent = '$127';

      const streakEl = document.getElementById('statStreak');
      if (streakEl) streakEl.textContent = '7';
    } catch (_) {}
  }

  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    try {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
    } catch (_) {}
    location.href = '/auth/login';
  });

  loadProfile();
</script>
