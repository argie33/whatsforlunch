---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Profile — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Profile" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Header -->
      <div id="profile-header" style="padding: 24px 22px; text-align: center; background: linear-gradient(135deg, var(--brand-soft) 0%, var(--brand-tint) 100%); min-height: 160px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--brand); margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; font-size: 40px;">
          👤
        </div>
        <h1 id="profile-name" style="font-size: 24px; font-weight: 800; margin: 0 0 4px 0; color: var(--t1);">Loading...</h1>
        <p id="profile-email" style="font-size: 13px; color: var(--t2); margin: 0;">...</p>
      </div>

      <!-- Stats -->
      <div style="padding: 16px 22px;">
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; text-align: center;">
            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Items</p>
              <p id="stat-items" style="font-size: 20px; font-weight: 700; margin: 0; color: var(--brand);">—</p>
            </div>
            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Streak</p>
              <p id="stat-streak" style="font-size: 20px; font-weight: 700; margin: 0; color: var(--coral);">—</p>
            </div>
            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Tier</p>
              <p id="stat-tier" style="font-size: 20px; font-weight: 700; margin: 0; color: var(--fresh);">—</p>
            </div>
          </div>
        </Card>

        <!-- Actions -->
        <Button variant="secondary" block onclick="location.href='/app/profile/edit'" style="margin-bottom: 8px;">
          ✏️ Edit Profile
        </Button>
        <Button variant="secondary" block onclick="location.href='/app/preferences'" style="margin-bottom: 8px;">
          ⚙️ Preferences
        </Button>
        <Button variant="secondary" block onclick="location.href='/app/household'" style="margin-bottom: 24px;">
          🏠 Household
        </Button>

        <!-- Account -->
        <p class="eyebrow" style="margin-bottom: 12px;">Account</p>
        <Card style="margin-bottom: 16px;">
          <div style="display: flex; flex-direction: column;">
            <button
              style="padding: 14px; background: none; border: none; border-bottom: 1px solid var(--b1); text-align: left; cursor: pointer; font-family: inherit; font-size: 14px; color: var(--t1);"
              onclick="alert('Change password')"
            >
              🔐 Change Password
            </button>
            <button
              style="padding: 14px; background: none; border: none; text-align: left; cursor: pointer; font-family: inherit; font-size: 14px; color: var(--t1);"
              onclick="location.href='/app/data-export'"
            >
              📥 Export Data
            </button>
          </div>
        </Card>

        <!-- Logout -->
        <Button variant="ghost" block onclick="location.href='/'">
          🚪 Logout
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  button:active {
    opacity: 0.7;
  }
</style>

<script>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  async function loadProfile() {
    try {
      // Fetch user profile
      const query = `query {
        getProfile {
          id
          email
          displayName
          subscriptionTier
        }
      }`;

      const data = await gql(query);
      const user = data.getProfile;

      // Update header
      document.getElementById('profile-name').textContent = user.displayName || 'User';
      document.getElementById('profile-email').textContent = user.email;

      // Update tier
      const tierMap = {
        free: 'Free',
        premium: 'Premium',
        pro: 'Pro',
      };
      document.getElementById('stat-tier').textContent = tierMap[user.subscriptionTier?.toLowerCase()] || 'Free';
    } catch (error) {
      console.error('Failed to load profile:', error);
      document.getElementById('profile-name').textContent = 'Error Loading';
      document.getElementById('profile-email').textContent = 'Try refreshing';
    }
  }

  loadProfile();
</script>
