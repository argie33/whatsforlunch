---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Search — WhatsFresh">
  <main>
    <div class="scroll no-tab" id="searchScroll">

      <!-- Back bar with inline search -->
      <div class="back-bar" style="padding-top:28px;gap:10px;">
        <a href="/app/items" class="btn-icon" style="text-decoration:none;">←</a>
        <div style="flex:1;display:flex;align-items:center;gap:10px;background:var(--sunken);padding:10px 14px;border-radius:var(--r-md);">
          <span style="color:var(--t3);font-size:18px;">🔍</span>
          <input id="searchInput" style="flex:1;border:none;background:transparent;font-size:15px;outline:none;font-family:inherit;color:var(--t1);" placeholder="Search items, recipes, friends..." autocomplete="off" />
          <button class="btn-icon" style="font-size:16px;" id="clearBtn">✕</button>
        </div>
      </div>

      <div style="padding:0 22px;">

        <!-- Items results -->
        <div id="itemsSection">
          <div class="caption" style="color:var(--t2);margin-bottom:8px;">ITEMS</div>
          <div class="info-card" id="itemsList">
            <div style="padding:14px;text-align:center;color:var(--t2);font-size:13px;">Start typing to search...</div>
          </div>
        </div>

        <!-- Recipes results -->
        <div id="recipesSection" style="margin-top:18px;">
          <div class="caption" style="color:var(--t2);margin-bottom:8px;">RECIPES</div>
          <div class="info-card" id="recipesList">
            <div style="padding:14px;text-align:center;color:var(--t2);font-size:13px;">Start typing to search...</div>
          </div>
        </div>

        <!-- Recent searches -->
        <div id="recentSection" style="margin-top:18px;">
          <div class="caption" style="color:var(--t2);margin-bottom:8px;">RECENT SEARCHES</div>
          <div class="info-card" id="recentList">
            <div class="info-row">
              <span style="display:flex;align-items:center;gap:10px;"><span>🕐</span> avocado toast recipes</span>
              <button class="btn-icon" style="font-size:14px;">✕</button>
            </div>
            <div class="info-row">
              <span style="display:flex;align-items:center;gap:10px;"><span>🕐</span> chicken expiry</span>
              <button class="btn-icon" style="font-size:14px;">✕</button>
            </div>
            <div class="info-row">
              <span style="display:flex;align-items:center;gap:10px;"><span>🕐</span> what to eat tonight</span>
              <button class="btn-icon" style="font-size:14px;">✕</button>
            </div>
          </div>
        </div>

      </div>
    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  let allItems: any[] = [];
  let allRecipes: any[] = [];

  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const itemsList = document.getElementById('itemsList')!;
  const recipesList = document.getElementById('recipesList')!;
  const recentSection = document.getElementById('recentSection')!;

  function getDaysLabel(d: number) {
    if (d < 0) return 'Expired';
    if (d === 0) return 'Today';
    if (d === 1) return '1d';
    return `${d}d`;
  }

  function getStatusBg(status: string) {
    if (status === 'urgent') return 'var(--urgent-bg)';
    if (status === 'soon') return 'var(--soon-bg)';
    if (status === 'fresh') return 'var(--fresh-bg)';
    return 'var(--sunken)';
  }

  function getStatusColor(status: string) {
    if (status === 'urgent') return 'var(--urgent)';
    if (status === 'soon') return 'var(--soon)';
    if (status === 'fresh') return 'var(--fresh)';
    return 'var(--t2)';
  }

  function highlight(text: string, query: string) {
    if (!query) return text;
    const idx = text.toLowerCase().indexOf(query.toLowerCase());
    if (idx === -1) return text;
    return text.slice(0, idx) + `<span style="background:var(--honey-soft);">${text.slice(idx, idx + query.length)}</span>` + text.slice(idx + query.length);
  }

  function renderResults(query: string) {
    const q = query.toLowerCase().trim();

    if (!q) {
      itemsList.innerHTML = `<div style="padding:14px;text-align:center;color:var(--t2);font-size:13px;">Start typing to search...</div>`;
      recipesList.innerHTML = `<div style="padding:14px;text-align:center;color:var(--t2);font-size:13px;">Start typing to search...</div>`;
      recentSection.style.display = 'block';
      return;
    }

    recentSection.style.display = 'none';

    const filteredItems = allItems.filter(i =>
      i.name.toLowerCase().includes(q) ||
      (i.container || '').toLowerCase().includes(q)
    );

    const filteredRecipes = allRecipes.filter((r: any) =>
      r.name.toLowerCase().includes(q)
    );

    // Render items
    if (filteredItems.length === 0) {
      itemsList.innerHTML = `<div style="padding:14px;text-align:center;color:var(--t2);font-size:13px;">No items found</div>`;
    } else {
      itemsList.innerHTML = filteredItems.slice(0, 8).map(item => `
        <a href="/app/items/${item.id}" class="info-row" style="text-decoration:none;">
          <div style="display:flex;align-items:center;gap:12px;flex:1;">
            <span style="font-size:24px;">${item.emoji || '🥫'}</span>
            <div>
              <div style="font-weight:600;font-size:14px;color:var(--t1);">${highlight(item.name, query)}</div>
              <div style="font-size:12px;color:var(--t2);">${item.container} · ${getDaysLabel(item.daysUntilExpiry)}</div>
            </div>
          </div>
          <span class="detail-badge" style="background:${getStatusBg(item.status)};color:${getStatusColor(item.status)};font-size:9px;">${getDaysLabel(item.daysUntilExpiry)}</span>
        </a>`).join('');
    }

    // Render recipes
    if (filteredRecipes.length === 0) {
      recipesList.innerHTML = `<div style="padding:14px;text-align:center;color:var(--t2);font-size:13px;">No recipes found</div>`;
    } else {
      recipesList.innerHTML = filteredRecipes.slice(0, 5).map((r: any) => `
        <a href="/app/recipes/${r.id}" class="info-row" style="text-decoration:none;">
          <div style="display:flex;align-items:center;gap:12px;flex:1;">
            <span style="font-size:24px;">${r.emoji || '🍽'}</span>
            <div>
              <div style="font-weight:600;font-size:14px;color:var(--t1);">${highlight(r.name, query)}</div>
              <div style="font-size:12px;color:var(--t2);">${r.cookTime ? r.cookTime + ' min · ' : ''}${r.servings ? r.servings + ' servings' : ''}</div>
            </div>
          </div>
        </a>`).join('');
    }
  }

  async function loadData() {
    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            items(limit: 200) { id name emoji status daysUntilExpiry container { name } }
            recipes(limit: 50) { id name emoji cookTime servings }
          }`
        })
      });
      const { data } = await res.json();
      if (data?.items) {
        allItems = data.items.map((i: any) => ({ ...i, container: i.container?.name || 'Fridge' }));
      }
      if (data?.recipes) {
        allRecipes = data.recipes;
      }
      if (searchInput.value) renderResults(searchInput.value);
    } catch (_) {}
  }

  searchInput?.addEventListener('input', (e) => {
    renderResults((e.target as HTMLInputElement).value);
  });

  document.getElementById('clearBtn')?.addEventListener('click', () => {
    searchInput.value = '';
    renderResults('');
    searchInput.focus();
  });

  // Auto-focus search input
  setTimeout(() => searchInput?.focus(), 100);

  loadData();
</script>
