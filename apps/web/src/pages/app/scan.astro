---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Scan — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Scan Item" subtitle="Barcode or receipt" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Camera Placeholder -->
        <div
          style="width: 100%; aspect-ratio: 1; background: linear-gradient(135deg, var(--brand-soft) 0%, var(--brand-tint) 100%); border-radius: var(--r-lg); display: flex; align-items: center; justify-content: center; margin-bottom: 24px; border: 2px dashed var(--b1);"
        >
          <div style="text-align: center;">
            <div style="font-size: 64px; margin-bottom: 12px;">📷</div>
            <p style="color: var(--t2); margin: 0; font-size: 14px;">Camera feed would appear here</p>
          </div>
        </div>

        <!-- Info -->
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; text-align: center;">
            <p style="color: var(--t2); margin: 0; font-size: 14px;">
              Point your camera at a barcode to scan and add an item to your inventory
            </p>
          </div>
        </Card>

        <!-- Example Results -->
        <p class="eyebrow" style="margin-bottom: 12px;">📦 EXAMPLE RESULT</p>

        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <div style="display: flex; gap: 12px; margin-bottom: 16px;">
              <div style="font-size: 40px;">🥕</div>
              <div>
                <h3 style="font-size: 17px; font-weight: 700; margin: 0 0 4px 0;">Organic Carrots</h3>
                <p style="font-size: 13px; color: var(--t2); margin: 0;">12345678901234</p>
                <p style="font-size: 12px; color: var(--t2); margin: 4px 0 0 0;">Expires: 14 days</p>
              </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
              <Button variant="secondary" block onclick="history.back()">
                Cancel
              </Button>
              <Button variant="primary" block onclick="location.href='/app/dashboard'">
                Add Item
              </Button>
            </div>
          </div>
        </Card>

        <div style="margin-top: 32px; padding: 20px; background: linear-gradient(135deg, var(--brand-soft) 0%, var(--brand-tint) 100%); border-radius: var(--r-lg); text-align: center;">
          <p style="color: var(--t2); margin: 0; font-size: 14px;">
            🚀 Full barcode scanning coming soon!
          </p>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
