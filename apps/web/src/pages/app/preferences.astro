---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Preferences — WhatsFresh">
  <main>
    <div class="scroll" id="prefsScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Preferences</div>
        <div style="width:44px"></div>
      </div>

      <!-- NOTIFICATIONS -->
      <div class="eyebrow" style="padding:8px 22px 8px;letter-spacing:0.5px;">🔔 NOTIFICATIONS</div>
      <div class="settings-section">
        <div class="settings-row" style="border-bottom:1px solid var(--b1);">
          <div style="flex:1;">
            <div class="settings-title">Expiry Alerts</div>
            <div class="settings-sub">Get notified when items expire</div>
          </div>
          <button class="toggle on" onclick="toggleNotif(this)"></button>
        </div>
        <div class="settings-row" style="border-bottom:1px solid var(--b1);">
          <div style="flex:1;">
            <div class="settings-title">Streak Updates</div>
            <div class="settings-sub">Daily streak achievements</div>
          </div>
          <button class="toggle on" onclick="toggleNotif(this)"></button>
        </div>
        <div class="settings-row">
          <div style="flex:1;">
            <div class="settings-title">Achievements</div>
            <div class="settings-sub">When you unlock badges</div>
          </div>
          <button class="toggle on" onclick="toggleNotif(this)"></button>
        </div>
      </div>

      <!-- DIETARY RESTRICTIONS -->
      <div class="eyebrow" style="padding:8px 22px 8px;margin-top:16px;letter-spacing:0.5px;">🥗 DIETARY RESTRICTIONS</div>
      <div class="settings-section">
        <div class="settings-row" style="border-bottom:1px solid var(--b1);">
          <div style="flex:1;">
            <div class="settings-title">Vegetarian</div>
            <div class="settings-sub">Exclude meat from suggestions</div>
          </div>
          <button class="toggle" onclick="toggleDiet(this)"></button>
        </div>
        <div class="settings-row" style="border-bottom:1px solid var(--b1);">
          <div style="flex:1;">
            <div class="settings-title">Vegan</div>
            <div class="settings-sub">Exclude animal products</div>
          </div>
          <button class="toggle" onclick="toggleDiet(this)"></button>
        </div>
        <div class="settings-row" style="border-bottom:1px solid var(--b1);">
          <div style="flex:1;">
            <div class="settings-title">Gluten-free</div>
            <div class="settings-sub">Avoid gluten products</div>
          </div>
          <button class="toggle" onclick="toggleDiet(this)"></button>
        </div>
        <div class="settings-row">
          <div style="flex:1;">
            <div class="settings-title">Dairy-free</div>
            <div class="settings-sub">No dairy products</div>
          </div>
          <button class="toggle" onclick="toggleDiet(this)"></button>
        </div>
      </div>

      <!-- THEME -->
      <div class="eyebrow" style="padding:8px 22px 8px;margin-top:16px;letter-spacing:0.5px;">🎨 THEME</div>
      <div class="settings-section">
        <div class="settings-row" style="border-bottom:1px solid var(--b1);" onclick="setTheme('light',this)">
          <div style="flex:1;">
            <div class="settings-title">Light</div>
            <div class="settings-sub">Default theme</div>
          </div>
          <div class="theme-radio" style="width:20px;height:20px;border:2px solid var(--brand);border-radius:50%;background:white;"></div>
        </div>
        <div class="settings-row" style="border-bottom:1px solid var(--b1);" onclick="setTheme('dark',this)">
          <div style="flex:1;">
            <div class="settings-title">Dark</div>
            <div class="settings-sub">Easy on the eyes</div>
          </div>
          <div class="theme-radio" style="width:20px;height:20px;border:2px solid var(--b1);border-radius:50%;background:transparent;"></div>
        </div>
        <div class="settings-row" onclick="setTheme('system',this)">
          <div style="flex:1;">
            <div class="settings-title">System</div>
            <div class="settings-sub">Match device setting</div>
          </div>
          <div class="theme-radio" style="width:20px;height:20px;border:2px solid var(--b1);border-radius:50%;background:transparent;"></div>
        </div>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function toggleNotif(el: HTMLElement) {
    (el as HTMLButtonElement).classList.toggle('on');
  }

  function toggleDiet(el: HTMLElement) {
    (el as HTMLButtonElement).classList.toggle('on');
  }

  function setTheme(theme: string, el: HTMLElement) {
    document.querySelectorAll('.theme-radio').forEach(r => {
      r.style.background = 'transparent';
      r.style.borderColor = 'var(--b1)';
    });
    const radio = el.querySelector('.theme-radio') as HTMLElement;
    if (radio) {
      radio.style.background = theme === 'light' ? 'white' : 'transparent';
      radio.style.borderColor = 'var(--brand)';
    }
  }

  (window as any).toggleNotif = toggleNotif;
  (window as any).toggleDiet = toggleDiet;
  (window as any).setTheme = setTheme;
</script>
