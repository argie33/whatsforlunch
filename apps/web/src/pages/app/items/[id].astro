---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';

export async function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
  ];
}

const mockItems: Record<string, any> = {
  '1': { name: 'Broccoli', emoji: '🥦', status: 'fresh', days: 5, container: 'Fridge', purchased: '2026-05-03', expires: '2026-05-13', quantity: 1, notes: 'Store in crisper drawer' },
  '2': { name: 'Milk', emoji: '🥛', status: 'soon', days: 2, container: 'Fridge', purchased: '2026-04-28', expires: '2026-05-10', quantity: 2, notes: '1% Low-fat' },
  '3': { name: 'Bread', emoji: '🍞', status: 'urgent', days: 0, container: 'Counter', purchased: '2026-05-06', expires: '2026-05-08', quantity: 1, notes: 'Whole wheat' },
};

const { id } = Astro.params;
const item = mockItems[id!] || mockItems['1'];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title={`${item.name} — WhatsFresh`}>
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Item Details" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Header with emoji and status -->
      <div style="padding: 32px 22px 24px; text-align: center; background: linear-gradient(135deg, var(--brand-soft) 0%, var(--brand-tint) 100%);">
        <div style="font-size: 80px; margin-bottom: 16px;">{item.emoji}</div>
        <h1 style="font-size: 28px; font-weight: 800; margin: 0 0 8px 0; color: var(--t1);">{item.name}</h1>
        <div
          style={`display: inline-block; padding: 8px 16px; border-radius: var(--r-full); font-weight: 700; font-size: 13px; text-transform: uppercase; background: ${
            item.status === 'fresh'
              ? 'var(--fresh-bg)'
              : item.status === 'soon'
                ? 'var(--soon-bg)'
                : item.status === 'urgent'
                  ? 'var(--urgent-bg)'
                  : 'var(--expired-bg)'
          }; color: ${
            item.status === 'fresh'
              ? 'var(--fresh)'
              : item.status === 'soon'
                ? 'var(--soon)'
                : item.status === 'urgent'
                  ? 'var(--urgent)'
                  : 'var(--expired)'
          };`}
        >
          {item.status === 'fresh' && '✓ Fresh'}
          {item.status === 'soon' && '⏰ Using Soon'}
          {item.status === 'urgent' && '⚠️ Use Today'}
          {item.status === 'expired' && '✕ Expired'}
        </div>
      </div>

      <!-- Details -->
      <div style="padding: 16px 22px;">
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: grid; gap: 16px;">
            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Location</p>
              <p style="font-size: 16px; font-weight: 600; margin: 0; color: var(--t1);">📦 {item.container}</p>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
              <div>
                <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Purchased</p>
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">{item.purchased}</p>
              </div>
              <div>
                <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Expires</p>
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">{item.expires}</p>
              </div>
            </div>

            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Quantity</p>
              <p style="font-size: 16px; font-weight: 600; margin: 0; color: var(--t1);">{item.quantity}</p>
            </div>

            {item.notes && (
              <div>
                <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Notes</p>
                <p style="font-size: 14px; margin: 0; color: var(--t1); line-height: 1.5;">{item.notes}</p>
              </div>
            )}
          </div>
        </Card>

        <!-- Timeline -->
        <p class="eyebrow" style="margin-bottom: 12px;">Activity</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <div style="display: flex; gap: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--b1);">
              <div style="font-size: 20px;">➕</div>
              <div>
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">Added to inventory</p>
                <p style="font-size: 12px; color: var(--t2); margin: 4px 0 0 0;">May 3, 2026 at 2:30 PM</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Action Buttons -->
        <div style="display: grid; gap: 8px;">
          <Button variant="primary" block onclick="alert('Mark as used')">
            ✓ Mark as Used
          </Button>
          <Button variant="secondary" block onclick="alert('Edit item')">
            ✏️ Edit Item
          </Button>
          <Button variant="ghost" block onclick="alert('Delete item')">
            🗑️ Delete
          </Button>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
