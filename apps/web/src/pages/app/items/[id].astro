---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';

const { id } = Astro.params;

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Item Details — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Item Details" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div id="item-detail-container" style="padding: 0 22px;">
        <div style="padding: 32px 0 24px; text-align: center;">
          <p style="color: var(--t2);">Loading item...</p>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  .status-badge {
    display: inline-block;
    padding: 8px 16px;
    border-radius: var(--r-full);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
  }

  .status-badge.fresh {
    background: var(--fresh-bg);
    color: var(--fresh);
  }

  .status-badge.soon {
    background: var(--soon-bg);
    color: var(--soon);
  }

  .status-badge.urgent {
    background: var(--urgent-bg);
    color: var(--urgent);
  }

  .status-badge.expired {
    background: var(--expired-bg);
    color: var(--expired);
  }

  .detail-row {
    display: flex;
    gap: 12px;
    padding-bottom: 12px;
  }

  .detail-row:not(:last-child) {
    border-bottom: 1px solid var(--b1);
  }

  .detail-label {
    font-size: 11px;
    font-weight: 800;
    color: var(--t2);
    text-transform: uppercase;
    margin: 0 0 4px 0;
    letter-spacing: 1.5px;
  }

  .detail-value {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    color: var(--t1);
  }
</style>

<script define:vars={{ itemId: id }}>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  const emojiMap = {
    vegetable: '🥦',
    fruit: '🍎',
    dairy: '🥛',
    bread: '🍞',
    meat: '🥩',
    frozen: '🧊',
    pantry: '🥫',
    other: '📦',
  };

  async function loadItem() {
    const container = document.getElementById('item-detail-container');

    try {
      // Get household ID first
      const userQuery = `query { getProfile { id } listHouseholds { id } }`;
      const userData = await gql(userQuery);

      let householdId = userData.listHouseholds?.[0]?.id;

      if (!householdId) {
        container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">No household found</p></div>';
        return;
      }

      // Fetch item by ID
      const itemQuery = `query GetItem($id: ID!, $householdId: ID!) {
        getItem(id: $id, householdId: $householdId) {
          id
          foodName
          category
          storageLocation
          status
          expiryAt
          notes
          quantityText
        }
      }`;

      const itemData = await gql(itemQuery, { id: itemId, householdId });
      const item = itemData.getItem;

      if (!item) {
        container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">Item not found</p></div>';
        return;
      }

      const emoji = emojiMap[item.category?.toLowerCase()] || emojiMap.other;
      const purchased = new Date(item.storedAt).toLocaleDateString();
      const expires = new Date(item.expiryAt).toLocaleDateString();

      container.innerHTML = `
        <div style="padding: 32px 0 24px; text-align: center; background: linear-gradient(135deg, var(--brand-soft) 0%, var(--brand-tint) 100%);">
          <div style="font-size: 80px; margin-bottom: 16px;">${emoji}</div>
          <h1 style="font-size: 28px; font-weight: 800; margin: 0 0 8px 0; color: var(--t1);">${item.foodName}</h1>
          <div class="status-badge ${item.status}">
            ${item.status === 'fresh' ? '✓ Fresh' : item.status === 'soon' ? '⏰ Using Soon' : item.status === 'urgent' ? '⚠️ Use Today' : '✕ Expired'}
          </div>
        </div>

        <div style="padding: 16px 0;">
          <div style="background: var(--raised); border: 1px solid var(--b1); border-radius: var(--r-lg); padding: 16px; margin-bottom: 16px;">
            <div style="display: grid; gap: 16px;">
              <div>
                <p class="detail-label">Category</p>
                <p class="detail-value">${item.category || 'Unknown'}</p>
              </div>

              <div>
                <p class="detail-label">Location</p>
                <p class="detail-value">📦 ${item.storageLocation || 'Unknown'}</p>
              </div>

              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div>
                  <p class="detail-label">Purchased</p>
                  <p class="detail-value">${purchased}</p>
                </div>
                <div>
                  <p class="detail-label">Expires</p>
                  <p class="detail-value">${expires}</p>
                </div>
              </div>

              <div>
                <p class="detail-label">Quantity</p>
                <p class="detail-value">${item.quantityText || item.quantityValue || '1'}</p>
              </div>

              ${item.notes ? `
                <div>
                  <p class="detail-label">Notes</p>
                  <p style="font-size: 14px; margin: 0; color: var(--t1); line-height: 1.5;">${item.notes}</p>
                </div>
              ` : ''}
            </div>
          </div>

          <div style="display: grid; gap: 8px; margin-bottom: 16px;">
            <button id="mark-used-btn" style="width: 100%; padding: 16px; background: var(--brand); color: white; border: none; border-radius: var(--r-md); font-weight: 700; cursor: pointer;">
              ✓ Mark as Used
            </button>
            <button id="delete-btn" style="width: 100%; padding: 16px; background: transparent; color: var(--t1); border: 1.5px solid var(--b1); border-radius: var(--r-md); font-weight: 700; cursor: pointer;">
              🗑️ Delete
            </button>
          </div>
        </div>
      `;

      // Wire up buttons
      const markUsedBtn = document.getElementById('mark-used-btn');
      const deleteBtn = document.getElementById('delete-btn');

      if (markUsedBtn) {
        markUsedBtn.addEventListener('click', async () => {
          markUsedBtn.disabled = true;
          markUsedBtn.textContent = 'Marking...';

          try {
            const mutation = `mutation MarkItemEaten($input: MarkItemEatenInput!) {
              markItemEaten(input: $input) { id }
            }`;
            await gql(mutation, { input: { id: itemId, householdId } });
            alert('✓ Item marked as used');
            window.location.href = '/app/items';
          } catch (error) {
            alert('Failed to mark item as used');
            markUsedBtn.disabled = false;
            markUsedBtn.textContent = '✓ Mark as Used';
          }
        });
      }

      if (deleteBtn) {
        deleteBtn.addEventListener('click', async () => {
          if (!confirm('Are you sure you want to delete this item?')) return;

          deleteBtn.disabled = true;
          deleteBtn.textContent = 'Deleting...';

          try {
            const mutation = `mutation DeleteItem($id: ID!, $householdId: ID!) {
              deleteItem(id: $id, householdId: $householdId)
            }`;
            await gql(mutation, { id: itemId, householdId });
            alert('✓ Item deleted');
            window.location.href = '/app/items';
          } catch (error) {
            alert('Failed to delete item');
            deleteBtn.disabled = false;
            deleteBtn.textContent = '🗑️ Delete';
          }
        });
      }
    } catch (error) {
      console.error('Failed to load item:', error);
      container.innerHTML = '<div style="padding: 32px; text-align: center;"><p style="color: var(--t2);">Failed to load item</p></div>';
    }
  }

  loadItem();
</script>
