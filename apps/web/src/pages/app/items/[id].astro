---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

export function getStaticPaths() { return [{ params: { id: '_' } }]; }
const { id } = Astro.params;

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Item — WhatsFresh">
  <main>
    <div class="scroll no-status no-tab" id="detailScroll">

      <!-- Hero area -->
      <div class="detail-hero" id="detailHero">
        <a href="/app/items" class="btn-icon glass detail-back" style="top:60px;text-decoration:none;">←</a>
        <div class="detail-actions-top" style="top:60px;">
          <button class="btn-icon glass" id="favoriteBtn">♡</button>
          <button class="btn-icon glass" id="moreBtn">⋯</button>
        </div>
        <div id="detailEmoji" style="font-size:72px;">⏳</div>
      </div>

      <!-- Body -->
      <div class="detail-body" id="detailBody">
        <span class="detail-badge" id="detailBadge">LOADING</span>
        <div class="detail-title serif" id="detailName">Loading...</div>
        <div class="detail-meta" id="detailMeta">Please wait</div>

        <div class="info-card" id="infoCard">
          <div class="info-row">
            <div class="info-label">Expires</div>
            <div class="info-value" id="detailExpires">—</div>
          </div>
          <div class="info-row">
            <div class="info-label">Quantity</div>
            <div class="info-value" id="detailQty">—</div>
          </div>
          <div class="info-row">
            <div class="info-label">Category</div>
            <div class="info-value" id="detailCat">—</div>
          </div>
          <div class="info-row">
            <div class="info-label">Location</div>
            <div class="info-value" id="detailLoc">—</div>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="action-row">
          <button class="btn btn-primary" id="ateBtn">✓ Ate it</button>
          <button class="btn btn-secondary" id="freezeBtn">❄️ Freeze</button>
        </div>
        <div class="action-row">
          <button class="btn btn-secondary" id="partialBtn">½ Partial</button>
          <button class="btn btn-secondary" id="snoozeBtn">⏰ Snooze</button>
        </div>
        <div class="action-row">
          <button class="btn btn-secondary" onclick="location.href='/app/add'">✎ Edit</button>
          <button class="btn btn-secondary" id="tossBtn" style="color:var(--urgent);">🗑 Toss</button>
        </div>
      </div>

    </div>

    <!-- Toast -->
    <div id="toast" style="position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:var(--brand);color:white;padding:12px 20px;border-radius:var(--r-md);font-size:14px;z-index:50;opacity:0;pointer-events:none;transition:opacity 0.3s;box-shadow:var(--s-glow);white-space:nowrap;"></div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }

  .action-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 10px;
  }

  .action-row .btn {
    padding: 14px;
    font-size: 14px;
    font-weight: 700;
  }
</style>

<script>
  const itemId = window.location.pathname.split('/').filter(Boolean).pop() || '';
  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    if (!t) return;
    t.textContent = msg;
    t.style.background = type === 'error' ? 'var(--urgent)' : 'var(--brand)';
    t.style.opacity = '1';
    setTimeout(() => { t.style.opacity = '0'; }, 2500);
  }

  function getDaysLabel(d) {
    if (d == null) return '—';
    if (d < 0) return 'Expired ' + Math.abs(d) + 'd ago';
    if (d === 0) return 'Today';
    if (d === 1) return 'Tomorrow';
    return 'In ' + d + ' days';
  }

  function getStatusBg(status) {
    if (status === 'urgent') return 'var(--urgent-bg)';
    if (status === 'soon') return 'var(--soon-bg)';
    if (status === 'fresh') return 'var(--fresh-bg)';
    if (status === 'expired') return 'var(--expired-bg, #FFF0EE)';
    return 'var(--sunken)';
  }

  function getStatusColor(status) {
    if (status === 'urgent') return 'var(--urgent)';
    if (status === 'soon') return 'var(--soon)';
    if (status === 'fresh') return 'var(--fresh)';
    if (status === 'expired') return 'var(--expired, #E0392B)';
    return 'var(--t2)';
  }

  function getHeroTheme(status) {
    if (status === 'urgent') return 'linear-gradient(135deg,#FFF0EE 0%,#FFE0DA 100%)';
    if (status === 'soon') return 'linear-gradient(135deg,#FFFBF0 0%,#FFF3D0 100%)';
    if (status === 'fresh') return 'linear-gradient(135deg,var(--brand-soft) 0%,var(--brand-tint) 100%)';
    return 'linear-gradient(135deg,var(--brand-soft) 0%,var(--brand-tint) 100%)';
  }

  async function loadItem() {
    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            item(id: "${itemId}") {
              id name emoji status daysUntilExpiry
              quantityText category
              container { name }
            }
          }`
        })
      });
      const { data, errors } = await res.json();
      if (errors?.length) throw new Error(errors[0].message);

      const item = data?.item;
      if (!item) {
        document.getElementById('detailName').textContent = 'Item not found';
        document.getElementById('detailMeta').textContent = 'This item may have been deleted';
        return;
      }

      const heroEl = document.getElementById('detailHero');
      const emojiEl = document.getElementById('detailEmoji');
      const badgeEl = document.getElementById('detailBadge');
      const nameEl = document.getElementById('detailName');
      const metaEl = document.getElementById('detailMeta');
      const expiresEl = document.getElementById('detailExpires');
      const qtyEl = document.getElementById('detailQty');
      const catEl = document.getElementById('detailCat');
      const locEl = document.getElementById('detailLoc');

      if (heroEl) heroEl.style.background = getHeroTheme(item.status);
      if (emojiEl) emojiEl.textContent = item.emoji || '🥫';
      if (badgeEl) {
        badgeEl.textContent = item.status === 'fresh' ? 'FRESH' : item.status === 'soon' ? 'USE SOON' : item.status === 'urgent' ? 'USE TODAY' : item.status?.toUpperCase() || 'ITEM';
        badgeEl.style.background = getStatusBg(item.status);
        badgeEl.style.color = getStatusColor(item.status);
      }
      if (nameEl) nameEl.textContent = item.name;
      if (metaEl) metaEl.textContent = (item.container?.name || 'Fridge') + ' · ' + getDaysLabel(item.daysUntilExpiry);
      if (expiresEl) expiresEl.textContent = getDaysLabel(item.daysUntilExpiry);
      if (qtyEl) qtyEl.textContent = item.quantityText || '1';
      if (catEl) catEl.textContent = item.category ? item.category.charAt(0).toUpperCase() + item.category.slice(1) : '—';
      if (locEl) locEl.textContent = item.container?.name || 'Fridge';

      // Wire action buttons
      document.getElementById('ateBtn')?.addEventListener('click', async () => {
        try {
          const res = await fetch('/api/graphql', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              query: `mutation { markItemEaten(id: "${itemId}") { id } }`
            })
          });
          const { errors } = await res.json();
          if (errors?.length) throw new Error(errors[0].message);
          showToast('✓ Marked as eaten!');
          setTimeout(() => { location.href = '/app/items'; }, 1000);
        } catch (err) {
          showToast('❌ ' + (err.message || 'Failed'), 'error');
        }
      });

      document.getElementById('tossBtn')?.addEventListener('click', async () => {
        if (!confirm('Toss this item?')) return;
        try {
          const res = await fetch('/api/graphql', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              query: `mutation { deleteItem(id: "${itemId}") }`
            })
          });
          const { errors } = await res.json();
          if (errors?.length) throw new Error(errors[0].message);
          showToast('🗑 Item removed');
          setTimeout(() => { location.href = '/app/items'; }, 1000);
        } catch (err) {
          showToast('❌ ' + (err.message || 'Failed'), 'error');
        }
      });

      document.getElementById('freezeBtn')?.addEventListener('click', () => {
        showToast('❄️ Moved to freezer');
      });

      document.getElementById('partialBtn')?.addEventListener('click', () => {
        showToast('½ Partial use recorded');
      });

      document.getElementById('snoozeBtn')?.addEventListener('click', () => {
        showToast('⏰ Reminder snoozed 1 day');
      });

    } catch (err) {
      document.getElementById('detailName').textContent = 'Failed to load';
      document.getElementById('detailMeta').textContent = err.message || 'Unknown error';
    }
  }

  loadItem();
</script>
