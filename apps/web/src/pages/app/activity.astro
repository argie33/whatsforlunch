---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';

const activityFeed = [
  { id: '1', icon: '➕', action: 'Added Broccoli', user: 'You', time: '2 hours ago' },
  { id: '2', icon: '✓', action: 'Used Milk', user: 'You', time: '1 day ago' },
  { id: '3', icon: '🔥', action: 'Achievement: 7-Day Streak', user: 'You', time: '2 days ago' },
  { id: '4', icon: '➕', action: 'Added Bread', user: 'Sarah', time: '3 days ago' },
  { id: '5', icon: '✓', action: 'Used Cheese', user: 'Sarah', time: '4 days ago' },
];

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Activity — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Activity" subtitle="Your household timeline" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        {activityFeed.map((activity) => (
          <Card key={activity.id} style="margin-bottom: 10px;">
            <div style="padding: 14px; display: flex; gap: 12px;">
              <div style="font-size: 20px;">{activity.icon}</div>
              <div style="flex: 1;">
                <p style="font-size: 14px; font-weight: 600; margin: 0 0 2px 0; color: var(--t1);">
                  {activity.action}
                </p>
                <p style="font-size: 12px; color: var(--t2); margin: 0;">
                  {activity.user} • {activity.time}
                </p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
