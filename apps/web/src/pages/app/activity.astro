---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Activity — WhatsFresh">
  <main>
    <div class="scroll" id="activityScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Activity</div>
        <button class="btn-icon">⚏</button>
      </div>

      <!-- Filter chips -->
      <div class="chips">
        <button class="chip active" onclick="filterActivity('all',this)">All</button>
        <button class="chip" onclick="filterActivity('items',this)">Items</button>
        <button class="chip" onclick="filterActivity('recipes',this)">Recipes</button>
        <button class="chip" onclick="filterActivity('members',this)">Members</button>
      </div>

      <div style="padding:0 22px;" id="activityList">
        <div class="caption" style="margin-bottom:8px;padding-left:4px;">ACTIVITY</div>
        <div class="info-card" style="margin-bottom:14px;">
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <div class="avatar" style="background:linear-gradient(135deg,var(--coral) 0%,var(--honey) 100%);">S</div>
              <div style="flex:1;">
                <div style="font-size:14px;line-height:1.4;"><strong>Sarah</strong> ate 🥬 Spinach</div>
                <div style="font-size:12px;color:var(--t3);margin-top:2px;">Just now</div>
              </div>
            </div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <div class="avatar" style="background:linear-gradient(135deg,var(--berry) 0%,var(--plum) 100%);">M</div>
              <div style="flex:1;">
                <div style="font-size:14px;line-height:1.4;"><strong>Mike</strong> added 🥑 Avocados (3 items)</div>
                <div style="font-size:12px;color:var(--t3);margin-top:2px;">5 min ago</div>
              </div>
            </div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <div class="avatar">U</div>
              <div style="flex:1;">
                <div style="font-size:14px;line-height:1.4;"><strong>You</strong> tried recipe 🍝 Garlic Spinach Pasta</div>
                <div style="font-size:12px;color:var(--t3);margin-top:2px;">12 min ago</div>
              </div>
            </div>
          </div>
        </div>

        <div class="caption" style="margin-bottom:8px;padding-left:4px;">EARLIER TODAY</div>
        <div class="info-card" style="margin-bottom:14px;">
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <div class="avatar" style="background:linear-gradient(135deg,var(--coral) 0%,var(--honey) 100%);">S</div>
              <div style="flex:1;">
                <div style="font-size:14px;line-height:1.4;"><strong>Sarah</strong> tossed 🍌 Bananas</div>
                <div style="font-size:12px;color:var(--t3);margin-top:2px;">2 hours ago</div>
              </div>
            </div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <div class="avatar">U</div>
              <div style="flex:1;">
                <div style="font-size:14px;line-height:1.4;"><strong>You</strong> added 8 items via barcode 📷</div>
                <div style="font-size:12px;color:var(--t3);margin-top:2px;">3 hours ago</div>
              </div>
            </div>
          </div>
        </div>

        <div class="caption" style="margin-bottom:8px;padding-left:4px;">YESTERDAY</div>
        <div class="info-card" id="dynamicActivity">
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#FFD86F 0%,#FF8E53 100%);display:flex;align-items:center;justify-content:center;font-size:18px;">🏆</div>
              <div style="flex:1;">
                <div style="font-size:14px;line-height:1.4;"><strong>Achievement unlocked</strong> — Zero Waste Week!</div>
                <div style="font-size:12px;color:var(--t3);margin-top:2px;">Yesterday</div>
              </div>
            </div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <div class="avatar">U</div>
              <div style="flex:1;">
                <div style="font-size:14px;line-height:1.4;"><strong>You</strong> saved $23 this week 💰</div>
                <div style="font-size:12px;color:var(--t3);margin-top:2px;">Yesterday, 9:00 AM</div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  function filterActivity(type: string, btn: HTMLElement) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
  }

  (window as any).filterActivity = filterActivity;

  async function loadActivity() {
    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            activityFeed(limit: 20) {
              id action emoji userName timestamp
            }
          }`
        })
      });
      const { data } = await res.json();
      const feed = data?.activityFeed;
      if (!feed?.length) return;

      const container = document.getElementById('dynamicActivity');
      if (!container) return;

      container.innerHTML = feed.map((a: any) => `
        <div class="info-row">
          <div style="display:flex;align-items:center;gap:12px;flex:1;">
            <div class="avatar">${(a.userName || 'U')[0].toUpperCase()}</div>
            <div style="flex:1;">
              <div style="font-size:14px;line-height:1.4;">${a.emoji || ''} ${a.action}</div>
              <div style="font-size:12px;color:var(--t3);margin-top:2px;">${a.timestamp || 'Recently'}</div>
            </div>
          </div>
        </div>`).join('');
    } catch (_) {}
  }

  loadActivity();
</script>
