---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';

const steps = [
  {
    icon: '📱',
    title: 'Track Your Food',
    description: 'Add items from your fridge, freezer, and pantry to keep track of what you have',
  },
  {
    icon: '⏰',
    title: 'Never Waste Again',
    description: 'Get reminded before food expires so you can use it in time',
  },
  {
    icon: '👨‍🍳',
    title: 'Find Recipes',
    description: 'Discover recipes based on what you already have at home',
  },
  {
    icon: '💰',
    title: 'Save Money',
    description: 'Track how much you save by reducing food waste',
  },
];
---

<BaseLayout title="Welcome — WhatsFresh">
  <main style="display: flex; flex-direction: column; min-height: 100vh; background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);">
    <!-- Content -->
    <div style="flex: 1; display: flex; flex-direction: column; justify-content: space-between; padding: 40px 22px; text-align: center; color: white;">
      <!-- Header -->
      <div>
        <div style="font-size: 56px; margin-bottom: 16px;">🥬</div>
        <h1 style="font-size: 32px; font-weight: 800; margin: 0 0 8px 0;">WhatsFresh</h1>
        <p style="font-size: 16px; opacity: 0.9; margin: 0;">Never waste food again</p>
      </div>

      <!-- Steps -->
      <div style="display: flex; flex-direction: column; gap: 16px; margin: 32px 0;">
        {steps.map((step, index) => (
          <div style="text-align: left;">
            <div style="display: flex; align-items: flex-start; gap: 12px;">
              <div
                style="
                  width: 40px;
                  height: 40px;
                  border-radius: 50%;
                  background: rgba(255, 255, 255, 0.2);
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  font-size: 20px;
                  flex-shrink: 0;
                "
              >
                {step.icon}
              </div>
              <div style="flex: 1;">
                <h3 style="font-size: 16px; font-weight: 600; margin: 0 0 4px 0;">{step.title}</h3>
                <p style="font-size: 13px; opacity: 0.85; margin: 0;">{step.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty space -->
      <div />

      <!-- Buttons -->
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <Button
          variant="primary"
          block
          onclick="location.href='/auth/signup'"
          style="background-color: white; color: var(--brand); font-weight: 600;"
        >
          Create Account
        </Button>
        <Button
          variant="ghost"
          block
          onclick="location.href='/auth/login'"
          style="color: white; border-color: rgba(255, 255, 255, 0.3);"
        >
          Sign In
        </Button>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
