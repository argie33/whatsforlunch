---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics', active: true },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Analytics — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Analytics" subtitle="Your food waste stats" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Stats Grid -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px;">
          <Card>
            <div style="padding: 16px; text-align: center;">
              <div style="font-size: 32px; font-weight: 800; color: var(--fresh); margin-bottom: 4px;">
                0
              </div>
              <p style="font-size: 12px; color: var(--t2); margin: 0;">Items Wasted</p>
            </div>
          </Card>
          <Card>
            <div style="padding: 16px; text-align: center;">
              <div style="font-size: 32px; font-weight: 800; color: var(--brand); margin-bottom: 4px;">
                $0
              </div>
              <p style="font-size: 12px; color: var(--t2); margin: 0;">Saved</p>
            </div>
          </Card>
        </div>

        <!-- Category Breakdown -->
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <h3 style="font-size: 17px; font-weight: 700; margin: 0 0 16px 0;">By Category</h3>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 14px;">
                  <span>🥦 Vegetables</span>
                  <span style="color: var(--t2);">35%</span>
                </div>
                <div style="height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
                  <div
                    style="width: 35%; height: 100%; background: linear-gradient(90deg, #1F9956 0%, #34B86C 100%); border-radius: 3px;"
                  ></div>
                </div>
              </div>
              <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 14px;">
                  <span>🍎 Fruits</span>
                  <span style="color: var(--t2);">25%</span>
                </div>
                <div style="height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
                  <div
                    style="width: 25%; height: 100%; background: linear-gradient(90deg, var(--coral) 0%, var(--honey) 100%); border-radius: 3px;"
                  ></div>
                </div>
              </div>
              <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 14px;">
                  <span>🥛 Dairy</span>
                  <span style="color: var(--t2);">40%</span>
                </div>
                <div style="height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
                  <div
                    style="width: 40%; height: 100%; background: linear-gradient(90deg, var(--sky) 0%, var(--brand-light) 100%); border-radius: 3px;"
                  ></div>
                </div>
              </div>
            </div>
          </div>
        </Card>

        <!-- Coming Soon -->
        <Card>
          <div style="padding: 20px; text-align: center;">
            <p style="color: var(--t2); margin: 0; font-size: 14px;">
              📊 Detailed analytics and trends coming soon!
            </p>
          </div>
        </Card>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="analytics" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
