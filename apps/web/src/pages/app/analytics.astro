---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Insights — WhatsFresh">
  <main>
    <div class="scroll" id="analyticsScroll">

      <!-- Top Bar -->
      <div class="topbar" id="topbarAnalytics">
        <div class="topbar-title">
          <div class="caption" style="color:var(--t2)">Your impact</div>
          <div class="h2 serif">Insights</div>
        </div>
      </div>

      <!-- Time filter chips -->
      <div class="chips">
        <button class="chip" onclick="setTime('week',this)">Week</button>
        <button class="chip active" onclick="setTime('month',this)">Month</button>
        <button class="chip" onclick="setTime('year',this)">Year</button>
        <button class="chip" onclick="setTime('all',this)">All time</button>
      </div>

      <!-- Money saved -->
      <div class="metric-card">
        <div class="metric-eyebrow">💸 Money saved</div>
        <div class="metric-value" id="moneySaved">$127</div>
        <div class="metric-change up">↑ 23% vs last month</div>
        <div class="bar-chart">
          <div class="bar fill" style="height:30%"></div>
          <div class="bar fill" style="height:45%"></div>
          <div class="bar fill" style="height:60%"></div>
          <div class="bar fill" style="height:40%"></div>
          <div class="bar fill" style="height:70%"></div>
          <div class="bar fill" style="height:55%"></div>
          <div class="bar peak" style="height:90%"></div>
        </div>
        <div class="bar-labels">
          <span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span><span>S</span>
        </div>
      </div>

      <!-- Food saved -->
      <div class="metric-card">
        <div class="metric-eyebrow">🌱 Food saved from waste</div>
        <div class="metric-value">8.4 lbs</div>
        <div class="metric-change up">↑ 18% vs last month</div>
        <div style="display:flex;gap:10px;margin-top:18px;">
          <div style="flex:1;padding:14px 10px;background:var(--brand-soft);border-radius:var(--r-md);">
            <div style="font-size:24px;">🥬</div>
            <div style="font-family:Fraunces,serif;font-weight:800;font-size:18px;margin-top:6px;color:var(--t1);">3.2</div>
            <div style="font-size:11px;color:var(--t2);font-weight:600;">Produce (lbs)</div>
          </div>
          <div style="flex:1;padding:14px 10px;background:var(--soon-bg);border-radius:var(--r-md);">
            <div style="font-size:24px;">🥩</div>
            <div style="font-family:Fraunces,serif;font-weight:800;font-size:18px;margin-top:6px;color:var(--t1);">2.1</div>
            <div style="font-size:11px;color:var(--t2);font-weight:600;">Protein (lbs)</div>
          </div>
          <div style="flex:1;padding:14px 10px;background:var(--coral-soft);border-radius:var(--r-md);">
            <div style="font-size:24px;">🥛</div>
            <div style="font-family:Fraunces,serif;font-weight:800;font-size:18px;margin-top:6px;color:var(--t1);">3.1</div>
            <div style="font-size:11px;color:var(--t2);font-weight:600;">Dairy (lbs)</div>
          </div>
        </div>
      </div>

      <!-- Spending by category -->
      <div class="metric-card">
        <div class="metric-eyebrow">🍽 Spending by category</div>
        <div style="display:flex;flex-direction:column;gap:14px;margin-top:14px;">
          <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
              <div style="font-weight:600;font-size:14px;">🥦 Produce</div>
              <div style="font-size:12px;color:var(--t2);">42% · $53</div>
            </div>
            <div class="progress">
              <div class="progress-fill" style="width:42%;background:linear-gradient(90deg,var(--brand) 0%,var(--brand-glow) 100%)"></div>
            </div>
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
              <div style="font-weight:600;font-size:14px;">🥛 Dairy</div>
              <div style="font-size:12px;color:var(--t2);">28% · $35</div>
            </div>
            <div class="progress">
              <div class="progress-fill" style="width:28%;background:linear-gradient(90deg,var(--sky) 0%,#7BB1F0 100%)"></div>
            </div>
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
              <div style="font-weight:600;font-size:14px;">🥩 Protein</div>
              <div style="font-size:12px;color:var(--t2);">20% · $24</div>
            </div>
            <div class="progress">
              <div class="progress-fill" style="width:20%;background:linear-gradient(90deg,var(--coral) 0%,#FFAA88 100%)"></div>
            </div>
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
              <div style="font-weight:600;font-size:14px;">🌾 Grain</div>
              <div style="font-size:12px;color:var(--t2);">10% · $15</div>
            </div>
            <div class="progress">
              <div class="progress-fill" style="width:10%;background:linear-gradient(90deg,var(--honey) 0%,#FFD888 100%)"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Planet impact -->
      <div class="planet-card">
        <div style="font-size:11px;font-weight:800;letter-spacing:2px;opacity:0.85;text-transform:uppercase;margin-bottom:8px;">🌍 Planet Impact</div>
        <div style="font-family:Fraunces,serif;font-size:36px;font-weight:800;line-height:1;margin-bottom:6px;">21.6 kg</div>
        <div style="font-size:14px;opacity:0.92;margin-bottom:18px;">CO₂ emissions avoided this month</div>
        <div style="display:flex;gap:12px;font-size:13px;position:relative;">
          <div style="flex:1;">
            <div style="font-family:Fraunces,serif;font-size:22px;font-weight:800;">52</div>
            <div style="opacity:0.85;font-size:12px;">items saved</div>
          </div>
          <div style="flex:1;">
            <div style="font-family:Fraunces,serif;font-size:22px;font-weight:800;">8.4</div>
            <div style="opacity:0.85;font-size:12px;">lbs saved</div>
          </div>
          <div style="flex:1;">
            <div style="font-family:Fraunces,serif;font-size:22px;font-weight:800;">$127</div>
            <div style="opacity:0.85;font-size:12px;">$ saved</div>
          </div>
        </div>
      </div>

      <!-- Recent achievements -->
      <div class="section">
        <div class="section-header">
          <div class="section-title serif">Recent achievements</div>
          <a href="/app/achievements" class="section-link">All →</a>
        </div>
      </div>
      <div class="achv-list">
        <div class="achv unlocked gold">
          <div class="achv-emoji">🏆</div>
          <div class="achv-name">Zero Waste Week</div>
          <div class="achv-prog">Unlocked!</div>
        </div>
        <div class="achv unlocked green">
          <div class="achv-emoji">🌱</div>
          <div class="achv-name">Eco Warrior</div>
          <div class="achv-prog">10 lbs saved</div>
        </div>
        <div class="achv unlocked silver">
          <div class="achv-emoji">📸</div>
          <div class="achv-name">Snap Master</div>
          <div class="achv-prog">50 scans</div>
        </div>
        <div class="achv">
          <div class="achv-emoji" style="opacity:0.4;">🔒</div>
          <div class="achv-name">Streak King</div>
          <div class="achv-prog">7/30 days</div>
        </div>
        <div class="achv">
          <div class="achv-emoji" style="opacity:0.4;">🔒</div>
          <div class="achv-name">$500 Club</div>
          <div class="achv-prog">$127/$500</div>
        </div>
      </div>

      <div style="padding-bottom:40px;"></div>

    </div>

    <TabBar tabs={tabs} activeTab="analytics" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }

  .topbar { padding-top: 20px; }
</style>

<script>
  const scroll = document.getElementById('analyticsScroll');
  const topbar = document.getElementById('topbarAnalytics');
  scroll?.addEventListener('scroll', () => {
    if ((scroll.scrollTop || 0) > 10) topbar?.classList.add('scrolled');
    else topbar?.classList.remove('scrolled');
  });

  function setTime(period: string, btn: HTMLElement) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
  }
  (window as any).setTime = setTime;

  // Animate bars on load
  document.querySelectorAll('.bar').forEach((bar, i) => {
    (bar as HTMLElement).style.transition = `height 0.6s cubic-bezier(0.16,1,0.3,1) ${i * 0.08}s`;
  });
</script>
