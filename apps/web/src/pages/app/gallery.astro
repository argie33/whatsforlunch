---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const mockPhotos = [
  { id: '1', emoji: '🥦', name: 'Broccoli', count: 3 },
  { id: '2', emoji: '🥬', name: 'Spinach', count: 1 },
  { id: '3', emoji: '🥛', name: 'Milk', count: 2 },
];

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Gallery — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/dashboard" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Photo Gallery</div>
        <div style="width:44px"></div>
      </div>

      <!-- Photos Grid -->
      <div style="padding:0 22px 40px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
          {mockPhotos.map((photo) => (
            <div key={photo.id} class="metric-card" style="cursor:pointer;text-align:center;">
              <div style="aspect-ratio:1;background:var(--bg);border-radius:var(--r-lg);display:flex;align-items:center;justify-content:center;font-size:48px;margin-bottom:10px;">
                {photo.emoji}
              </div>
              <div style="font-size:13px;font-weight:600;margin:0 0 2px 0;color:var(--t1);">{photo.name}</div>
              <div style="font-size:12px;color:var(--t2);margin:0;">{photo.count} photos</div>
            </div>
          ))}
        </div>

        <button class="btn btn-secondary btn-block" onclick="alert('Take photo')">📷 Add Photo</button>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
