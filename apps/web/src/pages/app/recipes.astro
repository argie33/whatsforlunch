---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes', active: true },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];

const staticRecipes = [
  { emoji: '🥘', title: 'Vegetable Stir Fry', time: 20, servings: 2, uses: 4, theme: 'warm', tag: 'Quick', match: 94 },
  { emoji: '🥗', title: 'Fresh Garden Salad', time: 10, servings: 2, uses: 5, theme: 'veggie', match: 87 },
  { emoji: '🍝', title: 'Garlic Spinach Pasta', time: 25, servings: 4, uses: 3, theme: 'cool', tag: 'Healthy', match: 82 },
  { emoji: '🍲', title: 'Leftover Soup', time: 30, servings: 4, uses: 6, theme: 'warm', tag: 'Easy', match: 78 },
  { emoji: '🥙', title: 'Veggie Wrap', time: 15, servings: 2, uses: 4, theme: 'veggie', match: 75 },
  { emoji: '🫕', title: 'Pantry Curry', time: 35, servings: 4, uses: 5, theme: 'spice', tag: 'Spicy', match: 71 },
];
---

<BaseLayout title="Recipes — WhatsFresh">
  <main>
    <div class="scroll" id="recipesScroll">

      <!-- Top Bar -->
      <div class="topbar" id="topbarRecipes">
        <div class="topbar-title">
          <div class="caption" style="color:var(--t2)">For your fridge</div>
          <div class="h2 serif">Recipes</div>
        </div>
        <div class="topbar-actions">
          <button class="btn-icon" id="refreshBtn" aria-label="Refresh">↻</button>
        </div>
      </div>

      <!-- Filter chips -->
      <div class="chips">
        <button class="chip active" onclick="filterRecipes('all',this)">✨ For you</button>
        <button class="chip" onclick="filterRecipes('quick',this)">⚡ Quick</button>
        <button class="chip" onclick="filterRecipes('vegetarian',this)">🥗 Vegetarian</button>
        <button class="chip" onclick="filterRecipes('healthy',this)">💪 Healthy</button>
        <button class="chip" onclick="filterRecipes('comfort',this)">🍝 Comfort</button>
        <button class="chip" onclick="filterRecipes('spicy',this)">🌶 Spicy</button>
      </div>

      <!-- Recipes grid -->
      <div id="recipesList" style="padding:0 22px 16px;">
        {staticRecipes.map(r => (
          <div class="recipe-card" onclick="location.href='/app/recipes'">
            <div class={`recipe-image ${r.theme}`}>
              <span style="position:relative;">{r.emoji}</span>
              <div class="recipe-match">✦ {r.match}% match</div>
              {r.tag && <div class="recipe-tag">{r.tag}</div>}
            </div>
            <div class="recipe-body">
              <div class="recipe-title">{r.title}</div>
              <div class="recipe-meta">
                <div class="recipe-meta-item">⏱ {r.time} min</div>
                <div class="recipe-meta-item">👥 {r.servings} servings</div>
                <div class="recipe-meta-item">🥦 Uses {r.uses} items</div>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="recipes" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }

  .topbar { padding-top: 20px; }
</style>

<script>
  const scroll = document.getElementById('recipesScroll');
  const topbar = document.getElementById('topbarRecipes');
  scroll?.addEventListener('scroll', () => {
    if ((scroll.scrollTop || 0) > 10) topbar?.classList.add('scrolled');
    else topbar?.classList.remove('scrolled');
  });

  function filterRecipes(type: string, btn: HTMLElement) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    // In a real app, this would filter/reload recipes
  }

  (window as any).filterRecipes = filterRecipes;

  // Try to load real recipes from API
  async function loadRecipes() {
    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            recipes(limit: 10) {
              id name emoji cookTime servings
            }
          }`
        })
      });
      const { data } = await res.json();
      if (!data?.recipes?.length) return;

      const themes = ['warm', 'veggie', 'cool', 'spice', 'berry', 'warm'];
      const container = document.getElementById('recipesList');
      if (!container) return;

      container.innerHTML = data.recipes.map((r: any, i: number) => `
        <div class="recipe-card" onclick="location.href='/app/recipes/${r.id}'">
          <div class="recipe-image ${themes[i % themes.length]}">
            <span style="position:relative;">${r.emoji || '🍽'}</span>
            <div class="recipe-match">✦ ${90 - i * 4}% match</div>
          </div>
          <div class="recipe-body">
            <div class="recipe-title">${r.name}</div>
            <div class="recipe-meta">
              ${r.cookTime ? `<div class="recipe-meta-item">⏱ ${r.cookTime} min</div>` : ''}
              ${r.servings ? `<div class="recipe-meta-item">👥 ${r.servings} servings</div>` : ''}
            </div>
          </div>
        </div>`).join('');
    } catch (_) {
      // Keep static recipes on error
    }
  }

  document.getElementById('refreshBtn')?.addEventListener('click', loadRecipes);
  loadRecipes();
</script>
