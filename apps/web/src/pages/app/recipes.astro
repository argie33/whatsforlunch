---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';

const mockRecipes = [
  { id: '1', name: 'Stir-fry Vegetables', ingredients: 3, time: '15 min' },
  { id: '2', name: 'Smoothie Bowl', ingredients: 2, time: '5 min' },
  { id: '3', name: 'Grilled Broccoli', ingredients: 1, time: '10 min' },
];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes', active: true },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Recipes — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Recipes" subtitle="Based on what you have" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <p class="eyebrow" style="margin-bottom: 16px;">🔥 FEATURED FOR YOU</p>

        {mockRecipes.map((recipe) => (
          <Card pressable key={recipe.id} class="recipe-card" style="margin-bottom: 12px; cursor: pointer;" onclick={`location.href='/app/recipes/${recipe.id}'`}>
            <div style="padding: 16px; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <h3 style="font-size: 17px; font-weight: 700; margin: 0 0 4px 0;">{recipe.name}</h3>
                <p style="font-size: 13px; color: var(--t2); margin: 0;">{recipe.ingredients} ingredients • {recipe.time}</p>
              </div>
              <div style="font-size: 24px;">👨‍🍳</div>
            </div>
          </Card>
        ))}

        <div style="margin-top: 32px; padding: 20px; background: linear-gradient(135deg, var(--brand-soft) 0%, var(--brand-tint) 100%); border-radius: var(--r-lg); text-align: center;">
          <p style="color: var(--t2); margin: 0;">🚀 Full recipe database and search coming soon!</p>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="recipes" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  .recipe-card {
    transition: transform 0.15s var(--quick), box-shadow 0.2s;
  }

  .recipe-card:active {
    transform: scale(0.98);
  }
</style>
