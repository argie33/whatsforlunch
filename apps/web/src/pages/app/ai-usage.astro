---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="AI Usage — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="AI Usage" subtitle="Photo & voice recognition" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Status -->
        <p class="eyebrow" style="margin-bottom: 12px;">Status</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: flex; gap: 12px;">
            <div style="width: 12px; height: 12px; border-radius: 50%; background: var(--fresh); flex-shrink: 0; margin-top: 2px;"></div>
            <div>
              <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">AI Recognition Enabled</p>
              <p style="font-size: 12px; color: var(--t2); margin: 4px 0 0 0;">You have access to photo and voice features</p>
            </div>
          </div>
        </Card>

        <!-- Usage Stats -->
        <p class="eyebrow" style="margin-bottom: 12px;">📊 This Month</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 6px 0; letter-spacing: 1.5px;">Photo Scans</p>
              <p style="font-size: 20px; font-weight: 700; margin: 0; color: var(--brand);">23</p>
            </div>
            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 6px 0; letter-spacing: 1.5px;">Voice Requests</p>
              <p style="font-size: 20px; font-weight: 700; margin: 0; color: var(--brand);">12</p>
            </div>
          </div>
        </Card>

        <!-- Privacy -->
        <p class="eyebrow" style="margin-bottom: 12px;">🔒 Privacy</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 10px;">
            <label style="display: flex; justify-content: space-between; align-items: center; cursor: pointer;">
              <span style="font-size: 14px; color: var(--t1);">Save photos</span>
              <input type="checkbox" defaultChecked style="width: 40px; height: 24px; cursor: pointer;" />
            </label>
            <label style="display: flex; justify-content: space-between; align-items: center; cursor: pointer;">
              <span style="font-size: 14px; color: var(--t1);">Use for training</span>
              <input type="checkbox" style="width: 40px; height: 24px; cursor: pointer;" />
            </label>
          </div>
        </Card>

        <p style="font-size: 12px; color: var(--t2); margin: 0; text-align: center;">
          Your photos and voice data are never shared with third parties
        </p>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
