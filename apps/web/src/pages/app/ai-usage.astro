---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="AI Usage — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">AI Usage</div>
        <div style="width:44px"></div>
      </div>

      <!-- Status -->
      <div class="eyebrow" style="padding:8px 22px 8px;letter-spacing:0.5px;">Status</div>
      <div class="settings-section">
        <div class="settings-row" style="border-bottom:none;">
          <div style="flex:1;display:flex;gap:12px;">
            <div style="width:12px;height:12px;border-radius:50%;background:var(--fresh);flex-shrink:0;margin-top:2px;"></div>
            <div>
              <div class="settings-title">AI Recognition Enabled</div>
              <div class="settings-sub">You have access to photo and voice features</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Usage Stats -->
      <div class="eyebrow" style="padding:8px 22px 8px;margin-top:16px;letter-spacing:0.5px;">📊 THIS MONTH</div>
      <div class="settings-section" style="margin:0;">
        <div class="settings-row" style="border-bottom:1px solid var(--b1);">
          <div>
            <div style="font-size:11px;font-weight:800;color:var(--t2);text-transform:uppercase;margin:0 0 6px 0;letter-spacing:1.5px;">Photo Scans</div>
            <div style="font-size:20px;font-weight:700;margin:0;color:var(--brand);">23</div>
          </div>
        </div>
        <div class="settings-row" style="border-bottom:none;">
          <div>
            <div style="font-size:11px;font-weight:800;color:var(--t2);text-transform:uppercase;margin:0 0 6px 0;letter-spacing:1.5px;">Voice Requests</div>
            <div style="font-size:20px;font-weight:700;margin:0;color:var(--brand);">12</div>
          </div>
        </div>
      </div>

      <!-- Privacy -->
      <div class="eyebrow" style="padding:8px 22px 8px;margin-top:16px;letter-spacing:0.5px;">🔒 PRIVACY</div>
      <div class="settings-section">
        <div class="settings-row" style="border-bottom:1px solid var(--b1);">
          <div style="flex:1;">
            <div class="settings-title">Save photos</div>
          </div>
          <button class="toggle on" onclick="togglePrivacy(this)"></button>
        </div>
        <div class="settings-row" style="border-bottom:none;">
          <div style="flex:1;">
            <div class="settings-title">Use for training</div>
          </div>
          <button class="toggle" onclick="togglePrivacy(this)"></button>
        </div>
      </div>

      <div style="padding:0 22px 40px;text-align:center;font-size:12px;color:var(--t2);">
        Your photos and voice data are never shared with third parties
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const PRIVACY_KEY = 'wfl_privacy';

  function savePrivacy() {
    const toggles = Array.from(document.querySelectorAll('.toggle')).map(t => t.classList.contains('on'));
    localStorage.setItem(PRIVACY_KEY, JSON.stringify(toggles));
  }

  function loadPrivacy() {
    const saved = localStorage.getItem(PRIVACY_KEY);
    if (!saved) return;
    const toggles = JSON.parse(saved);
    document.querySelectorAll('.toggle').forEach((btn, idx) => {
      if (toggles[idx]) (btn as HTMLElement).classList.add('on');
      else (btn as HTMLElement).classList.remove('on');
    });
  }

  function togglePrivacy(el: HTMLElement) {
    (el as HTMLButtonElement).classList.toggle('on');
    savePrivacy();
  }

  loadPrivacy();

  (window as any).togglePrivacy = togglePrivacy;
</script>
