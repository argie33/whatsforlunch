---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard', active: true },
  { id: 'items', label: 'Items', icon: '🥦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Insights', icon: '📊', href: '/app/analytics' },
  { id: 'settings', label: 'Profile', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Dashboard — WhatsFresh">
  <main>
    <div class="scroll" id="mainScroll">

      <!-- Top Bar -->
      <div class="topbar" id="topbarDash">
        <div class="topbar-title">
          <div style="display:flex;align-items:center;gap:8px;">
            <div class="caption" style="color:var(--t2)">Welcome back</div>
            <div class="sync-pill">
              <div class="sync-dot"></div>
              Synced
            </div>
          </div>
          <div class="h2" id="dashGreeting">Hello there 👋</div>
        </div>
        <div class="topbar-actions">
          <a href="/app/notifications" class="btn-icon" style="position:relative;text-decoration:none;">
            🔔
            <span style="position:absolute;top:6px;right:6px;width:9px;height:9px;background:var(--coral);border:2px solid white;border-radius:50%"></span>
          </a>
          <a href="/app/settings" class="avatar" id="userAvatar" style="text-decoration:none;">U</a>
        </div>
      </div>

      <!-- Hero stats -->
      <div class="hero-stats">
        <a href="/app/items?filter=fresh" class="stat stat-fresh" style="text-decoration:none;">
          <div class="stat-num" id="freshCount">—</div>
          <div class="stat-label">Fresh</div>
        </a>
        <a href="/app/items?filter=soon" class="stat stat-soon" style="text-decoration:none;">
          <div class="stat-num" id="soonCount">—</div>
          <div class="stat-label">Use soon</div>
        </a>
        <a href="/app/items?filter=urgent" class="stat stat-urgent" style="text-decoration:none;">
          <div class="stat-num" id="urgentCount">—</div>
          <div class="stat-label">Eat today</div>
        </a>
      </div>

      <!-- Today's Pick card -->
      <div class="section" style="padding-top:8px;padding-bottom:0;">
        <a href="/app/digest" class="card card-pressable" style="display:block;text-decoration:none;position:relative;background:linear-gradient(135deg,#FF6B47 0%,#F4B942 100%);color:white;border:none;padding:18px;overflow:hidden;">
          <div style="position:absolute;top:-20px;right:-20px;font-size:120px;opacity:0.15;">🍽</div>
          <div style="position:relative;">
            <div style="font-size:11px;font-weight:800;letter-spacing:1.5px;opacity:0.9;">⭐ TODAY'S PICK</div>
            <div class="serif" style="font-size:22px;font-weight:800;line-height:1.15;margin-top:6px;">What to eat today</div>
            <div style="font-size:13px;margin-top:4px;opacity:0.95;" id="digestSubtitle">Your personalized meal plan is ready</div>
          </div>
        </a>
      </div>

      <!-- Insight card -->
      <div class="insight">
        <div class="insight-row">
          <div>
            <div class="insight-eyebrow">💡 This month</div>
            <div class="insight-title serif">You saved $127</div>
            <div class="insight-text">Eating items before they expire saved 8.4 lbs of food from the trash.</div>
          </div>
          <div class="insight-icon">📈</div>
        </div>
      </div>

      <!-- Streak card -->
      <div class="streak-card">
        <div class="streak-num" id="streakNum">7</div>
        <div>
          <div style="font-size:18px;font-weight:800;font-family:Fraunces,serif;letter-spacing:-0.5px;">Day streak!</div>
          <div class="streak-label">Zero items wasted this week</div>
        </div>
      </div>

      <!-- Eat soon section -->
      <div class="section">
        <div class="section-header">
          <div class="section-title serif">Eat soon</div>
          <a href="/app/items" class="section-link">See all →</a>
        </div>
        <div id="dashItems">
          <div class="item-card" style="animation:none;opacity:1;">
            <div style="width:4px;flex-shrink:0;background:var(--sunken);"></div>
            <div class="item-content">
              <div class="skel" style="width:52px;height:52px;border-radius:var(--r-md);flex-shrink:0;"></div>
              <div class="item-info">
                <div class="skel" style="width:60%;height:17px;margin-bottom:6px;"></div>
                <div class="skel" style="width:40%;height:13px;"></div>
              </div>
            </div>
          </div>
          <div class="item-card" style="animation:none;opacity:1;">
            <div style="width:4px;flex-shrink:0;background:var(--sunken);"></div>
            <div class="item-content">
              <div class="skel" style="width:52px;height:52px;border-radius:var(--r-md);flex-shrink:0;"></div>
              <div class="item-info">
                <div class="skel" style="width:55%;height:17px;margin-bottom:6px;"></div>
                <div class="skel" style="width:35%;height:13px;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tonight's ideas -->
      <div class="section">
        <div class="section-header">
          <div class="section-title serif">Tonight's ideas</div>
          <a href="/app/recipes" class="section-link">More →</a>
        </div>
        <div class="recipe-card" onclick="location.href='/app/recipes'">
          <div class="recipe-image warm">
            <span style="position:relative;">🥘</span>
            <div class="recipe-match">✦ 94% match</div>
            <div class="recipe-tag">Quick</div>
          </div>
          <div class="recipe-body">
            <div class="recipe-title">Vegetable Stir Fry</div>
            <div class="recipe-meta">
              <div class="recipe-meta-item">⏱ 20 min</div>
              <div class="recipe-meta-item">👥 2 servings</div>
              <div class="recipe-meta-item">🥦 Uses 3 items</div>
            </div>
          </div>
        </div>
        <div class="recipe-card" onclick="location.href='/app/recipes'">
          <div class="recipe-image veggie">
            <span style="position:relative;">🥗</span>
            <div class="recipe-match">✦ 87% match</div>
          </div>
          <div class="recipe-body">
            <div class="recipe-title">Fresh Garden Salad</div>
            <div class="recipe-meta">
              <div class="recipe-meta-item">⏱ 10 min</div>
              <div class="recipe-meta-item">👥 2 servings</div>
              <div class="recipe-meta-item">🥬 Uses 5 items</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick actions grid -->
      <div class="section">
        <div class="section-header">
          <div class="section-title serif">Quick actions</div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;">
          <a href="/app/shopping" class="card card-pressable" style="display:block;text-decoration:none;padding:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="settings-icon honey">🛒</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--t1);">Shopping</div>
                <div style="font-size:12px;color:var(--t2);">3 items</div>
              </div>
            </div>
          </a>
          <a href="/app/containers" class="card card-pressable" style="display:block;text-decoration:none;padding:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="settings-icon coral">🍱</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--t1);">Containers</div>
                <div style="font-size:12px;color:var(--t2);">4 active</div>
              </div>
            </div>
          </a>
          <a href="/app/analytics" class="card card-pressable" style="display:block;text-decoration:none;padding:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="settings-icon sky">📊</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--t1);">Insights</div>
                <div style="font-size:12px;color:var(--t2);">$127 saved</div>
              </div>
            </div>
          </a>
          <a href="/app/achievements" class="card card-pressable" style="display:block;text-decoration:none;padding:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="settings-icon plum">🏆</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--t1);">Achievements</div>
                <div style="font-size:12px;color:var(--t2);">12/30</div>
              </div>
            </div>
          </a>
          <a href="/app/activity" class="card card-pressable" style="display:block;text-decoration:none;padding:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="settings-icon coral">📰</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--t1);">Activity</div>
                <div style="font-size:12px;color:var(--t2);">12 today</div>
              </div>
            </div>
          </a>
          <a href="/app/gallery" class="card card-pressable" style="display:block;text-decoration:none;padding:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="settings-icon honey">📖</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--t1);">Gallery</div>
                <div style="font-size:12px;color:var(--t2);">Discover recipes</div>
              </div>
            </div>
          </a>
          <a href="/app/friends" class="card card-pressable" style="display:block;text-decoration:none;padding:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="settings-icon coral">👥</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--t1);">Friends</div>
                <div style="font-size:12px;color:var(--t2);">Social feed</div>
              </div>
            </div>
          </a>
          <a href="/app/scan" class="card card-pressable" style="display:block;text-decoration:none;padding:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="settings-icon sky">🧾</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--t1);">Scan receipt</div>
                <div style="font-size:12px;color:var(--t2);">Add 30+ at once</div>
              </div>
            </div>
          </a>
        </div>
      </div>

      <!-- Premium upsell -->
      <div class="section">
        <a href="/app/paywall" class="card card-pressable" style="display:block;text-decoration:none;background:linear-gradient(135deg,#6B5B95 0%,#C2185B 100%);color:white;border:none;padding:18px;position:relative;overflow:hidden;">
          <div style="position:absolute;top:-30px;right:-20px;font-size:140px;opacity:0.15;">⭐</div>
          <div style="position:relative;">
            <div style="font-size:11px;font-weight:800;letter-spacing:1.5px;opacity:0.9;">PREMIUM</div>
            <div class="serif" style="font-size:20px;font-weight:800;margin-top:6px;">Unlimited AI · Family sharing · More</div>
            <div style="font-size:13px;margin-top:4px;opacity:0.92;">7-day free trial · Cancel anytime</div>
          </div>
        </a>
      </div>

      <!-- Weekly recap CTA -->
      <div class="section" style="padding-bottom:40px;">
        <a href="/app/recap" class="card card-pressable" style="display:block;text-decoration:none;background:linear-gradient(135deg,var(--brand) 0%,var(--brand-light) 100%);color:white;border:none;padding:18px;">
          <div style="display:flex;align-items:center;gap:14px;">
            <div style="width:48px;height:48px;background:rgba(255,255,255,0.2);border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;font-size:24px;">📅</div>
            <div style="flex:1;">
              <div style="font-family:Fraunces,serif;font-weight:800;font-size:18px;letter-spacing:-0.3px;">Your week in food</div>
              <div style="font-size:13px;opacity:0.9;">$42 saved · 7 day streak · See recap</div>
            </div>
            <div style="font-size:24px;">→</div>
          </div>
        </a>
      </div>

    </div>

    <!-- FAB -->
    <a href="/app/add" class="fab" aria-label="Add item">+</a>

    <!-- Tab Bar -->
    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }

  .topbar {
    padding-top: 20px;
  }

  .fab {
    position: fixed;
    bottom: 96px;
    right: 22px;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    font-weight: 300;
    z-index: 25;
  }
</style>

<script>
  // Scroll handler for topbar
  const mainScroll = document.getElementById('mainScroll');
  const topbarDash = document.getElementById('topbarDash');
  if (mainScroll && topbarDash) {
    mainScroll.addEventListener('scroll', () => {
      if (mainScroll.scrollTop > 10) {
        topbarDash.classList.add('scrolled');
      } else {
        topbarDash.classList.remove('scrolled');
      }
    });
  }

  // Greeting based on time
  const hour = new Date().getHours();
  const greetingEl = document.getElementById('dashGreeting');
  if (greetingEl) {
    if (hour < 12) greetingEl.textContent = 'Good morning 👋';
    else if (hour < 17) greetingEl.textContent = 'Good afternoon 👋';
    else greetingEl.textContent = 'Good evening 👋';
  }

  // Emoji map for categories
  const emojiMap = {
    produce: '🥦', vegetable: '🥦', fruit: '🍎', dairy: '🥛', bread: '🍞', baked: '🍞',
    meat: '🥩', protein: '🥩', frozen: '🧊', pantry: '🥫', sauce: '🥫', prepared: '🥘',
    leftover: '🥘', beverage: '🥤', other: '📦'
  };

  // Load real data from API
  async function loadDashboard() {
    try {
      const token = localStorage.getItem('auth_token');
      const headers = {
        'Content-Type': 'application/json',
      };
      if (token) {
        headers['Authorization'] = `Bearer ${token}`;
      }

      // First get user and household
      const profileResponse = await fetch('/api/graphql', {
        method: 'POST',
        headers,
        body: JSON.stringify({
          query: `query { getProfile { id displayName } listHouseholds { id } }`
        })
      });

      const profileData = await profileResponse.json();
      const user = profileData.data?.getProfile;
      const householdId = profileData.data?.listHouseholds?.[0]?.id;

      if (user?.displayName && greetingEl) {
        const firstName = user.displayName.split(' ')[0];
        if (hour < 12) greetingEl.textContent = `Good morning, ${firstName} 👋`;
        else if (hour < 17) greetingEl.textContent = `Good afternoon, ${firstName} 👋`;
        else greetingEl.textContent = `Good evening, ${firstName} 👋`;
        const avatar = document.getElementById('userAvatar');
        if (avatar) avatar.textContent = firstName[0].toUpperCase();
      }

      if (!householdId) return;

      // Fetch items
      const itemsResponse = await fetch('/api/graphql', {
        method: 'POST',
        headers,
        body: JSON.stringify({
          query: `query ListItems($householdId: ID!) {
            listItems(householdId: $householdId) {
              id foodName category storageLocation status expiryAt
            }
          }`,
          variables: { householdId }
        })
      });

      const itemsData = await itemsResponse.json();
      const items = itemsData.data?.listItems || [];

      // Calculate stats
      const fresh = items.filter((i: any) => i.status === 'fresh').length;
      const soon = items.filter((i: any) => i.status === 'soon').length;
      const urgent = items.filter((i: any) => i.status === 'urgent').length;

      const freshEl = document.getElementById('freshCount');
      const soonEl = document.getElementById('soonCount');
      const urgentEl = document.getElementById('urgentCount');
      if (freshEl) freshEl.textContent = String(fresh);
      if (soonEl) soonEl.textContent = String(soon);
      if (urgentEl) urgentEl.textContent = String(urgent);

      const eatSoon = items
        .filter((i: any) => i.status === 'urgent' || i.status === 'soon')
        .slice(0, 4);

      const dashItemsEl = document.getElementById('dashItems');
      if (dashItemsEl) {
        if (eatSoon.length > 0) {
          dashItemsEl.innerHTML = eatSoon.map((item: any, idx: number) => {
            const days = item.expiryAt ? Math.ceil((new Date(item.expiryAt).getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24)) : 0;
            const daysLabel = days === 0 ? 'Today' : days === 1 ? 'Tomorrow' : days < 0 ? 'Expired' : `${days}d left`;
            const emoji = emojiMap[item.category?.toLowerCase() as keyof typeof emojiMap] || '📦';
            return `
              <a href="/app/items/${item.id}" class="item-card" style="text-decoration:none;animation-delay:${idx * 0.05}s;">
                <div class="item-stripe ${item.status}"></div>
                <div class="item-content">
                  <div class="item-icon ${item.status}">${emoji}</div>
                  <div class="item-info">
                    <div class="item-name">${item.foodName}</div>
                    <div class="item-meta">
                      <span>${item.storageLocation || 'Fridge'}</span>
                      <div class="dot"></div>
                      <span>${daysLabel}</span>
                    </div>
                  </div>
                  <div class="item-badge ${item.status}">${daysLabel}</div>
                </div>
              </a>`;
          }).join('');
        } else {
          dashItemsEl.innerHTML = `
              <div style="text-align:center;padding:32px;color:var(--t2);">
                <div style="font-size:48px;margin-bottom:12px;">✨</div>
                <div style="font-weight:700;font-size:17px;color:var(--t1);margin-bottom:4px;">Everything's fresh!</div>
                <div style="font-size:14px;">No items expiring soon</div>
              </div>`;
        }

        const digestEl = document.getElementById('digestSubtitle');
        if (digestEl && urgent > 0) {
          digestEl.textContent = `${urgent} item${urgent > 1 ? 's' : ''} expiring today · Quick recipes ready`;
        }
      }
    } catch (e) {
      // Silently fall back on error
    }
  }

  loadDashboard();
</script>
