---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import StatCard from '@/components/StatCard.astro';
import InsightCard from '@/components/InsightCard.astro';
import StreakCard from '@/components/StreakCard.astro';
import ItemCard from '@/components/ItemCard.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';
import FAB from '@/components/FAB.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard', active: true },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Dashboard — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <!-- Top Bar -->
    <TopBar
      title="Dashboard"
      subtitle="Your kitchen inventory"
      actions={[
        { icon: '🔔', label: 'Notifications', onClick: "location.href='/app/notifications'" },
        { icon: '🔍', label: 'Search', onClick: "location.href='/app/search'" },
      ]}
    />

    <!-- Scrollable Content -->
    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Hero Stats -->
      <div class="hero-stats" style="animation: fadeInUp 0.5s var(--ease);">
        <div style="animation: staggerFadeIn 0.4s var(--ease) 0.05s backwards;">
          <StatCard number={0} id="fresh-count" label="Fresh" status="fresh" />
        </div>
        <div style="animation: staggerFadeIn 0.4s var(--ease) 0.1s backwards;">
          <StatCard number={0} id="soon-count" label="Use soon" status="soon" />
        </div>
        <div style="animation: staggerFadeIn 0.4s var(--ease) 0.15s backwards;">
          <StatCard number={0} id="urgent-count" label="Use today" status="urgent" />
        </div>
      </div>

      <!-- Insight Card -->
      <InsightCard
        eyebrow="Smart Recommendation"
        title="Use Your Bread!"
        text="Your bread expires today. Check out a recipe that uses bread."
        icon="👨‍🍳"
        onClick="location.href='/app/recipes'"
      />

      <!-- Streak Card -->
      <StreakCard number={7} label="Day Streak" />

      <!-- Quick Actions -->
      <div style="padding: 16px 22px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
        <Card pressable>
          <Button variant="secondary" block onClick="location.href='/app/add'">
            ➕ Add Item
          </Button>
        </Card>
        <Card pressable>
          <Button variant="secondary" block onClick="location.href='/app/scan'">
            📷 Scan
          </Button>
        </Card>
      </div>

      <!-- Recent Items Section -->
      <div style="padding: 16px 22px 0;">
        <div class="section-header">
          <h2 class="section-title">Recent Items</h2>
          <a href="/app/items" class="section-link">View all</a>
        </div>
      </div>

      <div id="recent-items-list" style="padding: 0 22px;">
        <p style="color: var(--t2); text-align: center;">Loading items...</p>
      </div>

      <!-- Coming Soon Section -->
      <div style="margin: 32px 22px;">
        <Card>
          <div style="padding: 16px; text-align: center;">
            <p class="body-sm" style="color: var(--t2); margin-bottom: 8px;">
              📚 More features coming soon:
            </p>
            <ul style="list-style: none; padding: 0; margin: 0; font-size: 14px; color: var(--t2);">
              <li>📦 Containers management</li>
              <li>🧑‍🍳 Recipe suggestions</li>
              <li>🏠 Household sharing</li>
              <li>📊 Advanced analytics</li>
            </ul>
          </div>
        </Card>
      </div>
    </div>

    <!-- FAB -->
    <FAB icon="➕" label="Add item" href="/app/add" />

    <!-- Tab Bar -->
    <TabBar
      tabs={tabs}
      activeTab="dashboard"
    />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  /* Scroll reveal effect */
  .card, .insight {
    opacity: 0;
  }

  .card.revealed, .insight.revealed {
    animation: fadeInUp 0.5s var(--ease) forwards;
  }
</style>

<script>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  const emojiMap = {
    vegetable: '🥦',
    produce: '🥦',
    fruit: '🍎',
    dairy: '🥛',
    bread: '🍞',
    baked: '🍞',
    meat: '🥩',
    protein: '🥩',
    frozen: '🧊',
    pantry: '🥫',
    sauce: '🥫',
    prepared: '🥘',
    leftover: '🥘',
    beverage: '🥤',
    other: '📦',
  };

  async function loadDashboard() {
    try {
      const userQuery = `query { getProfile { id } listHouseholds { id } }`;
      const userData = await gql(userQuery);
      const householdId = userData.listHouseholds?.[0]?.id;

      if (!householdId) {
        document.getElementById('recent-items-list').innerHTML = '<p style="color: var(--t2); text-align: center;">No household found</p>';
        return;
      }

      // Fetch items
      const itemsQuery = `query ListItems($householdId: ID!) {
        listItems(householdId: $householdId) {
          id foodName category storageLocation status expiryAt
        }
      }`;

      const itemsData = await gql(itemsQuery, { householdId });
      const items = itemsData.listItems || [];

      // Calculate stats
      const stats = { fresh: 0, soon: 0, urgent: 0 };
      items.forEach((item) => {
        stats[item.status]++;
      });

      document.getElementById('fresh-count').textContent = stats.fresh;
      document.getElementById('soon-count').textContent = stats.soon;
      document.getElementById('urgent-count').textContent = stats.urgent;

      // Get recent 3 items
      const recentItems = items.slice(0, 3);
      if (recentItems.length === 0) {
        document.getElementById('recent-items-list').innerHTML = '<p style="color: var(--t2); text-align: center;">No items yet</p>';
        return;
      }

      const itemsHtml = recentItems.map((item) => {
        const days = item.expiryAt ? Math.ceil((new Date(item.expiryAt).getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24)) : 0;
        const emoji = emojiMap[item.category?.toLowerCase()] || emojiMap.other;
        return `
          <div style="background: var(--raised); border: 1px solid var(--b1); border-radius: var(--r-lg); padding: 14px; margin-bottom: 10px; display: flex; gap: 12px; cursor: pointer; transition: transform 0.15s, box-shadow 0.2s;" onclick="location.href='/app/items/${item.id}'">
            <div style="width: 52px; height: 52px; border-radius: var(--r-md); background: var(--sunken); display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0;">${emoji}</div>
            <div style="flex: 1;">
              <div style="font-size: 17px; font-weight: 700; color: var(--t1); margin-bottom: 3px;">${item.foodName}</div>
              <div style="font-size: 13px; color: var(--t2);">${item.storageLocation || 'Unknown'}</div>
            </div>
            <div style="display: flex; align-items: center;">
              <div style="padding: 6px 12px; border-radius: var(--r-full); background: ${item.status === 'fresh' ? 'var(--fresh-bg)' : item.status === 'soon' ? 'var(--soon-bg)' : 'var(--urgent-bg)'}; color: ${item.status === 'fresh' ? 'var(--fresh)' : item.status === 'soon' ? 'var(--soon)' : 'var(--urgent)'}; font-size: 11px; font-weight: 700; white-space: nowrap;">${days > 0 ? days + 'd' : 'Today'}</div>
            </div>
          </div>
        `;
      }).join('');

      document.getElementById('recent-items-list').innerHTML = itemsHtml;
    } catch (error) {
      console.error('Failed to load dashboard:', error);
      document.getElementById('recent-items-list').innerHTML = '<p style="color: var(--t2); text-align: center;">Failed to load items</p>';
    }
  }

  loadDashboard();

  // Scroll reveal animation using Intersection Observer
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.card, .insight').forEach((el) => {
      observer.observe(el);
    });
  }
</script>
