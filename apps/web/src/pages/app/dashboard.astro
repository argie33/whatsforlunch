---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import StatCard from '@/components/StatCard.astro';
import InsightCard from '@/components/InsightCard.astro';
import StreakCard from '@/components/StreakCard.astro';
import ItemCard from '@/components/ItemCard.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';
import FAB from '@/components/FAB.astro';

const mockItems = [
  { id: '1', name: 'Broccoli', emoji: '🥦', status: 'fresh' as const, days: 5, container: 'Fridge' },
  { id: '2', name: 'Milk', emoji: '🥛', status: 'soon' as const, days: 2, container: 'Fridge' },
  { id: '3', name: 'Bread', emoji: '🍞', status: 'urgent' as const, days: 0, container: 'Counter' },
];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard', active: true },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Dashboard — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <style>
      .dashboard-item {
        animation: slideInFromUp 0.5s var(--ease);
      }
    </style>

    <!-- Top Bar -->
    <TopBar
      title="Dashboard"
      subtitle="Your kitchen inventory"
      actions={[
        { icon: '🔔', label: 'Notifications', onClick: "location.href='/app/notifications'" },
        { icon: '🔍', label: 'Search', onClick: "location.href='/app/search'" },
      ]}
    />

    <!-- Scrollable Content -->
    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <!-- Hero Stats -->
      <div class="hero-stats" style="animation: fadeInUp 0.5s var(--ease);">
        <div style="animation: staggerFadeIn 0.4s var(--ease) 0.05s backwards;">
          <StatCard number={3} label="Fresh" status="fresh" />
        </div>
        <div style="animation: staggerFadeIn 0.4s var(--ease) 0.1s backwards;">
          <StatCard number={2} label="Use soon" status="soon" />
        </div>
        <div style="animation: staggerFadeIn 0.4s var(--ease) 0.15s backwards;">
          <StatCard number={1} label="Use today" status="urgent" />
        </div>
      </div>

      <!-- Insight Card -->
      <InsightCard
        eyebrow="Smart Recommendation"
        title="Use Your Bread!"
        text="Your bread expires today. Check out a recipe that uses bread."
        icon="👨‍🍳"
        onClick="location.href='/app/recipes'"
      />

      <!-- Streak Card -->
      <StreakCard number={7} label="Day Streak" />

      <!-- Quick Actions -->
      <div style="padding: 16px 22px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
        <Card pressable>
          <Button variant="secondary" block onClick="location.href='/app/add'">
            ➕ Add Item
          </Button>
        </Card>
        <Card pressable>
          <Button variant="secondary" block onClick="location.href='/app/scan'">
            📷 Scan
          </Button>
        </Card>
      </div>

      <!-- Recent Items Section -->
      <div style="padding: 16px 22px 0;">
        <div class="section-header">
          <h2 class="section-title">Recent Items</h2>
          <a href="/app/items" class="section-link">View all</a>
        </div>
      </div>

      <div style="padding: 0 22px;">
        {mockItems.map((item) => (
          <ItemCard
            key={item.id}
            name={item.name}
            emoji={item.emoji}
            status={item.status}
            days={item.days}
            container={item.container}
            onClick={`location.href='/app/items/${item.id}'`}
          />
        ))}
      </div>

      <!-- Coming Soon Section -->
      <div style="margin: 32px 22px;">
        <Card>
          <div style="padding: 16px; text-align: center;">
            <p class="body-sm" style="color: var(--t2); margin-bottom: 8px;">
              📚 More features coming soon:
            </p>
            <ul style="list-style: none; padding: 0; margin: 0; font-size: 14px; color: var(--t2);">
              <li>📦 Containers management</li>
              <li>🧑‍🍳 Recipe suggestions</li>
              <li>🏠 Household sharing</li>
              <li>📊 Advanced analytics</li>
            </ul>
          </div>
        </Card>
      </div>
    </div>

    <!-- FAB -->
    <FAB icon="➕" label="Add item" href="/app/add" />

    <!-- Tab Bar -->
    <TabBar
      tabs={tabs}
      activeTab="dashboard"
    />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  /* Scroll reveal effect */
  .card, .insight {
    opacity: 0;
  }

  .card.revealed, .insight.revealed {
    animation: fadeInUp 0.5s var(--ease) forwards;
  }
</style>

<script>
  import { gql, queries } from '@/lib/graphql';
  import { getToken, initAuth, isAuthenticated } from '@/lib/auth';

  // Initialize auth and check if user is logged in
  initAuth();

  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  // Scroll reveal animation using Intersection Observer
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.card, .insight').forEach((el) => {
      observer.observe(el);
    });
  }

  // Fetch user data and items
  async function loadData() {
    try {
      // Fetch user profile
      const userDataQuery = `query { me { id email displayName defaultHouseholdId } }`;
      const userData = await gql(userDataQuery);
      const userId = userData.me.id;
      const householdId = userData.me.defaultHouseholdId;

      // If no default household, fetch first household
      if (!householdId) {
        const hhQuery = `query { myHouseholds { id } }`;
        const hhData = await gql(hhQuery);
        if (hhData.myHouseholds.length === 0) {
          console.warn('No households found');
          return;
        }
        householdId = hhData.myHouseholds[0].id;
      }

      // Fetch items for household
      const itemsQuery = `query ListItems($householdId: UUID!) { listItems(householdId: $householdId) { id foodName category status expiryAt } }`;
      const itemsData = await gql(itemsQuery, { householdId });

      // Get emoji for food type (simple mapping)
      const emojiMap: Record<string, string> = {
        vegetable: '🥦',
        fruit: '🍎',
        dairy: '🥛',
        bread: '🍞',
        meat: '🥩',
        frozen: '🧊',
        default: '📦',
      };

      // Update stats
      const fresh = itemsData.listItems.filter((i: any) => i.status === 'fresh').length;
      const soon = itemsData.listItems.filter((i: any) => i.status === 'soon').length;
      const urgent = itemsData.listItems.filter((i: any) => i.status === 'urgent').length;

      // Update stat cards
      const statCards = document.querySelectorAll('.hero-stats > div');
      if (statCards.length >= 3) {
        statCards[0].textContent = fresh.toString();
        statCards[1].textContent = soon.toString();
        statCards[2].textContent = urgent.toString();
      }

      // Update recent items
      const recentItems = itemsData.listItems.slice(0, 3);
      const itemsContainer = document.querySelector('[style*="padding: 0 22px"]');
      if (itemsContainer) {
        itemsContainer.innerHTML = recentItems
          .map(
            (item: any) =>
              `<div class="item-card" onclick="location.href='/app/items/${item.id}'" style="background: var(--raised); border-radius: var(--r-lg); margin-bottom: 10px; overflow: hidden; border: 1px solid var(--b1); display: flex; cursor: pointer; transition: transform 0.15s var(--quick), box-shadow 0.2s;">
                <div class="item-stripe ${item.status}" style="width: 4px; flex-shrink: 0; background: linear-gradient(180deg, #1F9956 0%, #34B86C 100%);"></div>
                <div style="flex: 1; padding: 14px 16px; display: flex; align-items: center; gap: 14px;">
                  <div style="width: 52px; height: 52px; border-radius: var(--r-md); background: var(--sunken); display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0;">
                    ${emojiMap[item.category?.toLowerCase()] || emojiMap.default}
                  </div>
                  <div style="flex: 1;">
                    <div style="font-size: 17px; font-weight: 700; color: var(--t1); margin-bottom: 3px;">${item.foodName}</div>
                    <div style="font-size: 13px; color: var(--t2);">${item.category}</div>
                  </div>
                </div>
              </div>`
          )
          .join('');
      }
    } catch (error) {
      console.error('Failed to load data:', error);
    }
  }

  // Load data on page load
  loadData();
</script>
