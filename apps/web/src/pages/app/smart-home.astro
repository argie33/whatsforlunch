---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const devices = [
  { id: '1', name: 'Main Fridge Temperature', type: 'Sensor', connected: true, temp: '38°F' },
  { id: '2', name: 'Smart Scale', type: 'Scale', connected: false },
];

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Smart Home — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Smart Home" subtitle={`${devices.filter((d) => d.connected).length} connected`} />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Connected Devices -->
        <p class="eyebrow" style="margin-bottom: 12px;">📱 Connected Devices</p>
        {devices.map((device) => (
          <Card key={device.id} style="margin-bottom: 10px;">
            <div style="padding: 14px; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">{device.name}</p>
                <p style="font-size: 12px; color: var(--t2); margin: 4px 0 0 0;">
                  {device.type} {device.temp && `• ${device.temp}`}
                </p>
              </div>
              <div
                style={`width: 12px; height: 12px; border-radius: 50%; ${device.connected ? 'background: var(--fresh);' : 'background: var(--expired);'}`}
              ></div>
            </div>
          </Card>
        ))}

        <!-- Add Device -->
        <Button variant="secondary" block onclick="alert('Add device')" style="margin-bottom: 24px;">
          🔗 Connect Device
        </Button>

        <!-- Available Integrations -->
        <p class="eyebrow" style="margin-bottom: 12px;">Integrations</p>
        <Card>
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 10px;">
            <button
              style="padding: 10px; background: transparent; border: none; text-align: left; cursor: pointer; font-family: inherit; font-size: 14px; color: var(--t1); border-bottom: 1px solid var(--b1);"
              onclick="alert('Connect to Alexa')"
            >
              🔊 Amazon Alexa
            </button>
            <button
              style="padding: 10px; background: transparent; border: none; text-align: left; cursor: pointer; font-family: inherit; font-size: 14px; color: var(--t1); border-bottom: 1px solid var(--b1);"
              onclick="alert('Connect to Google')"
            >
              🔵 Google Home
            </button>
            <button
              style="padding: 10px; background: transparent; border: none; text-align: left; cursor: pointer; font-family: inherit; font-size: 14px; color: var(--t1);"
              onclick="alert('Connect to HomeKit')"
            >
              🍎 HomeKit
            </button>
          </div>
        </Card>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  button:active {
    opacity: 0.7;
  }
</style>
