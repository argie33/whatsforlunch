---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Household — WhatsFresh">
  <main>
    <div class="scroll" id="householdScroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title" id="householdTitle">My Home</div>
        <a href="/app/household/invite" class="btn-icon" style="text-decoration:none;">+</a>
      </div>

      <!-- Summary card -->
      <div style="padding:0 22px 14px;">
        <div class="card" style="background:linear-gradient(135deg,var(--brand) 0%,var(--brand-light) 100%);color:white;border:none;padding:22px;">
          <div style="font-size:11px;font-weight:800;letter-spacing:2px;opacity:0.85;text-transform:uppercase;margin-bottom:8px;">🏠 Household</div>
          <div style="font-family:Fraunces,serif;font-size:28px;font-weight:800;letter-spacing:-0.6px;line-height:1;margin-bottom:6px;" id="householdName">My Home</div>
          <div style="font-size:14px;opacity:0.92;" id="householdStats">Loading members...</div>
        </div>
      </div>

      <!-- Members -->
      <div class="caption" style="padding:8px 22px 8px;">MEMBERS</div>
      <div style="padding:0 22px;" id="membersList">
        <div class="info-card">
          <div class="info-row">
            <div class="avatar">U</div>
            <div class="settings-content">
              <div class="settings-title">You · Owner</div>
              <div class="settings-sub">Loading...</div>
            </div>
            <div class="settings-value" style="background:var(--brand-soft);color:var(--brand);padding:4px 10px;border-radius:var(--r-full);font-size:11px;font-weight:700;">OWNER</div>
          </div>
        </div>
      </div>

      <!-- Invite button -->
      <div style="padding:14px 22px 40px;">
        <a href="/app/household/invite" class="btn btn-primary btn-block btn-lg" style="text-decoration:none;display:block;text-align:center;">+ Invite member</a>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  const avatarColors = [
    'linear-gradient(135deg,var(--coral) 0%,var(--honey) 100%)',
    'linear-gradient(135deg,var(--berry) 0%,var(--plum) 100%)',
    'linear-gradient(135deg,var(--sky) 0%,var(--brand) 100%)',
  ];

  async function loadHousehold() {
    try {
      const res = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          query: `query {
            me { name }
            household {
              id name
              members { id name role }
              items { id }
            }
          }`
        })
      });
      const { data } = await res.json();
      const household = data?.household;
      const me = data?.me;

      if (household) {
        const nameEl = document.getElementById('householdName');
        const titleEl = document.getElementById('householdTitle');
        const statsEl = document.getElementById('householdStats');
        if (nameEl) nameEl.textContent = household.name || 'My Home';
        if (titleEl) titleEl.textContent = household.name || 'My Home';
        const memberCount = household.members?.length || 1;
        const itemCount = household.items?.length || 0;
        if (statsEl) statsEl.textContent = `${memberCount} member${memberCount !== 1 ? 's' : ''} · ${itemCount} items shared`;

        const listEl = document.getElementById('membersList');
        if (listEl && household.members?.length) {
          listEl.innerHTML = `<div class="info-card">` + household.members.map((m: any, i: number) => `
            <div class="info-row">
              <div class="avatar" style="width:42px;height:42px;font-size:16px;${i > 0 ? 'background:' + avatarColors[(i-1) % avatarColors.length] : ''}">${(m.name || 'U')[0].toUpperCase()}</div>
              <div class="settings-content">
                <div class="settings-title">${m.name || 'Member'}${m.name === me?.name ? ' · Owner' : ''}</div>
                <div class="settings-sub">${m.role || 'Member'}</div>
              </div>
              ${m.name === me?.name ? '<div class="settings-value" style="background:var(--brand-soft);color:var(--brand);padding:4px 10px;border-radius:var(--r-full);font-size:11px;font-weight:700;">OWNER</div>' : '<span class="chevron">›</span>'}
            </div>`).join('') + `</div>`;
        }
      }
    } catch (_) {}
  }

  loadHousehold();
</script>
