---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Household — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Household" subtitle="Manage members" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Household Info -->
        <p class="eyebrow" style="margin-bottom: 12px;">🏠 Your Household</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <p style="font-size: 14px; color: var(--t2); margin: 0;">Name: <strong style="color: var(--t1);">My Home</strong></p>
          </div>
        </Card>

        <!-- Members -->
        <p class="eyebrow" style="margin-bottom: 12px;">Members</p>
        <div id="members-list" style="min-height: 100px;">
          <p style="color: var(--t2); text-align: center;">Loading members...</p>
        </div>

        <!-- Invite Button -->
        <Button variant="secondary" block onclick="location.href='/app/household/invite'" style="margin-bottom: 16px;">
          👥 Invite Member
        </Button>

        <!-- Household Settings -->
        <p class="eyebrow" style="margin-bottom: 12px;">Settings</p>
        <Button variant="ghost" block onclick="alert('Edit household')" style="margin-bottom: 8px;">
          ✏️ Edit Household
        </Button>
        <Button variant="ghost" block onclick="alert('Switch household')" style="margin-bottom: 8px;">
          🏘️ Switch Household
        </Button>
        <Button variant="ghost" block onclick="alert('Leave household')" style="color: var(--coral);">
          🚪 Leave Household
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  .member-card {
    background: var(--raised);
    border: 1px solid var(--b1);
    border-radius: var(--r-lg);
    padding: 14px;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
</style>

<script>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  async function loadHousehold() {
    const list = document.getElementById('members-list');

    try {
      const query = `query {
        getProfile { id }
        listHouseholds { id name }
      }`;

      const data = await gql(query);
      let householdId = data.listHouseholds?.[0]?.id;

      if (!householdId) {
        list.innerHTML = '<p style="color: var(--t2); text-align: center;">No household found</p>';
        return;
      }

      const membersQuery = `query ListMembers($householdId: ID!) {
        listHouseholdMembers(householdId: $householdId) {
          userId
          displayName
          role
          joinedAt
        }
      }`;

      const membersData = await gql(membersQuery, { householdId });
      const members = membersData.listHouseholdMembers || [];

      if (members.length === 0) {
        list.innerHTML = '<p style="color: var(--t2); text-align: center;">No members found</p>';
        return;
      }

      const html = members
        .map(
          (m) => `
        <div class="member-card">
          <div style="display: flex; gap: 12px; align-items: center;">
            <div style="font-size: 32px;">👤</div>
            <div>
              <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">${m.displayName || 'Member'}</p>
              <p style="font-size: 12px; color: var(--t2); margin: 0;">${m.role || 'Member'}</p>
            </div>
          </div>
        </div>
      `
        )
        .join('');

      list.innerHTML = html;
    } catch (error) {
      console.error('Failed to load household:', error);
      list.innerHTML = '<p style="color: var(--t2); text-align: center;">Failed to load household</p>';
    }
  }

  loadHousehold();
</script>
