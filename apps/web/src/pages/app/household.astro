---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const members = [
  { id: '1', name: 'You', emoji: '👤', role: 'Owner', status: 'active' },
  { id: '2', name: 'Sarah', emoji: '👩', role: 'Member', status: 'active' },
  { id: '3', name: 'John', emoji: '👨', role: 'Member', status: 'away' },
];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Household — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Household" subtitle={`${members.length} members`} />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Household Info -->
        <p class="eyebrow" style="margin-bottom: 12px;">🏠 Your Household</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <p style="font-size: 14px; color: var(--t2); margin: 0;">Name: <strong style="color: var(--t1);">My Home</strong></p>
          </div>
        </Card>

        <!-- Members -->
        <p class="eyebrow" style="margin-bottom: 12px;">Members</p>
        {members.map((member) => (
          <Card
            key={member.id}
            pressable
            style="margin-bottom: 10px; cursor: pointer;"
            onclick={`alert('View ${member.name} profile')`}
          >
            <div style="padding: 14px; display: flex; justify-content: space-between; align-items: center;">
              <div style="display: flex; gap: 12px; align-items: center;">
                <div style="font-size: 32px;">{member.emoji}</div>
                <div>
                  <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">{member.name}</p>
                  <p style="font-size: 12px; color: var(--t2); margin: 0;">
                    {member.role} • {member.status}
                  </p>
                </div>
              </div>
              {member.id !== '1' && (
                <button
                  style="background: transparent; border: none; font-size: 16px; cursor: pointer;"
                  onclick="alert('Menu')"
                >
                  ⋯
                </button>
              )}
            </div>
          </Card>
        ))}

        <!-- Invite Button -->
        <Button variant="secondary" block onclick="location.href='/app/household/invite'" style="margin-bottom: 16px;">
          👥 Invite Member
        </Button>

        <!-- Household Settings -->
        <p class="eyebrow" style="margin-bottom: 12px;">Settings</p>
        <Button variant="ghost" block onclick="alert('Edit household')" style="margin-bottom: 8px;">
          ✏️ Edit Household
        </Button>
        <Button variant="ghost" block onclick="alert('Switch household')" style="margin-bottom: 8px;">
          🏘️ Switch Household
        </Button>
        <Button variant="ghost" block onclick="alert('Leave household')" style="color: var(--coral);">
          🚪 Leave Household
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
