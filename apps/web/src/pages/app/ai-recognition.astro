---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="AI Recognition — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Identify Food" subtitle="Take a photo or upload" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Camera/Upload Options -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px;">
          <Card pressable style="cursor: pointer;" onclick="alert('Camera coming soon')">
            <div style="padding: 20px; text-align: center;">
              <div style="font-size: 40px; margin-bottom: 8px;">📷</div>
              <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">Take Photo</p>
            </div>
          </Card>
          <Card pressable style="cursor: pointer;" onclick="alert('Upload coming soon')">
            <div style="padding: 20px; text-align: center;">
              <div style="font-size: 40px; margin-bottom: 8px;">📁</div>
              <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">Upload</p>
            </div>
          </Card>
        </div>

        <!-- AI Result Example -->
        <p class="eyebrow" style="margin-bottom: 12px;">📊 ANALYSIS RESULT</p>

        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <div style="text-align: center; margin-bottom: 16px;">
              <div style="font-size: 64px; margin-bottom: 12px;">🥕</div>
              <h3 style="font-size: 20px; font-weight: 800; margin: 0 0 8px 0;">Carrots</h3>
              <p style="font-size: 13px; color: var(--t2); margin: 0;">Confidence: 96%</p>
            </div>

            <div style="background: var(--brand-soft); border-radius: var(--r-md); padding: 12px; margin-bottom: 16px; text-align: center;">
              <p style="font-size: 12px; color: var(--brand); font-weight: 600; margin: 0;">✓ High confidence — ready to add</p>
            </div>

            <div style="display: grid; gap: 8px;">
              <div>
                <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Category</p>
                <p style="font-size: 14px; margin: 0; color: var(--t1);">🥦 Vegetables</p>
              </div>
              <div>
                <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Typical Shelf Life</p>
                <p style="font-size: 14px; margin: 0; color: var(--t1);">3-4 weeks in fridge</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Action Buttons -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
          <Button variant="secondary" block onclick="alert('Try another')">
            Try Another
          </Button>
          <Button variant="primary" block onclick="location.href='/app/add'">
            Add Item
          </Button>
        </div>

        <div style="margin-top: 24px; padding: 20px; background: linear-gradient(135deg, var(--brand-soft) 0%, var(--brand-tint) 100%); border-radius: var(--r-lg); text-align: center;">
          <p style="color: var(--t2); margin: 0; font-size: 14px;">
            🤖 AI-powered food recognition coming soon!
          </p>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
