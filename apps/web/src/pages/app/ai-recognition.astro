---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="AI Recognition — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/dashboard" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Identify Food</div>
        <div style="width:44px"></div>
      </div>

      <!-- Camera/Upload Options -->
      <div style="padding:0 22px;margin-top:8px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;">
          <div class="metric-card" style="cursor:pointer;text-align:center;padding:20px;" onclick="alert('Camera coming soon')">
            <div style="font-size:40px;margin-bottom:8px;">📷</div>
            <div style="font-size:14px;font-weight:600;margin:0;color:var(--t1);">Take Photo</div>
          </div>
          <div class="metric-card" style="cursor:pointer;text-align:center;padding:20px;" onclick="alert('Upload coming soon')">
            <div style="font-size:40px;margin-bottom:8px;">📁</div>
            <div style="font-size:14px;font-weight:600;margin:0;color:var(--t1);">Upload</div>
          </div>
        </div>

        <!-- AI Result Example -->
        <div class="eyebrow" style="margin-bottom:12px;">📊 ANALYSIS RESULT</div>

        <div class="metric-card" style="margin-bottom:16px;padding:16px;">
          <div style="text-align:center;margin-bottom:16px;">
            <div style="font-size:64px;margin-bottom:12px;">🥕</div>
            <div style="font-size:20px;font-weight:800;margin:0 0 8px 0;">Carrots</div>
            <div style="font-size:13px;color:var(--t2);margin:0;">Confidence: 96%</div>
          </div>

          <div style="background:var(--brand-soft);border-radius:var(--r-md);padding:12px;margin-bottom:16px;text-align:center;">
            <div style="font-size:12px;color:var(--brand);font-weight:600;margin:0;">✓ High confidence — ready to add</div>
          </div>

          <div style="display:grid;gap:8px;">
            <div>
              <div style="font-size:11px;font-weight:800;color:var(--t2);text-transform:uppercase;margin:0 0 4px 0;letter-spacing:1.5px;">Category</div>
              <div style="font-size:14px;margin:0;color:var(--t1);">🥦 Vegetables</div>
            </div>
            <div>
              <div style="font-size:11px;font-weight:800;color:var(--t2);text-transform:uppercase;margin:0 0 4px 0;letter-spacing:1.5px;">Typical Shelf Life</div>
              <div style="font-size:14px;margin:0;color:var(--t1);">3-4 weeks in fridge</div>
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:24px;">
          <button class="btn btn-secondary btn-block" onclick="alert('Try another')">Try Another</button>
          <button class="btn btn-primary btn-block" onclick="location.href='/app/add'">Add Item</button>
        </div>

        <div style="padding:20px;background:linear-gradient(135deg,var(--brand-soft) 0%,var(--brand-tint) 100%);border-radius:var(--r-lg);text-align:center;margin-bottom:40px;">
          <div style="color:var(--t2);margin:0;font-size:14px;">🤖 AI-powered food recognition coming soon!</div>
        </div>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="items" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
