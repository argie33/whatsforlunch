---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tiers = [
  {
    name: 'Free',
    price: '$0',
    features: ['5 items per month', 'Basic analytics', 'Community recipes'],
    current: true,
  },
  {
    name: 'Plus',
    price: '$9.99',
    period: '/month',
    features: ['Unlimited items', 'Advanced analytics', 'AI photo recognition', 'Shopping list'],
    highlighted: true,
  },
  {
    name: 'Pro',
    price: '$19.99',
    period: '/month',
    features: ['Everything in Plus', 'Household premium', 'Voice assistant', 'Priority support'],
  },
];

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Upgrade — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Upgrade Plan" subtitle="Get more features" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        {tiers.map((tier) => (
          <Card
            key={tier.name}
            style={`margin-bottom: 12px; ${tier.highlighted ? 'border: 2px solid var(--brand); background: var(--brand-tint);' : ''}`}
          >
            <div style="padding: 16px;">
              <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 12px;">
                <div>
                  <h3 style="font-size: 17px; font-weight: 700; margin: 0; color: var(--t1);">{tier.name}</h3>
                  <p style="font-size: 13px; color: var(--t2); margin: 4px 0 0 0;">
                    <span style="font-size: 20px; font-weight: 700; color: var(--t1);">{tier.price}</span>
                    {tier.period && <span>{tier.period}</span>}
                  </p>
                </div>
                {tier.current && (
                  <div style="background: var(--fresh); color: white; padding: 4px 8px; border-radius: var(--r-full); font-size: 11px; font-weight: 600;">
                    Current
                  </div>
                )}
              </div>

              <ul style="list-style: none; padding: 0; margin: 12px 0; display: flex; flex-direction: column; gap: 8px;">
                {tier.features.map((feature) => (
                  <li key={feature} style="font-size: 13px; color: var(--t1);">
                    ✓ {feature}
                  </li>
                ))}
              </ul>

              {!tier.current && (
                <Button
                  variant={tier.highlighted ? 'primary' : 'secondary'}
                  block
                  onclick="alert(`Upgrade to ${tier.name}`)"
                >
                  {tier.highlighted ? 'Upgrade Now' : 'Select Plan'}
                </Button>
              )}
            </div>
          </Card>
        ))}

        <p style="font-size: 12px; color: var(--t2); margin: 16px 0 0 0; text-align: center;">
          7-day free trial. Cancel anytime.
        </p>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
