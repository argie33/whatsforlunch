---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Premium — WhatsFresh">
  <main class="paywall-screen">
    <div class="scroll no-tab no-status">

      <!-- Hero -->
      <div style="position:relative;background:linear-gradient(135deg,#6B5B95 0%,#C2185B 100%);padding:80px 24px 48px;color:white;">
        <a href="/app/settings" class="btn-icon glass" style="position:absolute;top:60px;left:16px;color:#444;text-decoration:none;">✕</a>
        <div style="text-align:center;">
          <div style="display:inline-block;padding:14px;background:rgba(255,255,255,0.15);border-radius:var(--r-full);backdrop-filter:blur(10px);">
            <div style="font-size:48px;">⭐</div>
          </div>
          <div class="caption" style="color:white;opacity:0.9;margin-top:18px;letter-spacing:2px;">PREMIUM</div>
          <div class="serif" style="font-size:36px;font-weight:800;margin-top:8px;line-height:1.1;">Unlock<br>everything</div>
          <div style="font-size:15px;opacity:0.92;margin-top:10px;">Get the full WhatsFresh experience</div>
        </div>
      </div>

      <div style="padding:24px 22px;">

        <!-- Features list -->
        <div class="info-card">
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:14px;flex:1;">
              <div style="width:36px;height:36px;border-radius:var(--r-full);background:var(--brand-soft);display:flex;align-items:center;justify-content:center;font-size:18px;">∞</div>
              <div>
                <div style="font-weight:700;font-size:14px;">Unlimited AI scans</div>
                <div style="font-size:12px;color:var(--t2);">Free: 50/mo · Premium: unlimited</div>
              </div>
            </div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:14px;flex:1;">
              <div style="width:36px;height:36px;border-radius:var(--r-full);background:var(--coral-soft);display:flex;align-items:center;justify-content:center;font-size:18px;">👨‍👩‍👧</div>
              <div>
                <div style="font-weight:700;font-size:14px;">Family sharing</div>
                <div style="font-size:12px;color:var(--t2);">Up to 6 members in a household</div>
              </div>
            </div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:14px;flex:1;">
              <div style="width:36px;height:36px;border-radius:var(--r-full);background:var(--honey-soft);display:flex;align-items:center;justify-content:center;font-size:18px;">📊</div>
              <div>
                <div style="font-weight:700;font-size:14px;">Advanced analytics</div>
                <div style="font-size:12px;color:var(--t2);">Cost trends, waste reports, exports</div>
              </div>
            </div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:14px;flex:1;">
              <div style="width:36px;height:36px;border-radius:var(--r-full);background:var(--berry-soft);display:flex;align-items:center;justify-content:center;font-size:18px;">📷</div>
              <div>
                <div style="font-weight:700;font-size:14px;">Receipt scanning</div>
                <div style="font-size:12px;color:var(--t2);">Auto-add 30+ items in seconds</div>
              </div>
            </div>
          </div>
          <div class="info-row">
            <div style="display:flex;align-items:center;gap:14px;flex:1;">
              <div style="width:36px;height:36px;border-radius:var(--r-full);background:var(--sky-soft);display:flex;align-items:center;justify-content:center;font-size:18px;">🥗</div>
              <div>
                <div style="font-weight:700;font-size:14px;">Diet plans + nutrition</div>
                <div style="font-size:12px;color:var(--t2);">Daily intake tracking, custom plans</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Plans -->
        <div style="margin-top:24px;display:grid;gap:10px;">
          <div style="position:relative;padding:18px;background:linear-gradient(135deg,#FFFAF0 0%,#FDF1D9 100%);border:2px solid var(--honey);border-radius:var(--r-md);cursor:pointer;">
            <div style="position:absolute;top:-10px;right:18px;background:var(--honey);color:white;padding:3px 10px;border-radius:var(--r-full);font-size:10px;font-weight:800;letter-spacing:0.5px;">BEST VALUE · SAVE 33%</div>
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <div>
                <div style="font-weight:800;font-size:16px;">Yearly</div>
                <div style="font-size:12px;color:var(--t2);margin-top:2px;">$39.99/year · $3.33/mo</div>
              </div>
              <div style="text-align:right;">
                <div style="font-family:Fraunces,serif;font-size:28px;font-weight:800;">$39.99</div>
                <div style="font-size:11px;color:var(--t3);text-decoration:line-through;">$59.88</div>
              </div>
            </div>
          </div>
          <div style="padding:18px;background:var(--raised);border:1px solid var(--b1);border-radius:var(--r-md);cursor:pointer;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <div>
                <div style="font-weight:700;font-size:15px;">Monthly</div>
                <div style="font-size:12px;color:var(--t2);">Cancel anytime</div>
              </div>
              <div style="font-family:Fraunces,serif;font-size:24px;font-weight:800;">$4.99</div>
            </div>
          </div>
        </div>

        <button class="btn btn-primary btn-block btn-lg" style="margin-top:18px;background:linear-gradient(135deg,var(--brand) 0%,var(--brand-light) 100%);">Start 7-day free trial</button>
        <p style="font-size:11px;color:var(--t3);text-align:center;margin-top:12px;">No charge until trial ends · Cancel anytime</p>

      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .paywall-screen {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 40px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }
</style>
