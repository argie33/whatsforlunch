---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Edit Profile — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Edit Profile" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Avatar -->
        <div style="text-align: center; margin-bottom: 24px;">
          <div
            style="width: 80px; height: 80px; border-radius: 50%; background: var(--brand); margin: 0 auto 12px; display: flex; align-items: center; justify-content: center; font-size: 40px; cursor: pointer;"
            onclick="alert('Change avatar')"
          >
            👤
          </div>
          <Button variant="secondary" onclick="alert('Change avatar')" style="font-size: 12px; padding: 8px 12px;">
            Change Photo
          </Button>
        </div>

        <!-- Form -->
        <Card>
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 14px;">
            <div>
              <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 13px;">
                Name
              </label>
              <input
                type="text"
                placeholder="Your name"
                defaultValue="Your Name"
                style="width: 100%; padding: 10px; border: 1px solid var(--b1); border-radius: var(--r-md); font-size: 14px; font-family: inherit; box-sizing: border-box;"
              />
            </div>

            <div>
              <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 13px;">
                Email
              </label>
              <input
                type="email"
                placeholder="your@email.com"
                defaultValue="your@email.com"
                style="width: 100%; padding: 10px; border: 1px solid var(--b1); border-radius: var(--r-md); font-size: 14px; font-family: inherit; box-sizing: border-box;"
              />
            </div>

            <div>
              <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 13px;">
                Bio
              </label>
              <textarea
                placeholder="Tell us about yourself..."
                style="width: 100%; padding: 10px; border: 1px solid var(--b1); border-radius: var(--r-md); font-size: 14px; font-family: inherit; box-sizing: border-box; min-height: 80px; resize: vertical;"
              ></textarea>
            </div>
          </div>
        </Card>

        <!-- Actions -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 16px;">
          <Button variant="secondary" block onclick="location.href='/app/profile'">
            Cancel
          </Button>
          <Button variant="primary" block onclick="location.href='/app/profile'">
            Save Changes
          </Button>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-soft);
  }
</style>
