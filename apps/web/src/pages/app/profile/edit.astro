---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Edit Profile — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/profile" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Edit Profile</div>
        <div style="width:44px"></div>
      </div>

      <div style="padding:0 22px;">
        <!-- Avatar -->
        <div style="text-align:center;margin-bottom:24px;padding-top:16px;">
          <div style="width:80px;height:80px;border-radius:50%;background:var(--brand);margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:40px;cursor:pointer;" onclick="alert('Change avatar')">
            👤
          </div>
          <button class="btn btn-secondary" style="font-size:12px;padding:8px 12px;" onclick="alert('Change avatar')">Change Photo</button>
        </div>

        <!-- Form -->
        <div class="metric-card" style="padding:16px;display:flex;flex-direction:column;gap:14px;margin-bottom:16px;">
          <div>
            <label style="display:block;font-weight:600;margin-bottom:6px;font-size:13px;">Name</label>
            <input id="profile-name-input" type="text" placeholder="Your name" value="Loading..." style="width:100%;padding:10px;border:1px solid var(--b1);border-radius:var(--r-md);font-size:14px;font-family:inherit;box-sizing:border-box;" />
          </div>

          <div>
            <label style="display:block;font-weight:600;margin-bottom:6px;font-size:13px;">Email</label>
            <input id="profile-email-input" type="email" placeholder="your@email.com" value="Loading..." disabled style="width:100%;padding:10px;border:1px solid var(--b1);border-radius:var(--r-md);font-size:14px;font-family:inherit;box-sizing:border-box;opacity:0.6;" />
          </div>

          <div>
            <label style="display:block;font-weight:600;margin-bottom:6px;font-size:13px;">Bio</label>
            <textarea id="profile-bio-input" placeholder="Tell us about yourself..." style="width:100%;padding:10px;border:1px solid var(--b1);border-radius:var(--r-md);font-size:14px;font-family:inherit;box-sizing:border-box;min-height:80px;resize:vertical;"></textarea>
          </div>
        </div>

        <!-- Actions -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:40px;">
          <button class="btn btn-secondary btn-block" onclick="location.href='/app/profile'">Cancel</button>
          <button id="save-btn" class="btn btn-primary btn-block">Save Changes</button>
        </div>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-soft);
  }
</style>

<script>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  async function loadProfile() {
    try {
      const query = `query {
        me {
          id
          email
          displayName
        }
      }`;

      const data = await gql(query);
      const user = data.me;

      document.getElementById('profile-name-input').value = user.displayName || '';
      document.getElementById('profile-email-input').value = user.email || '';
    } catch (error) {
      console.error('Failed to load profile:', error);
      alert('Failed to load profile');
    }
  }

  document.getElementById('save-btn')?.addEventListener('click', async () => {
    const nameInput = document.getElementById('profile-name-input');
    const saveBtn = document.getElementById('save-btn');

    if (!nameInput.value.trim()) {
      alert('Name cannot be empty');
      return;
    }

    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    try {
      alert('✓ Profile updated (backend mutation pending)');
      window.location.href = '/app/profile';
    } catch (error) {
      console.error('Failed to save profile:', error);
      alert('Failed to save profile');
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
    }
  });

  loadProfile();
</script>
