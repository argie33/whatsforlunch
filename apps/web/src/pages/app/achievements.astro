---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Achievements — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Achievements" subtitle="Track your progress" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <div id="achievements-list" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; min-height: 200px;">
          <p style="color: var(--t2); grid-column: 1 / -1; text-align: center;">Loading achievements...</p>
        </div>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }

  .achievement-card {
    background: var(--raised);
    border: 1px solid var(--b1);
    border-radius: var(--r-lg);
    padding: 16px;
    text-align: center;
    cursor: pointer;
    transition: transform 0.15s, opacity 0.2s;
  }

  .achievement-card.locked {
    opacity: 0.6;
  }

  .achievement-emoji {
    font-size: 40px;
    margin-bottom: 8px;
  }

  .achievement-card.locked .achievement-emoji {
    opacity: 0.5;
  }
</style>

<script>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  async function loadAchievements() {
    const list = document.getElementById('achievements-list');

    try {
      const query = `query { getAchievements { id name description unlocked progress total emoji } }`;
      const data = await gql(query);
      const achievements = data.getAchievements || [];

      if (achievements.length === 0) {
        list.innerHTML =
          '<p style="color: var(--t2); grid-column: 1 / -1; text-align: center;">No achievements yet. Get started!</p>';
        return;
      }

      const html = achievements
        .map(
          (a) => `
        <div class="achievement-card ${a.unlocked ? '' : 'locked'}">
          <div class="achievement-emoji">${a.emoji || '🏆'}</div>
          <h4 style="font-size: 13px; font-weight: 700; margin: 0 0 4px 0; color: var(--t1);">${a.name}</h4>
          <p style="font-size: 11px; color: var(--t2); margin: 0 0 8px 0;">${a.description}</p>
          ${a.total && a.progress ? `
            <div style="background: var(--bg); border-radius: 4px; height: 4px; overflow: hidden; margin-bottom: 4px;">
              <div style="height: 100%; width: ${(a.progress / a.total) * 100}%; background: linear-gradient(90deg, var(--brand) 0%, var(--brand-light) 100%);"></div>
            </div>
            <p style="font-size: 10px; color: var(--t2); margin: 0;">${a.progress}/${a.total}</p>
          ` : ''}
        </div>
      `
        )
        .join('');

      list.innerHTML = html;
    } catch (error) {
      console.error('Failed to load achievements:', error);
      list.innerHTML =
        '<p style="color: var(--t2); grid-column: 1 / -1; text-align: center;">Failed to load achievements</p>';
    }
  }

  loadAchievements();
</script>
