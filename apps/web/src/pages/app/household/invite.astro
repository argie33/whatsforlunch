---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Invite Member — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/household" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Invite Member</div>
        <div style="width:44px"></div>
      </div>

      <!-- Share Link -->
      <div style="padding:0 22px;">
        <div class="eyebrow" style="margin-bottom:12px;">📱 INVITE LINK</div>
        <div class="metric-card" style="padding:16px;margin-bottom:16px;">
          <div id="invite-link-container" style="background:var(--bg);border-radius:var(--r-md);padding:12px;margin-bottom:12px;word-break:break-all;">
            <code id="invite-link" style="font-size:12px;color:var(--t2);">Loading...</code>
          </div>
          <button id="copy-link-btn" class="btn btn-secondary btn-block">📋 Copy Link</button>
        </div>

        <!-- Share Methods -->
        <div class="eyebrow" style="margin-bottom:12px;">SHARE VIA</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:24px;">
          <button class="btn btn-secondary" onclick="alert('Share via SMS')">💬 SMS</button>
          <button class="btn btn-secondary" onclick="alert('Share via Email')">📧 Email</button>
          <button class="btn btn-secondary" onclick="alert('Share via Whatsapp')">💚 WhatsApp</button>
          <button class="btn btn-secondary" onclick="alert('More options')">⋯ More</button>
        </div>

        <!-- QR Code -->
        <div class="eyebrow" style="margin-bottom:12px;">🎫 QR CODE</div>
        <div class="metric-card" style="text-align:center;padding:20px;margin-bottom:16px;">
          <div style="width:200px;height:200px;background:var(--raised);border:2px solid var(--b1);border-radius:var(--r-lg);margin:0 auto;display:flex;align-items:center;justify-content:center;color:var(--t2);">
            QR Code here
          </div>
        </div>

        <!-- Pending Invites -->
        <div class="eyebrow" style="margin-bottom:12px;">PENDING INVITES</div>
        <div class="metric-card" style="padding:16px;text-align:center;margin-bottom:40px;">
          <div style="color:var(--t2);margin:0;font-size:14px;">No pending invites</div>
        </div>
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  import { gql } from '@/lib/graphql';
  import { initAuth, isAuthenticated } from '@/lib/auth';

  initAuth();
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  }

  async function loadInvite() {
    try {
      const userQuery = `query { getProfile { id } listHouseholds { id } }`;
      const userData = await gql(userQuery);

      let householdId = userData.listHouseholds?.[0]?.id;
      let inviteCode = null;

      if (householdId) {
        inviteCode = householdId.slice(0, 8);
      }

      if (!inviteCode) {
        inviteCode = 'xyz123abc';
      }

      const inviteLink = `${window.location.origin}/join/${inviteCode}`;
      document.getElementById('invite-link').textContent = inviteLink;

      document.getElementById('copy-link-btn').addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(inviteLink);
          const btn = document.getElementById('copy-link-btn');
          const original = btn.textContent;
          btn.textContent = '✓ Copied!';
          setTimeout(() => {
            btn.textContent = original;
          }, 2000);
        } catch (error) {
          alert('Failed to copy to clipboard');
        }
      });
    } catch (error) {
      console.error('Failed to load invite:', error);
      document.getElementById('invite-link').textContent = 'whatsfresh.app/join/xyz123abc';
    }
  }

  loadInvite();
</script>
