---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Invite Member — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Invite Member" subtitle="Share your household" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Share Link -->
        <p class="eyebrow" style="margin-bottom: 12px;">📱 Invite Link</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px;">
            <div style="background: var(--bg); border-radius: var(--r-md); padding: 12px; margin-bottom: 12px; word-break: break-all;">
              <code style="font-size: 12px; color: var(--t2);">whatsfresh.app/join/xyz123abc</code>
            </div>
            <Button variant="secondary" block onclick="alert('Copied to clipboard')">
              📋 Copy Link
            </Button>
          </div>
        </Card>

        <!-- Share Methods -->
        <p class="eyebrow" style="margin-bottom: 12px;">Share Via</p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 24px;">
          <Button variant="secondary" block onclick="alert('Share via SMS')">
            💬 SMS
          </Button>
          <Button variant="secondary" block onclick="alert('Share via Email')">
            📧 Email
          </Button>
          <Button variant="secondary" block onclick="alert('Share via Whatsapp')">
            💚 WhatsApp
          </Button>
          <Button variant="secondary" block onclick="alert('More options')">
            ⋯ More
          </Button>
        </div>

        <!-- QR Code -->
        <p class="eyebrow" style="margin-bottom: 12px;">🎫 QR Code</p>
        <Card style="text-align: center; margin-bottom: 16px;">
          <div style="padding: 20px;">
            <div
              style="width: 200px; height: 200px; background: var(--raised); border: 2px solid var(--b1); border-radius: var(--r-lg); margin: 0 auto; display: flex; align-items: center; justify-content: center; color: var(--t2);"
            >
              QR Code here
            </div>
          </div>
        </Card>

        <!-- Pending Invites -->
        <p class="eyebrow" style="margin-bottom: 12px;">Pending Invites</p>
        <Card>
          <div style="padding: 16px; text-align: center;">
            <p style="color: var(--t2); margin: 0; font-size: 14px;">No pending invites</p>
          </div>
        </Card>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
