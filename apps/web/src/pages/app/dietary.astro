---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];

const dietary = [
  { id: '1', label: 'Vegetarian', icon: '🥕' },
  { id: '2', label: 'Vegan', icon: '🥬' },
  { id: '3', label: 'Gluten-free', icon: '🌾' },
  { id: '4', label: 'Dairy-free', icon: '🥛' },
  { id: '5', label: 'Nut Allergy', icon: '🥜' },
  { id: '6', label: 'Shellfish Allergy', icon: '🦐' },
];
---

<BaseLayout title="Dietary Restrictions — WhatsFresh">
  <main>
    <div class="scroll">

      <!-- Back bar -->
      <div class="back-bar" style="padding-top:28px;">
        <a href="/app/settings" class="btn-icon" style="text-decoration:none;">←</a>
        <div class="back-title">Dietary Preferences</div>
        <div style="width:44px"></div>
      </div>

      <!-- Dietary options -->
      <div class="settings-section" style="margin:16px 22px;">
        {dietary.map((item) => (
          <div key={item.id} class="settings-row" style={item.id !== '6' ? 'border-bottom:1px solid var(--b1);' : ''}>
            <div style="flex:1;">
              <div style="display:flex;align-items:center;gap:12px;">
                <span style="font-size:20px;">{item.icon}</span>
                <div class="settings-title">{item.label}</div>
              </div>
            </div>
            <button class="toggle" onclick="toggleItem(this)"></button>
          </div>
        ))}
      </div>

      <div style="padding:0 22px 40px;text-align:center;font-size:12px;color:var(--t2);">
        These preferences help personalize recipe suggestions for your needs
      </div>

    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function toggleItem(el: HTMLElement) {
    (el as HTMLButtonElement).classList.toggle('on');
  }

  (window as any).toggleItem = toggleItem;
</script>
