---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];

const dietary = [
  { id: '1', label: 'Vegetarian', icon: '🥕', checked: false },
  { id: '2', label: 'Vegan', icon: '🥬', checked: false },
  { id: '3', label: 'Gluten-free', icon: '🌾', checked: false },
  { id: '4', label: 'Dairy-free', icon: '🥛', checked: false },
  { id: '5', label: 'Nut Allergy', icon: '🥜', checked: false },
  { id: '6', label: 'Shellfish Allergy', icon: '🦐', checked: false },
];
---

<BaseLayout title="Dietary Restrictions — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Dietary Restrictions" subtitle="Customize recipe suggestions" />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <Card>
          <div style="padding: 16px; display: flex; flex-direction: column; gap: 12px;">
            {dietary.map((item) => (
              <label key={item.id} style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <input
                  type="checkbox"
                  defaultChecked={item.checked}
                  style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--brand);"
                />
                <span style="font-size: 20px;">{item.icon}</span>
                <span style="font-size: 14px; color: var(--t1);">{item.label}</span>
              </label>
            ))}
          </div>
        </Card>

        <p style="font-size: 12px; color: var(--t2); margin: 16px 0 0 0; text-align: center;">
          These preferences will be used to personalize recipe suggestions
        </p>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="settings" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
