---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import TabBar from '@/components/TabBar.astro';
import Card from '@/components/Card.astro';
import Button from '@/components/Button.astro';

const friends = [
  { id: '1', name: 'Sarah', emoji: '👩', waste: '2.4 lbs', streak: 12 },
  { id: '2', name: 'John', emoji: '👨', waste: '3.1 lbs', streak: 8 },
  { id: '3', name: 'Emma', emoji: '👩‍🦰', waste: '1.8 lbs', streak: 15 },
];

const tabs = [
  { id: 'dashboard', label: 'Dashboard', icon: '📊', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '🛒', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '👨‍🍳', href: '/app/recipes' },
  { id: 'analytics', label: 'Analytics', icon: '📈', href: '/app/analytics' },
  { id: 'settings', label: 'Settings', icon: '⚙️', href: '/app/settings' },
];
---

<BaseLayout title="Friends — WhatsFresh">
  <main style="display: flex; flex-direction: column; height: 100vh; background: var(--bg);">
    <TopBar title="Friends & Leaderboard" subtitle={`${friends.length} friends`} />

    <div style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 80px; -webkit-overflow-scrolling: touch;">
      <div style="padding: 16px 22px;">
        <!-- Your Stats -->
        <p class="eyebrow" style="margin-bottom: 12px;">🏆 Your Stats</p>
        <Card style="margin-bottom: 16px;">
          <div style="padding: 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; text-align: center;">
            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Waste</p>
              <p style="font-size: 20px; font-weight: 700; margin: 0; color: var(--fresh);">1.2 lbs</p>
            </div>
            <div>
              <p style="font-size: 11px; font-weight: 800; color: var(--t2); text-transform: uppercase; margin: 0 0 4px 0; letter-spacing: 1.5px;">Streak</p>
              <p style="font-size: 20px; font-weight: 700; margin: 0; color: var(--brand);">7 days</p>
            </div>
          </div>
        </Card>

        <!-- Leaderboard -->
        <p class="eyebrow" style="margin-bottom: 12px;">Leaderboard</p>
        {friends.map((friend, index) => (
          <Card
            key={friend.id}
            pressable
            style="margin-bottom: 10px; cursor: pointer;"
            onclick={`alert('View ${friend.name} profile')`}
          >
            <div style="padding: 14px; display: flex; align-items: center; gap: 12px;">
              <div
                style="width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, var(--brand) 0%, var(--brand-light) 100%); display: flex; align-items: center; justify-content: center; font-weight: 700; color: white;"
              >
                {index + 1}
              </div>
              <div style="font-size: 24px;">{friend.emoji}</div>
              <div style="flex: 1;">
                <p style="font-size: 14px; font-weight: 600; margin: 0; color: var(--t1);">{friend.name}</p>
                <p style="font-size: 12px; color: var(--t2); margin: 0;">Waste: {friend.waste}</p>
              </div>
              <div style="text-align: right;">
                <p style="font-size: 12px; font-weight: 700; margin: 0 0 2px 0; color: var(--coral);">🔥 {friend.streak}</p>
              </div>
            </div>
          </Card>
        ))}

        <!-- Add Friends -->
        <Button variant="secondary" block onclick="alert('Add friends')" style="margin-top: 16px;">
          👥 Add Friend
        </Button>
      </div>
    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
  }
</style>
