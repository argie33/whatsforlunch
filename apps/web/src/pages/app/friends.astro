---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TabBar from '@/components/TabBar.astro';

const tabs = [
  { id: 'dashboard', label: 'Home', icon: '🏠', href: '/app/dashboard' },
  { id: 'items', label: 'Items', icon: '📦', href: '/app/items' },
  { id: 'recipes', label: 'Recipes', icon: '🍽', href: '/app/recipes' },
  { id: 'settings', label: 'More', icon: '👤', href: '/app/settings' },
];
---

<BaseLayout title="Friends — WhatsFresh">
  <main>
    <div class="scroll" id="friendsScroll">

      <!-- Top bar -->
      <div class="topbar" id="topbarFriends">
        <div class="topbar-title">
          <div class="caption" style="color:var(--t2);">Community</div>
          <div class="h2 serif">Friends</div>
        </div>
        <div class="topbar-actions">
          <button class="btn-icon" onclick="alert('Add friend')">+</button>
          <button class="btn-icon" onclick="alert('Find friends')">🔍</button>
        </div>
      </div>

      <!-- Stories row -->
      <div style="padding:8px 16px;">
        <div style="display:flex;gap:12px;overflow-x:auto;padding:8px 0;scrollbar-width:none;">
          <div style="text-align:center;flex-shrink:0;">
            <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--coral),var(--honey));padding:3px;">
              <div style="width:100%;height:100%;border-radius:50%;background:white;padding:3px;display:flex;align-items:center;justify-content:center;font-size:28px;box-sizing:border-box;">+</div>
            </div>
            <div style="font-size:11px;font-weight:600;margin-top:4px;">You</div>
          </div>
          <div style="text-align:center;flex-shrink:0;">
            <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--brand-glow),var(--sky));padding:3px;">
              <div style="width:100%;height:100%;border-radius:50%;background:var(--brand-soft);display:flex;align-items:center;justify-content:center;font-size:24px;">A</div>
            </div>
            <div style="font-size:11px;font-weight:600;margin-top:4px;">Alex</div>
          </div>
          <div style="text-align:center;flex-shrink:0;">
            <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--berry),var(--plum));padding:3px;">
              <div style="width:100%;height:100%;border-radius:50%;background:var(--berry-soft);display:flex;align-items:center;justify-content:center;font-size:24px;">M</div>
            </div>
            <div style="font-size:11px;font-weight:600;margin-top:4px;">Maya</div>
          </div>
          <div style="text-align:center;flex-shrink:0;">
            <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--honey),var(--coral));padding:3px;">
              <div style="width:100%;height:100%;border-radius:50%;background:var(--honey-soft);display:flex;align-items:center;justify-content:center;font-size:24px;">J</div>
            </div>
            <div style="font-size:11px;font-weight:600;margin-top:4px;">Jess</div>
          </div>
        </div>
      </div>

      <!-- Feed posts -->
      <div style="padding:0 16px;">

        <div class="card" style="padding:0;overflow:hidden;margin-bottom:14px;">
          <div style="padding:12px 14px;display:flex;align-items:center;gap:10px;">
            <div class="avatar" style="background:var(--brand-soft);color:var(--brand);">A</div>
            <div style="flex:1;">
              <div style="font-weight:700;font-size:13px;">Alex Chen</div>
              <div style="font-size:11px;color:var(--t3);">Made a recipe · 12m ago</div>
            </div>
            <button class="btn-icon">⋯</button>
          </div>
          <div style="height:200px;background:linear-gradient(135deg,var(--coral-soft),var(--honey-soft));display:flex;align-items:center;justify-content:center;font-size:96px;">🍝</div>
          <div style="padding:14px;">
            <div style="font-family:Fraunces,serif;font-weight:700;font-size:16px;">Garlic spinach pasta</div>
            <div style="font-size:13px;color:var(--t2);margin-top:4px;">"Used the spinach before it went bad! 5★"</div>
            <div style="display:flex;align-items:center;gap:14px;margin-top:10px;">
              <button style="background:none;border:none;font-size:18px;cursor:pointer;">❤️ 24</button>
              <button style="background:none;border:none;font-size:14px;color:var(--t2);cursor:pointer;">💬 3 comments</button>
              <div style="flex:1;"></div>
              <a href="/app/recipes" class="btn-ghost" style="font-size:12px;color:var(--brand);font-weight:700;text-decoration:none;">Try it →</a>
            </div>
          </div>
        </div>

        <div class="card" style="padding:0;overflow:hidden;margin-bottom:14px;">
          <div style="padding:12px 14px;display:flex;align-items:center;gap:10px;">
            <div class="avatar" style="background:var(--berry-soft);color:var(--berry);">M</div>
            <div style="flex:1;">
              <div style="font-weight:700;font-size:13px;">Maya Patel</div>
              <div style="font-size:11px;color:var(--t3);">Hit a streak · 2h ago</div>
            </div>
            <button class="btn-icon">⋯</button>
          </div>
          <div style="padding:14px;">
            <div style="font-family:Fraunces,serif;font-weight:700;font-size:18px;">🔥 21-day streak!</div>
            <div style="font-size:13px;color:var(--t2);margin-top:4px;">Zero food waste for 3 weeks straight. Let's gooo!</div>
            <div style="display:flex;align-items:center;gap:14px;margin-top:10px;">
              <button style="background:none;border:none;font-size:18px;cursor:pointer;">🎉 48</button>
              <button style="background:none;border:none;font-size:14px;color:var(--t2);cursor:pointer;">💬 7 comments</button>
            </div>
          </div>
        </div>

      </div>
    </div>

    <TabBar tabs={tabs} activeTab="dashboard" />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', system-ui, sans-serif;
    position: relative;
  }

  .scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 100px;
    -webkit-overflow-scrolling: touch;
  }

  .scroll::-webkit-scrollbar { display: none; }

  .topbar { padding-top: 20px; }
</style>

<script>
  const scroll = document.getElementById('friendsScroll');
  const topbar = document.getElementById('topbarFriends');
  scroll?.addEventListener('scroll', () => {
    if ((scroll.scrollTop || 0) > 10) topbar?.classList.add('scrolled');
    else topbar?.classList.remove('scrolled');
  });
</script>
