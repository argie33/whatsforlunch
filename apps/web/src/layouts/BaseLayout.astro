---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'WhatsForLunch — Stop wasting food.',
  description = 'Track everything in your kitchen. Get reminded before food expires. Cook smart with what you already have.',
  ogImage = '/og-image.svg',
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="WhatsForLunch" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Schema.org structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MobileApplication",
      "name": "WhatsForLunch",
      "description": description,
      "operatingSystem": "iOS, Android",
      "applicationCategory": "LifestyleApplication",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "url": "https://whatsforlunch.app",
    })} />

    <!-- Smart App Banner (iOS Safari) -->
    <meta name="apple-itunes-app" content="app-id=XXXXXXXX" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts: system stack, no external requests -->
  </head>
  <body class="bg-surface text-gray-900 antialiased">
    <slot />
  </body>
</html>
