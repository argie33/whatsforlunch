---
interface Props {
  icon: string;
  label?: string;
  onClick?: string;
  href?: string;
  class?: string;
}

const { icon, label, onClick, href, class: className = '' } = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class={`fab ${className}`}
  href={href}
  onclick={onClick}
  aria-label={label}
>
  {icon}
</Tag>

<style>
  a.fab {
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
