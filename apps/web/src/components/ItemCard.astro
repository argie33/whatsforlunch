---
interface Props {
  name: string;
  emoji: string;
  status: 'fresh' | 'soon' | 'urgent' | 'expired';
  days?: number;
  container?: string;
  onClick?: string;
  id?: string;
  class?: string;
}

const { name, emoji, status, days, container, onClick, id, class: className = '' } = Astro.props;

const statusText = {
  fresh: 'Fresh',
  soon: 'Using soon',
  urgent: 'Use today',
  expired: 'Expired',
};
---

<div
  class={`item-card ${className}`}
  id={id}
  data-status={status}
  onclick={onClick}
>
  <div class={`item-stripe ${status}`}></div>
  <div class="item-content">
    <div class={`item-icon ${status}`}>{emoji}</div>
    <div class="item-info">
      <div class="item-name">{name}</div>
      <div class="item-meta">
        {container && (
          <>
            <span>{container}</span>
            <div class="dot"></div>
          </>
        )}
        {days !== undefined && <span>{days}d</span>}
      </div>
    </div>
  </div>
  <div class={`item-badge ${status}`}>{statusText[status]}</div>
</div>

<style>
  .item-card {
    padding-right: 12px;
  }
</style>
