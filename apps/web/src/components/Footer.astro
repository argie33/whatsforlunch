---
const year = new Date().getFullYear();
---
<footer class="bg-gray-900 text-gray-400 py-14 px-6">
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col md:flex-row justify-between gap-10 mb-10">
      <!-- Brand -->
      <div class="max-w-xs">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-xl bg-brand flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="5" y="2" width="14" height="20" rx="3" fill="white" fill-opacity="0.9"/>
              <rect x="5" y="2" width="14" height="9" rx="3" fill="white"/>
              <rect x="5" y="10" width="14" height="1" fill="white" fill-opacity="0.3"/>
              <circle cx="9" cy="6" r="1" fill="#E85C38"/>
              <circle cx="13" cy="6" r="1" fill="#E8A838"/>
              <circle cx="9" cy="15" r="1" fill="#2F7D5B"/>
            </svg>
          </div>
          <span class="text-white font-bold text-base">WhatsForLunch</span>
        </div>
        <p class="text-sm leading-relaxed">
          Track food. Reduce waste. Cook smarter.
        </p>
      </div>

      <!-- Links -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 text-sm">
        <div>
          <h3 class="text-white font-semibold mb-3">Product</h3>
          <ul class="space-y-2">
            <li><a href="/#features" class="hover:text-white transition-colors">Features</a></li>
            <li><a href="/#faq" class="hover:text-white transition-colors">FAQ</a></li>
            <li><a href="/support" class="hover:text-white transition-colors">Support</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-white font-semibold mb-3">Download</h3>
          <ul class="space-y-2">
            <li>
              <a href="https://apps.apple.com/app/id000000000" class="hover:text-white transition-colors" aria-label="Download on the App Store">
                App Store
              </a>
            </li>
            <li>
              <a href="https://play.google.com/store/apps/details?id=app.whatsforlunch.mobile" class="hover:text-white transition-colors" aria-label="Get it on Google Play">
                Google Play
              </a>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-white font-semibold mb-3">Legal</h3>
          <ul class="space-y-2">
            <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
            <li><a href="/terms" class="hover:text-white transition-colors">Terms of Service</a></li>
            <li><a href="/press" class="hover:text-white transition-colors">Press Kit</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm">
      <p>&copy; {year} WhatsForLunch. All rights reserved.</p>
      <p>
        Made with care ·{' '}
        <a href="mailto:support@whatsforlunch.app" class="hover:text-white transition-colors">
          support@whatsforlunch.app
        </a>
      </p>
    </div>
  </div>
</footer>
