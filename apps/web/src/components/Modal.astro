---
interface Props {
  title?: string;
  visible?: boolean;
  onClose?: string;
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const {
  title,
  visible = true,
  onClose,
  class: className = '',
  size = 'md',
} = Astro.props;

const sizeClass = {
  sm: 'max-w-sm',
  md: 'max-w-md',
  lg: 'max-w-lg',
}[size];
---

{
  visible && (
    <div class="modal-overlay" onclick={onClose}>
      <div
        class={`modal-content ${sizeClass} ${className}`}
        onclick="event.stopPropagation()"
      >
        {title && <h2 class="modal-title">{title}</h2>}
        <slot />
      </div>
    </div>
  )
}

<style>
  div {
    animation: fadeIn 0.2s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
