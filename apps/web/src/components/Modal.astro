---
interface Props {
  title?: string;
  visible?: boolean;
  onClose?: string;
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const {
  title,
  visible = true,
  onClose,
  class: className = '',
  size = 'md',
} = Astro.props;

const sizeClass = {
  sm: 'max-w-sm',
  md: 'max-w-md',
  lg: 'max-w-lg',
}[size];
---

{
  visible && (
    <div style="position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 50;" onclick={onClose}>
      <div
        class={`bg-white rounded-2xl shadow-lg ${sizeClass} ${className} p-6 max-h-96 overflow-y-auto`}
        onclick="event.stopPropagation()"
      >
        {title && <h2 style="font-size: 20px; font-weight: 700; margin: 0 0 16px 0; color: var(--t1);">{title}</h2>}
        <slot />
      </div>
    </div>
  )
}

<style>
  div {
    animation: fadeIn 0.2s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
