---
interface Props {
  title: string;
  subtitle?: string;
  actions?: Array<{
    icon: string;
    label: string;
    onClick?: string;
  }>;
  class?: string;
  scrolled?: boolean;
}

const { title, subtitle, actions = [], class: className = '', scrolled = false } = Astro.props;
---

<div class={`topbar ${scrolled ? 'scrolled' : ''} ${className}`}>
  <div class="topbar-title">
    <h1 style="font-size: 20px; font-weight: 700; margin: 0;">{title}</h1>
    {subtitle && (
      <p style="font-size: 13px; color: var(--t2); margin: 0;">{subtitle}</p>
    )}
  </div>
  {actions.length > 0 && (
    <div class="topbar-actions">
      {actions.map((action) => (
        <button
          class="btn-icon"
          onclick={action.onClick}
          aria-label={action.label}
        >
          {action.icon}
        </button>
      ))}
    </div>
  )}
</div>

<style>
  .topbar {
    width: 100%;
  }
</style>
