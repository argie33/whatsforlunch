---
interface Props {
  value: number;
  max?: number;
  label?: string;
  showLabel?: boolean;
  color?: 'brand' | 'fresh' | 'soon' | 'urgent';
  size?: 'sm' | 'md' | 'lg';
  animated?: boolean;
  class?: string;
}

const {
  value,
  max = 100,
  label,
  showLabel = false,
  color = 'brand',
  size = 'md',
  animated = true,
  class: className = '',
} = Astro.props;

const percentage = Math.min((value / max) * 100, 100);

const colors = {
  brand: 'var(--brand)',
  fresh: 'var(--fresh)',
  soon: 'var(--soon)',
  urgent: 'var(--urgent)',
};

const sizes = {
  sm: { height: '4px', borderRadius: '2px' },
  md: { height: '8px', borderRadius: '4px' },
  lg: { height: '12px', borderRadius: '6px' },
};

const sizeStyle = sizes[size];
const colorValue = colors[color];
---

<div class={`progress-wrapper ${className}`}>
  {showLabel && label && (
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
      <label style="font-size: 13px; font-weight: 500; color: var(--t1);">{label}</label>
      <span style="font-size: 12px; color: var(--t2);">{Math.round(percentage)}%</span>
    </div>
  )}
  <div
    style={`
      width: 100%;
      height: ${sizeStyle.height};
      border-radius: ${sizeStyle.borderRadius};
      background-color: var(--sunken);
      overflow: hidden;
      position: relative;
    `}
  >
    <div
      class={`progress-bar ${animated ? 'animated' : ''}`}
      style={`
        width: ${percentage}%;
        height: 100%;
        background-color: ${colorValue};
        border-radius: ${sizeStyle.borderRadius};
        transition: width 0.3s ease;
      `}
    />
  </div>
</div>

<style>
  .progress-bar.animated {
    background-image: linear-gradient(90deg, var(--brand), var(--brand-light), var(--brand));
    background-size: 200% 100%;
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
</style>
