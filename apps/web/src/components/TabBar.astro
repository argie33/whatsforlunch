---
interface Tab {
  id: string;
  label: string;
  icon: string;
  href: string;
  active?: boolean;
}

interface Props {
  tabs: Tab[];
  activeTab?: string;
  showScan?: boolean;
  class?: string;
}

const { tabs, activeTab, showScan = true, class: className = '' } = Astro.props;
---

<nav class={`tab-bar ${className}`} aria-label="Main navigation">
  {tabs.slice(0, 2).map((tab) => (
    <a
      href={tab.href}
      class={`tab-item ${activeTab === tab.id ? 'active' : ''}`}
      data-tab={tab.id}
    >
      <div class="tab-icon">{tab.icon}</div>
      <div class="tab-label">{tab.label}</div>
    </a>
  ))}

  {showScan && (
    <div class="tab-action">
      <a href="/app/scan" class="tab-scan" aria-label="Scan">📷</a>
    </div>
  )}

  {tabs.slice(2).map((tab) => (
    <a
      href={tab.href}
      class={`tab-item ${activeTab === tab.id ? 'active' : ''}`}
      data-tab={tab.id}
    >
      <div class="tab-icon">{tab.icon}</div>
      <div class="tab-label">{tab.label}</div>
    </a>
  ))}
</nav>

<style>
  .tab-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 88px;
    padding: 8px 0 28px;
    background: rgba(250, 246, 238, 0.88);
    backdrop-filter: blur(24px) saturate(1.5);
    -webkit-backdrop-filter: blur(24px) saturate(1.5);
    border-top: 0.5px solid var(--b1);
    display: flex;
    align-items: center;
    z-index: 20;
  }

  .tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    text-decoration: none;
    color: var(--t3);
    transition: color 0.2s;
    padding: 4px;
    position: relative;
  }

  .tab-item.active {
    color: var(--brand);
  }

  .tab-item.active::before {
    content: '';
    position: absolute;
    top: 0;
    width: 32px;
    height: 3px;
    background: var(--brand);
    border-radius: 0 0 4px 4px;
  }

  .tab-item.active .tab-icon {
    transform: scale(1.1);
  }

  .tab-icon {
    font-size: 24px;
    line-height: 1;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .tab-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Center scan action */
  .tab-action {
    flex: 0 0 60px;
    position: relative;
    margin-top: -28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tab-scan {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--brand) 0%, var(--brand-light) 100%);
    color: white;
    border: 4px solid rgba(250, 246, 238, 0.9);
    cursor: pointer;
    font-size: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--s-glow);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    text-decoration: none;
  }

  .tab-scan:active {
    transform: scale(0.92);
  }
</style>
