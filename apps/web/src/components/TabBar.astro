---
interface Tab {
  id: string;
  label: string;
  icon: string;
  href: string;
  active?: boolean;
}

interface Props {
  tabs: Tab[];
  activeTab?: string;
  class?: string;
}

const { tabs, activeTab, class: className = '' } = Astro.props;
---

<nav class={`tab-bar ${className}`} aria-label="Main navigation">
  {tabs.map((tab) => (
    <a
      href={tab.href}
      class={`tab-item ${activeTab === tab.id ? 'active' : ''}`}
      data-tab={tab.id}
    >
      <div class="tab-icon">{tab.icon}</div>
      <div class="tab-label">{tab.label}</div>
    </a>
  ))}
</nav>

<style>
  .tab-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-around;
    align-items: stretch;
    background: var(--raised);
    border-top: 1px solid var(--b1);
    z-index: 20;
    padding-bottom: env(safe-area-inset-bottom);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 8px 12px;
    min-height: 60px;
    text-decoration: none;
    color: var(--t2);
    transition: color 0.2s;
  }

  .tab-item.active {
    color: var(--brand);
  }

  .tab-icon {
    font-size: 24px;
  }

  .tab-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
</style>
