---
interface Props {
  message: string;
  type?: 'success' | 'error' | 'info' | 'warning';
  duration?: number;
  visible?: boolean;
  onClose?: string;
}

const {
  message,
  type = 'info',
  duration = 3000,
  visible = true,
  onClose,
} = Astro.props;

const bgColor = {
  success: 'var(--fresh-bg)',
  error: 'var(--urgent-bg)',
  info: 'var(--sky-soft)',
  warning: 'var(--soon-bg)',
}[type];

const textColor = {
  success: 'var(--fresh)',
  error: 'var(--urgent)',
  info: 'var(--sky)',
  warning: 'var(--soon)',
}[type];

const icon = {
  success: '✓',
  error: '✕',
  info: 'ℹ',
  warning: '⚠',
}[type];
---

{
  visible && (
    <div
      style={`position: fixed; bottom: 100px; left: 22px; right: 22px; background: ${bgColor}; color: ${textColor}; padding: 16px; border-radius: var(--r-md); display: flex; align-items: center; gap: 12px; z-index: 40; animation: slideUp 0.3s ease-out;`}
      role="alert"
    >
      <span style="font-size: 18px; font-weight: 700;">{icon}</span>
      <span style="font-size: 14px; font-weight: 500; flex: 1;">{message}</span>
      {onClose && (
        <button
          onclick={onClose}
          style="background: none; border: none; font-size: 18px; cursor: pointer; color: inherit; padding: 0;"
          aria-label="Close notification"
        >
          ✕
        </button>
      )}
    </div>
  )
}

<style>
  @keyframes slideUp {
    from {
      transform: translateY(100px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
