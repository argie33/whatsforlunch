# ============================================
# LOCAL DEVELOPMENT (no AWS required)
# ============================================
# For local-only development with docker-compose:
#   cp apps/mobile/.env.local.example apps/mobile/.env.local
#
# Then run:
#   docker-compose -f docker-compose.local.yml up -d
#   pnpm dev:mobile

# ============================================
# AWS DEVELOPMENT STACK
# ============================================
# For AWS-based development:
#   pnpm cdk:deploy --context env=dev-$(whoami)
#   pnpm cdk:outputs
#
# Then fill in values below from the outputs

EXPO_PUBLIC_ENV=aws

# Cognito User Pool (from CDK outputs)
EXPO_PUBLIC_AWS_REGION=us-east-1
EXPO_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
EXPO_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AppSync GraphQL API (from CDK outputs)
EXPO_PUBLIC_APPSYNC_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql
EXPO_PUBLIC_APPSYNC_API_KEY=da2-xxxxxxxxxxxxxxxxxxxxxxxxxx

# S3 (from CDK outputs)
EXPO_PUBLIC_S3_BUCKET_PHOTOS=wfl-photos-dev-username

# ============================================
# Observability (optional)
# ============================================
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=

# ============================================
# Feature Flags
# ============================================
EXPO_PUBLIC_ENABLE_AI=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# ============================================
# Development
# ============================================
EXPO_PUBLIC_DEBUG=false
