# Copy this to .env.local for local development (no AWS needed)

EXPO_PUBLIC_API_URL=http://localhost:4000/graphql
EXPO_PUBLIC_WS_URL=ws://localhost:4000/graphql
EXPO_PUBLIC_AUTH_MODE=mock
EXPO_PUBLIC_COGNITO_USER_POOL_ID=local-pool-id
EXPO_PUBLIC_COGNITO_CLIENT_ID=local-client-id
EXPO_PUBLIC_COGNITO_REGION=us-east-1
EXPO_PUBLIC_AI_MODE=mock
EXPO_PUBLIC_SENTRY_ENABLED=false
EXPO_PUBLIC_POSTHOG_ENABLED=false
EXPO_PUBLIC_ENVIRONMENT=local
EXPO_PUBLIC_APP_URL=https://whatsforlunch.app
