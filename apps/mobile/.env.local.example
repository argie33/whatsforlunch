# ── Local dev environment — no AWS needed ──────────────────────────────────────
# Copy to .env.local:  cp apps/mobile/.env.local.example apps/mobile/.env.local
#
# Then choose your URL based on how you run the app:
#   iOS Simulator:       http://localhost:4000/graphql   (default below)
#   Android Emulator:    http://10.0.2.2:4000/graphql
#   Physical device:     http://<your-LAN-IP>:4000/graphql

EXPO_PUBLIC_APPSYNC_URL=http://localhost:4000/graphql

# "local" = call local API server (JWT auth, no Cognito)
# "mock"  = purely offline stub (no server needed)
EXPO_PUBLIC_AUTH_MODE=local

# Dummy Cognito values (ignored in local mode)
EXPO_PUBLIC_AWS_REGION=us-east-1
EXPO_PUBLIC_COGNITO_USER_POOL_ID=local
EXPO_PUBLIC_COGNITO_CLIENT_ID=local
EXPO_PUBLIC_COGNITO_IDENTITY_POOL_ID=local

# Leave blank to disable Sentry/PostHog in local dev
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
