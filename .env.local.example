# Local Development Environment
# Copy this to .env.local and adjust as needed

# ============================================
# Backend (GraphQL API)
# ============================================
GRAPHQL_ENDPOINT=http://localhost:4000/graphql
GRAPHQL_WS_ENDPOINT=ws://localhost:4000/graphql
NODE_ENV=development
PORT=4000

# ============================================
# DynamoDB Local Configuration
# ============================================
AWS_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
USE_LOCAL_DYNAMODB=true

# Table names
TABLE_NAME=wfl-main-dev
AUTH_CHALLENGES_TABLE=wfl-auth-challenges-dev

# ============================================
# S3 Local Configuration
# ============================================
# Using LocalStack S3
S3_ENDPOINT=http://localhost:4566
PHOTOS_BUCKET=wfl-photos-dev
EXPORTS_BUCKET=wfl-exports-dev
ASSETS_BUCKET=wfl-assets-dev
USE_LOCAL_S3=true

# ============================================
# Authentication (Local JWT)
# ============================================
JWT_SECRET=dev-secret-not-for-production
TOKEN_TTL=3600
REFRESH_TOKEN_TTL=2592000
USE_MOCK_AUTH=true

# ============================================
# AI Services (Mocked locally)
# ============================================
USE_MOCK_AI=true
BEDROCK_REGION=us-east-1
BEDROCK_MODEL=claude-3-5-haiku-20241022

# ============================================
# Mobile App
# ============================================
# For physical device testing, replace localhost with your machine IP
# Find with: ipconfig (Windows) or ifconfig (Mac/Linux)
MOBILE_API_URL=http://localhost:4000
MOBILE_WS_URL=ws://localhost:4000

# Expo configuration
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_WS_URL=ws://localhost:4000

# ============================================
# Debugging & Logging
# ============================================
LOG_LEVEL=debug
DEBUG=true
SKIP_ENV_VALIDATION=true

# ============================================
# Database Management
# ============================================
# DynamoDB Admin UI
DYNAMODB_ADMIN_PORT=8001

# Redis (optional, for caching in Phase B)
REDIS_URL=redis://localhost:6379

# ============================================
# Feature Flags (Local Development)
# ============================================
# All features enabled locally for testing
FEATURE_OFFLINE_MODE=true
FEATURE_PHOTO_UPLOAD=true
FEATURE_OCR=true
FEATURE_AI_CLASSIFICATION=true
FEATURE_VOICE_INPUT=false  # Not yet implemented
