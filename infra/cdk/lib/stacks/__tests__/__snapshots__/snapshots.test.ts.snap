    "DeleteAccountFn90E69631": {
      "DependsOn": [
        "DeleteAccountFnServiceRoleDefaultPolicy08AB12EC",
        "DeleteAccountFnServiceRole223B4FBA",
      ],
      "Properties": {
        "Code": {
          "ZipFile": "
        const { DynamoDBClient } = require('@aws-sdk/client-dynamodb');
        const { DynamoDBDocumentClient, UpdateCommand } = require('@aws-sdk/lib-dynamodb');
        const ddb = DynamoDBDocumentClient.from(new DynamoDBClient({}));
        exports.handler = async (event) => {
          const userId = event.identity?.sub;
          if (!userId) throw new Error('Unauthorized');
          await ddb.send(new UpdateCommand({
            TableName: process.env.MAIN_TABLE,
            Key: { PK: 'USER#' + userId, SK: 'PROFILE' },
            UpdateExpression: 'SET deletionScheduledAt = :t, updatedAt = :now, _version = _version + :inc',
            ExpressionAttributeValues: {
              ':t': new Date(Date.now() + 30 * 86400000).toISOString(),
              ':now': new Date().toISOString(),
              ':inc': 1,
            },
          }));
          return true;
        };
      ",
        },
        "Environment": {
          "Variables": {
            "MAIN_TABLE": {
              "Fn::ImportValue": "CompData:ExportsOutputRefMainTable74195DAB4503BD7E",
            },
          },
        },
        "Handler": "index.handler",
        "MemorySize": 256,
        "Role": {
          "Fn::GetAtt": [
            "DeleteAccountFnServiceRole223B4FBA",
            "Arn",
          ],
        },
        "Runtime": "nodejs20.x",
        "Timeout": 30,
      },
      "Type": "AWS::Lambda::Function",
    },
