        "Definition": """"
WhatsForLunch GraphQL API Schema
Source of truth for mobile client + Lambda business logic
Primary data source: DynamoDB single-table (wfl-main-{env})
Authorizer: Cognito User Pools
Subscriptions: AppSync real-time (WebSocket)
"""

schema {
  query: Query
  mutation: Mutation
  subscription: Subscription
}

# ============================================
# SCALARS
# ============================================

scalar AWSDateTime
scalar AWSEmail
scalar AWSURL
scalar AWSJSON
scalar UUID
scalar Date

# ============================================
# ENUMS
# ============================================

enum StorageLocation {
  fridge
  freezer
  pantry
  counter
  lunchbox
}

enum ItemStatus {
  active
  partial
  eaten
  tossed
  frozen
  transferred
}

enum ExpirySource {
  rule
  ai
  ocr
  barcode
  user
}

enum HouseholdRole {
  owner
  member
  viewer
}

enum SubscriptionTier {
  free
  premium
  family
}

enum FoodCategory {
  protein
  grain
  dairy
  produce
  leftover
  sauce
  baked
  prepared
  beverage
}

enum EventType {
  created
  photoAdded
  aiClassified
  ocrProcessed
  edited
  markedEaten
  markedTossed
  markedFrozen
  markedPartial
  transferred
  snoozed
}

# ============================================
# TYPES
# ============================================

type GeoPoint {
  lat: Float!
  lng: Float!
  accuracy: Float
}

type Profile @aws_cognito_user_pools {
  id: UUID!
  email: AWSEmail!
  displayName: String
  photoUrl: AWSURL
  timeZone: String!
  units: String!
  locale: String!
  dietaryPreferences: [String!]!
  cuisinePreferences: [String!]!
  allergies: [String!]!
  defaultHouseholdId: UUID
  homeLocation: GeoPoint
  subscriptionTier: SubscriptionTier!
  subscriptionExpiresAt: AWSDateTime
  aiQuotaUsedToday: Int!
  aiQuotaResetAt: AWSDateTime!
  createdAt: AWSDateTime!
  updatedAt: AWSDateTime!
  _version: Int!
  _lastChangedAt: AWSDateTime!
}

type Household @aws_cognito_user_pools {
  id: UUID!
  name: String!
  ownerId: UUID!
  imageUrl: AWSURL
  memberCount: Int!
  members: [HouseholdMember!]!
  createdAt: AWSDateTime!
  updatedAt: AWSDateTime!
  _version: Int!
  _lastChangedAt: AWSDateTime!
}

type HouseholdMember @aws_cognito_user_pools {
  userId: UUID!
  displayName: String
  photoUrl: AWSURL
  role: HouseholdRole!
  joinedAt: AWSDateTime!
}

type HouseholdInvite @aws_cognito_user_pools {
  id: UUID!
  householdId: UUID!
  token: String!
  expiresAt: AWSDateTime!
  createdBy: UUID!
  acceptedBy: UUID
  acceptedAt: AWSDateTime
}

type Container @aws_cognito_user_pools {
  id: UUID!
  householdId: UUID!
  qrToken: String!
  nickname: String
  imageUrl: AWSURL
  claimedAt: AWSDateTime!
  claimedBy: UUID!
  archivedAt: AWSDateTime
  currentItem: Item
  history(limit: Int = 50): [Item!]!
  createdAt: AWSDateTime!
  updatedAt: AWSDateTime!
  _version: Int!
  _lastChangedAt: AWSDateTime!
}

type Item @aws_cognito_user_pools {
  id: UUID!
  householdId: UUID!
  containerId: UUID
  container: Container
  addedByUserId: UUID!
  addedBy: HouseholdMember
  foodType: String!
  foodName: String!
  category: FoodCategory!
  storageLocation: StorageLocation!
  quantityText: String
  quantityValue: Float
  quantityUnit: String
  storedAt: AWSDateTime!
  storedTz: String!
  expiryAt: AWSDateTime!
  expirySource: ExpirySource!
  expiryConfidence: Float
  notes: String
  photoUrl: AWSURL
  barcode: String
  barcodeData: BarcodeData
  priceUsd: Float
  nutritionalData: NutritionalData
  status: ItemStatus!
  eatenAt: AWSDateTime
  tossedAt: AWSDateTime
  frozenAt: AWSDateTime
  transferredToContainerId: UUID
  events(limit: Int = 20): [ItemEvent!]!
  hoursUntilExpiry: Int!
  statusColor: String!
  createdAt: AWSDateTime!
  updatedAt: AWSDateTime!
  deletedAt: AWSDateTime
  _version: Int!
  _lastChangedAt: AWSDateTime!
}

type BarcodeData {
  brand: String
  product: String
  servingSize: String
  imageUrl: AWSURL
}

type NutritionalData {
  calories: Float
  protein: Float
  carbs: Float
  fat: Float
  fiber: Float
  sugar: Float
  sodium: Float
}

type FoodRule @aws_cognito_user_pools {
  foodType: String!
  displayName: String!
  category: FoodCategory!
  aliases: [String!]!
  fridgeDaysSafe: Int!
  freezerDaysSafe: Int
  pantryDaysSafe: Int
  counterHoursSafe: Int
  description: String
  iconKey: String
  version: Int!
}

type ItemEvent @aws_cognito_user_pools {
  id: UUID!
  itemId: UUID!
  actorUserId: UUID!
  actor: HouseholdMember
  eventType: EventType!
  payload: AWSJSON
  createdAt: AWSDateTime!
}

type AiClassification @aws_cognito_user_pools {
  id: UUID!
  itemId: UUID!
  model: String!
  promptVersion: Int!
  response: AWSJSON!
  confidence: Float!
  userOverrode: Boolean!
  latencyMs: Int!
  costUsd: Float
  cacheHit: Boolean
  createdAt: AWSDateTime!
}

type OcrJob @aws_cognito_user_pools {
  id: UUID!
  kind: String!
  status: String!
  result: AWSJSON
  confidence: Float
  createdAt: AWSDateTime!
}

type ShoppingListItem @aws_cognito_user_pools {
  id: UUID!
  householdId: UUID!
  name: String!
  quantity: String
  category: String
  notes: String
  addedByUserId: UUID!
  addedBy: HouseholdMember
  purchasedAt: AWSDateTime
  purchasedByUserId: UUID
  autoSuggested: Boolean!
  linkedFoodType: String
  createdAt: AWSDateTime!
  updatedAt: AWSDateTime!
  _version: Int!
  _lastChangedAt: AWSDateTime!
}

type Recipe @aws_cognito_user_pools {
  id: UUID!
  householdId: UUID
  title: String!
  summary: String
  cuisine: String
  servings: Int!
  cookTimeMinutes: Int!
  difficulty: String!
  ingredients: [RecipeIngredient!]!
  steps: [String!]!
  tags: [String!]!
  imageUrl: AWSURL
  source: String!
  aiPromptVersion: Int
  usedItemIds: [UUID!]
  cookedAt: [AWSDateTime!]
  rating: Int
  notes: String
  createdAt: AWSDateTime!
  updatedAt: AWSDateTime!
  _version: Int!
  _lastChangedAt: AWSDateTime!
}

type RecipeIngredient {
  name: String!
  quantity: Float
  unit: String
  optional: Boolean
}

type Device @aws_cognito_user_pools {
  id: UUID!
  userId: UUID!
  expoPushToken: String
  platform: String!
  appVersion: String
  osVersion: String
  model: String
  lastSeenAt: AWSDateTime!
  pushEnabled: Boolean!
}

# ============================================
# DELTA SYNC (for offline-first sync engine)
# ============================================

type DeltaSyncResponse @aws_cognito_user_pools {
  items: [Item!]!
  containers: [Container!]!
  shoppingList: [ShoppingListItem!]!
  serverTimestamp: AWSDateTime!
}

type DeletedItemRef {
  id: UUID!
  entityType: String!
  deletedAt: AWSDateTime!
}

type ImageUploadResponse @aws_cognito_user_pools {
  uploadUrl: AWSURL!
  imageKey: String!
  expiresIn: Int!
}

# ============================================
# INPUT TYPES
# ============================================

input UpdateProfileInput {
  displayName: String
  photoUrl: AWSURL
  timeZone: String
  units: String
  locale: String
  dietaryPreferences: [String!]
  cuisinePreferences: [String!]
  allergies: [String!]
  defaultHouseholdId: UUID
  homeLocation: GeoPointInput
}

input GeoPointInput {
  lat: Float!
  lng: Float!
  accuracy: Float
}

input CreateHouseholdInput {
  name: String!
  imageUrl: AWSURL
}

input UpdateHouseholdInput {
  householdId: UUID!
  name: String
  imageUrl: AWSURL
}

input InviteHouseholdMemberInput {
  householdId: UUID!
}

input AcceptHouseholdInviteInput {
  token: String!
}

input RemoveHouseholdMemberInput {
  householdId: UUID!
  userId: UUID!
}

input CreateContainerInput {
  householdId: UUID!
  nickname: String
  imageUrl: AWSURL
}

input UpdateContainerInput {
  containerId: UUID!
  householdId: UUID!
  nickname: String
  imageUrl: AWSURL
}

input ArchiveContainerInput {
  containerId: UUID!
  householdId: UUID!
}

input ClaimContainerInput {
  householdId: UUID!
  qrToken: String!
}

input CreateItemInput {
  householdId: UUID!
  containerId: UUID
  foodType: String!
  foodName: String!
  category: FoodCategory!
  storageLocation: StorageLocation!
  quantityText: String
  quantityValue: Float
  quantityUnit: String
  expiryAt: AWSDateTime!
  expirySource: ExpirySource!
  expiryConfidence: Float
  notes: String
  photoUrl: AWSURL
  barcode: String
  priceUsd: Float
  nutritionalData: NutritionalDataInput
}

input NutritionalDataInput {
  calories: Float
  protein: Float
  carbs: Float
  fat: Float
  fiber: Float
  sugar: Float
  sodium: Float
}

input UpdateItemInput {
  householdId: UUID!
  id: UUID!
  foodName: String
  storageLocation: StorageLocation
  quantityText: String
  quantityValue: Float
  quantityUnit: String
  expiryAt: AWSDateTime
  notes: String
  _version: Int!
}

input MarkItemEatenInput {
  householdId: UUID!
  id: UUID!
  _version: Int!
}

input MarkItemTossedInput {
  householdId: UUID!
  id: UUID!
  _version: Int!
}

input MarkItemFrozenInput {
  householdId: UUID!
  id: UUID!
  _version: Int!
}

input MarkItemPartialInput {
  householdId: UUID!
  id: UUID!
  _version: Int!
}

input TransferItemInput {
  householdId: UUID!
  id: UUID!
  toContainerId: UUID!
  _version: Int!
}

# ============================================
# RESTAURANTS (Wave 3 - Nearby Recommendations)
# ============================================

type DeliveryPlatform @aws_cognito_user_pools {
  platform: String!
  deepLink: String!
}

type Restaurant @aws_cognito_user_pools {
  placeId: String!
  name: String!
  address: String!
  cuisineTypes: [String!]!
  rating: Float!
  priceLevel: Int
  distanceMeters: Int!
  isOpenNow: Boolean!
  deliveryPlatforms: [DeliveryPlatform!]!
  aiScore: Float!
  aiReason: String!
}

# ============================================
# QUERIES
# ============================================

type Query {
  # Profile
  getProfile: Profile! @aws_cognito_user_pools
  getProfileById(userId: UUID!): Profile @aws_cognito_user_pools

  # Households
  listHouseholds: [Household!]! @aws_cognito_user_pools
  getHousehold(id: UUID!): Household @aws_cognito_user_pools

  # Household members
  listHouseholdMembers(householdId: UUID!): [HouseholdMember!]! @aws_cognito_user_pools

  # Containers
  listContainers(householdId: UUID!): [Container!]! @aws_cognito_user_pools
  getContainer(id: UUID!, householdId: UUID!): Container @aws_cognito_user_pools
  getContainerByQrToken(qrToken: String!): Container @aws_cognito_user_pools

  # Items
  listItems(householdId: UUID!, limit: Int = 50): [Item!]! @aws_cognito_user_pools
  getItem(id: UUID!, householdId: UUID!): Item @aws_cognito_user_pools
  listExpiringItems(householdId: UUID!, days: Int = 14): [Item!]! @aws_cognito_user_pools
  listItemsByContainer(containerId: UUID!, householdId: UUID!): [Item!]! @aws_cognito_user_pools
  searchItems(householdId: UUID!, query: String!): [Item!]! @aws_cognito_user_pools

  # Food Rules
  listFoodRules: [FoodRule!]! @aws_cognito_user_pools
  getFoodRule(foodType: String!): FoodRule @aws_cognito_user_pools

  # Recipe Recommendations (AI-powered via Bedrock Claude)
  getRecipeRecommendations(householdId: UUID!): [Recipe!]! @aws_cognito_user_pools

  # Nearby Restaurants (Wave 3 - Google Places + Claude ranking)
  getNearbyRestaurants(householdId: UUID!, latitude: Float!, longitude: Float!): [Restaurant!]! @aws_cognito_user_pools

  # Invites
  getHouseholdInvite(token: String!): HouseholdInvite @aws_cognito_user_pools

  # Shopping List
  listShoppingItems(householdId: UUID!): [ShoppingListItem!]! @aws_cognito_user_pools

  # Sync (for offline-first)
  deltaSync(
    householdId: UUID!
    lastSyncAt: AWSDateTime!
    limit: Int = 100
  ): DeltaSyncResponse! @aws_cognito_user_pools
}

# ============================================
# MUTATIONS
# ============================================

type Mutation {
  # Profile
  updateProfile(input: UpdateProfileInput!): Profile! @aws_cognito_user_pools
  deleteAccount: Boolean! @aws_cognito_user_pools
  exportData: String! @aws_cognito_user_pools

  # Households
  createHousehold(input: CreateHouseholdInput!): Household! @aws_cognito_user_pools
  updateHousehold(input: UpdateHouseholdInput!): Household! @aws_cognito_user_pools
  deleteHousehold(householdId: UUID!): Boolean! @aws_cognito_user_pools
  inviteHouseholdMember(input: InviteHouseholdMemberInput!): HouseholdInvite! @aws_cognito_user_pools
  acceptHouseholdInvite(input: AcceptHouseholdInviteInput!): Household! @aws_cognito_user_pools
  removeHouseholdMember(input: RemoveHouseholdMemberInput!): Boolean! @aws_cognito_user_pools

  # Containers
  createContainer(input: CreateContainerInput!): Container! @aws_cognito_user_pools
  updateContainer(input: UpdateContainerInput!): Container! @aws_cognito_user_pools
  archiveContainer(input: ArchiveContainerInput!): Container! @aws_cognito_user_pools
  claimContainer(input: ClaimContainerInput!): Container! @aws_cognito_user_pools

  # Items
  createItem(input: CreateItemInput!): Item! @aws_cognito_user_pools
  updateItem(input: UpdateItemInput!): Item! @aws_cognito_user_pools
  deleteItem(householdId: UUID!, id: UUID!): Boolean! @aws_cognito_user_pools
  markItemEaten(input: MarkItemEatenInput!): Item! @aws_cognito_user_pools
  markItemTossed(input: MarkItemTossedInput!): Item! @aws_cognito_user_pools
  markItemFrozen(input: MarkItemFrozenInput!): Item! @aws_cognito_user_pools
  markItemPartial(input: MarkItemPartialInput!): Item! @aws_cognito_user_pools
  transferItem(input: TransferItemInput!): Item! @aws_cognito_user_pools

  # AI Operations (call Lambda functions)
  classifyFood(householdId: UUID!, photoUrl: AWSURL!): Item! @aws_cognito_user_pools
  ocrExpiryDate(householdId: UUID!, photoUrl: AWSURL!): String! @aws_cognito_user_pools

  # Photo Management
  uploadImage(householdId: UUID!, filename: String!, contentType: String!, size: Int!): ImageUploadResponse! @aws_cognito_user_pools

  # Shopping List
  addShoppingItem(householdId: UUID!, name: String!, quantity: String): ShoppingListItem! @aws_cognito_user_pools
  markShoppingItemPurchased(householdId: UUID!, id: UUID!): ShoppingListItem! @aws_cognito_user_pools
  deleteShoppingItem(householdId: UUID!, id: UUID!): Boolean! @aws_cognito_user_pools
}

# ============================================
# SUBSCRIPTIONS (real-time updates)
# ============================================

type Subscription {
  onHouseholdUpdate(householdId: UUID!): Household
    @aws_cognito_user_pools
    @aws_subscribe(mutations: ["updateHousehold", "updateContainer", "createItem", "updateItem", "deleteItem"])

  onItemUpdate(householdId: UUID!): Item
    @aws_cognito_user_pools
    @aws_subscribe(mutations: ["createItem", "updateItem", "markItemEaten", "markItemTossed", "markItemFrozen", "markItemPartial", "transferItem"])

  onMemberJoined(householdId: UUID!): HouseholdMember
    @aws_cognito_user_pools
    @aws_subscribe(mutations: ["acceptHouseholdInvite"])
}
",
      },
      "Type": "AWS::AppSync::GraphQLSchema",
    },
    "ArchiveContainerDataFn2F1852EB": {
      "DependsOn": [
        "ApiDynamoDbDs27372B9D",
        "ApiSchema510EECD7",
      ],
      "Properties": {
        "ApiId": {
          "Fn::GetAtt": [
            "ApiF70053CD",
            "ApiId",
          ],
        },
        "Code": "
      export function request(ctx) {
        const i = ctx.args.input;
        return { operation: 'UpdateItem', key: { PK: { S: 'HOUSEHOLD#' + i.householdId }, SK: { S: 'CONTAINER#' + i.containerId } }, update: { expression: 'SET archivedAt = :now, _version = _version + :inc', expressionValues: { ':now': { S: util.time.nowISO8601() }, ':inc': { N: '1' } } } };
      }
      export function response(ctx) {
        if (ctx.error) util.error(ctx.error.message, ctx.error.type);
        return ctx.result;
      }
    ",
        "DataSourceName": "DynamoDbDs",
        "FunctionVersion": "2018-05-29",
        "Name": "ArchiveContainerDataFn",
        "Runtime": {
          "Name": "APPSYNC_JS",
          "RuntimeVersion": "1.0.0",
        },
      },
      "Type": "AWS::AppSync::FunctionConfiguration",
    },
    "CheckHouseholdMemberFn56AF4816": {
      "DependsOn": [
        "ApiDynamoDbDs27372B9D",
