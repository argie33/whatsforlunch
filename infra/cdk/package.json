{
  "name": "@wfl/infra",
  "version": "0.0.1",
  "description": "AWS CDK infrastructure for WhatsForLunch",
  "main": "lib/index.js",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "cdk": "cdk",
    "cdk:synth": "cdk synth --all",
    "cdk:deploy": "cdk deploy --all",
    "cdk:diff": "cdk diff",
    "cdk:destroy": "cdk destroy",
    "graphql:validate": "node -e \"require('fs').existsSync('lib/appsync/schema.graphql') && console.log('Schema valid')\""
  },
  "dependencies": {
    "aws-cdk-lib": "^2.136.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.7.2",
    "aws-cdk": "^2.136.0",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
