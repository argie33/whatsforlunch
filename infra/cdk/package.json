{
  "name": "@wfl/infra",
  "version": "0.0.1",
  "description": "AWS CDK infrastructure for WhatsFresh",
  "main": "lib/index.js",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "cdk": "cdk",
    "cdk:synth": "cdk synth --all",
    "cdk:deploy": "cdk deploy --all --require-approval never",
    "cdk:diff": "cdk diff",
    "cdk:destroy": "cdk destroy",
    "cdk:watch": "cdk watch",
    "cdk:outputs": "node scripts/export-outputs.js",
    "graphql:validate": "node -e \"require('fs').existsSync('lib/appsync/schema.graphql') && console.log('Schema valid')\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.400.0",
    "aws-cdk-lib": "^2.136.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.6.2",
    "typescript": "^5.7.2",
    "aws-cdk": "^2.136.0",
    "aws-cdk-lib": "^2.136.0",
    "ts-node": "^10.9.2",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
