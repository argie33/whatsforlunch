{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "outDir": "./cdk.out",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "jest"]
  },
  "include": ["lib/**/*", "bin/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "lib/appsync/resolvers/**",
    "lib/appsync/functions/**"
  ]
}
