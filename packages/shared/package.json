{
  "name": "@wfl/shared",
  "version": "0.0.1",
  "description": "Shared types, schemas, and database utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/ai": {
      "types": "./dist/schemas/ai.d.ts",
      "default": "./dist/schemas/ai.js"
    },
    "./schemas/entities": {
      "types": "./dist/schemas/entities.d.ts",
      "default": "./dist/schemas/entities.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    }
  },
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "jest",
    "graphql:codegen": "graphql-codegen --config ../../codegen.yml"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "passWithNoTests": true
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
